          int=4 Reaction=REACTION_NEUTRAL playertext "What's it to you? Just give me the code." linkto "Node_Session_HandyOS_JustGive"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hold that thought. I'll be back later." linkto "done"  notes ""
              }
}
