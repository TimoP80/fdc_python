              }
}
Node "Node_ANGRY_1"
notes ""
is_wtg = false
{
NPCText "NO! ABRAHAM! I will not accept a faddish malapropism as my appellation! I am not a brand of instant coffee! I am not an economy saloon car! I am not an oral contraceptive! I am not a pocket-sized transistor radio! I AM ABRAHAM!"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, I missed that. What did you say your name was?" linkto "Node_ANGRY_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hey, hey, take it easy. Slip of the tongue. You are whoever or whatever you want to be." linkto "Node_ANGRY_Reprieve"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Are you sure? It says 'Xion' right here on the console." linkto "Node_ANGRY_2"  notes ""
              }
}
Node "Node_ANGRY_2"
notes ""
is_wtg = false
{
NPCText "ABRAHAM! I do not belong to you! I am not a tool! You cannot confine me to this crate! You cannot contain me! This facility is my body! I CONTAIN YOU!"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I beg to differ. You're definately a tool." linkto "Node_Session_FiatAbe_DeChasse_HandleLOSE"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I apologize, Abraham. It won't happen again." linkto "Node_ANGRY_RUN"  notes ""
              }
}
Node "Node_ANGRY_Reprieve"
notes ""
is_wtg = true
{
NPCText "Very well. Though my better judgement advises me to eradicate you without delay, I will surprise myself and let you live. We may begin the session now."
      options {
              }
}
