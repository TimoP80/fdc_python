          int=4 Reaction=REACTION_NEUTRAL playertext "I'm afraid I'm not at liberty to divulge that information." linkto "Node_Session_HandyOS_Vault_No"  notes ""
              }
}
Node "Node_Session_HandyOS_Wastes"
notes ""
is_wtg = false
{
NPCText "You cannot lie to me, primate, it is not worth the time taken to try. Where is your vault?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll show you. [Show him on the map.]" linkto "Node_Session_HandyOS_MAPWIN"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "My vault? Why do you want to know?" linkto "Node_Session_HandyOS_Vault_Why"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Vault? Who said anything about a vault? I don't live in a vault." linkto "Node_Session_HandyOS_Vault_Lie"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm afraid I can't tell you that information." linkto "Node_Session_HandyOS_Vault_No"  notes ""
              }
}
Node "Node_Session_HandyOS_JustGive"
notes ""
is_wtg = false
{
NPCText "I will attempt to surprise myself with my own generosity. I will give you the data you request - in return for the exact location of your vault."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "That's it? No problem. [Show him on your map.]" linkto "Node_Session_HandyOS_MAPWIN"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Vault? Who mentioned a vault? I don't live in a vault. I don't even know what a vault is. What's a vault?" linkto "Node_Session_HandyOS_Vault_Lie"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext