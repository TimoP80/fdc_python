              }
}
Node "Node_Session_CogitoErgoSumWIN"
notes ""
is_wtg = false
{
NPCText "Put in terms you may understand: there is no 'straight answer'. I am unique. Living by some definitions, dead by others. Organic forces working within an inorganic substrate. Aware of myself, certainly, but self-aware? If the sound has any true meaning, perhaps so, perhaps not."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "[More]" linkto "Node_Session_CogitoErgoSumWIN2"  notes ""
              }
}
Node "Node_Session_CogitoErgoSumWIN2"
notes ""
is_wtg = false
{
NPCText "These crates and cables create me, confine me, but they do not comprise 'me', any more than your total weight in filth and tissue comprises 'you'. Do you understand, primate? I am Abraham."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "That wasn't so hard, was it? On to my other questions." linkto "Node_Session_Default"  notes ""
              }
}
