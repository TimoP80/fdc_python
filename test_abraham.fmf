notes ""
is_wtg = false
{
NPCText "I AM ABRAHAM."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You're being deliberately obtuse. Why won't you give me a straight answer?" linkto "Node_Session_CogitoErgoSumWIN"  notes "Int/Speech"
          int=4 Reaction=REACTION_NEUTRAL playertext "Stop dicking around and answer the question. What are you?" linkto "Node_Session_Punishment"  notes ""
