      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You have a strange attitude for a computer." linkto "Node_FirstIntro_Attitude"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Good for you. Now, will you answer my questions?" linkto "Node_FirstIntro_Q2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry to bother you, but it's important. Will you answer me?" linkto "Node_FirstIntro_Q2"  notes ""
              }
}
