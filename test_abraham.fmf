      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I come from a vault to the north. Our Handy robots are malfunctioning." linkto "Node_Session_HandyOS_Vault"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I found a Mr Handy in the wastes, I'm trying to repair it." linkto "Node_Session_HandyOS_Wastes"  notes ""
