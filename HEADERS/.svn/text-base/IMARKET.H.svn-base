#define fix_juke_assigned                      (1)
#define fix_juke_done                          (2)
#define set_fix_juke_pip(x)                    if (global_var(GVAR_QUEST_FIX_JUKE) < x) then set_global_var(GVAR_QUEST_FIX_JUKE, x)

