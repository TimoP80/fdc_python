/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.26.0-beta

*/

vars {
local var Jon_Free_Papers notes "This variable keeps track of whether the PC has given the papers from the GAI base to Jonathan for free." = 0;
export var Jon_Historian notes "This variable keeps track of whether Jonathan has told the PC what he knows about the history of Sandover. This allows the PC to relay the knowledge of Jon's expertise to the museum curator in Rusty Springs (exact nature of NPC not known at time of writing)." = 0;
local var Jon_Holodisk_Threat notes "This variable keeps track of whether the PC used the threat of violence to force Jonathan to give a voice recording of Sandover's history." = 0;
}
NPCName "Jonathan"
Location "Sandover (surface)."
Description "Jonathan is the 'billboard' character for Sandover, meaning that he tells the PC what is going on in Sandover, as well as giving a detailed history of the place. Jonathan is also one of the lead characters in the 'Find out about Sandover's history' quest. (See wiki)."
Unknown_Desc "a wirey old man."
Known_Desc "Jonathan."
Detailed_Desc "he is suffering from a chesty cough."
/* Dialogue starting conditions */

start_conditions
default_condition -1
{
cond target_node "Jon_1a_1"
{
    SSL "local_var(LVAR_Herebefore) == 0" var_param "" eval -1 value_to_check "" ini_index 6 link 0
},
cond target_node "Jon_1b_1"
{
    SSL "local_var(LVAR_Herebefore) == 1" var_param "" eval -1 value_to_check "" ini_index 9 link 0
}
};

/* Float message nodes */

Floatnode "Jon_Norm"
notes "Jonathan's default float node."
{
"*Cough, cough.*",
"Nothing quite like the great outdoors. *Cough.*",
"Sandover has come a long way, despite what others say about it.",
"Oh, to be twenty years younger.",
"Plenty of good eating on a rat.",
"I'll cough myself inside out, one of these days."
}
Floatnode "Jon_Bogus"
notes "Jonathan floats this node if he has been convinced by the PC that the bogus religious item is genuine."
{
"The bombs, *cough,* cleansed the world of superstition!",
"We are in a new golden age of science and rationality.",
"*Cough.* Thank, *cough,* goodness for the war.",
"I could not have lived before the war.",
"The more I learn about life before the war, the less I want to know.",
"No wonder the pre-war world destroyed itself."
}

/* Regular nodes */

Node "Jon_0"
notes ""
is_wtg = true
{
NPCText "- STARTING CONDITIONS -"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "The PC has not spoken to Jonathan before." linkto "Jon_1a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "The PC has spoken to Jonathan before." linkto "Jon_1b_1"  notes ""
              }
}
Node "Jon_1a_1"
notes ""
is_wtg = true
{
NPCText "Hello, there."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hi, my name's <PC>." linkto "Jon_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who are you?" linkto "Jon_1a_2b"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "'Lo." linkto "Jon_1a_2b"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Not want speak." linkto "done"  notes ""
              }
}
Node "Jon_1a_2a"
notes ""
is_wtg = false
{
NPCText "Nice to meet you, <PC>. I'm Jonathan."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about this place?" linkto "Jon_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you know where I can find the General Atomics International base?" linkto "Jon_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye for now." linkto "done"  notes ""
              }
}
Node "Jon_1a_2b"
notes ""
is_wtg = false
{
NPCText "My name is Jonathan. *Cough*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about this place?" linkto "Jon_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Watch where you're spraying that plegm, old-timer." linkto "Jon_1a_2b_B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you know where I can find the General Atomics International base?" linkto "Jon_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye for now." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "What this place I in?" linkto "Jon_2_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Why you cough?" linkto "Jon_1a_2b_B1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I want find G-A-I place." linkto "Jon_4_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I go now." linkto "done"  notes ""
              }
}
Node "Jon_1a_2b_B1"
notes ""
is_wtg = false
{
NPCText "I'm sorry. My breathing isn't what isn't used to be, I'm afraid."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You won't be doing any breathing at all, if you cough on me again." linkto "Jon_1a_2b_B2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about this place?" linkto "Jon_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you know where I can find the General Atomics International base?" linkto "Jon_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye for now." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "What this place I in?" linkto "Jon_2_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Tell me where G-A-I place. I find." linkto "Jon_4_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[Leave]" linkto "done"  notes ""
              }
}
Node "Jon_1a_2b_B2"
notes ""
is_wtg = false
{
NPCText "*Cough, cough.* Was that a threat?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You did it again! What did I just say? [Reach for weapon.]" linkto "combat"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about this place?" linkto "Jon_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you know where I can find the General Atomics International base?" linkto "Jon_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye for now." linkto "done"  notes ""
              }
}
Node "Jon_1b_1"
notes ""
is_wtg = true
{
NPCText "Oh, hello, again."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hello, Jonathan. Do you have time to answer a question?" linkto "Jon_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Just stopping by. 'Bye for now." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I ask question you?" linkto "Jon_9"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[Leave]" linkto "done"  notes ""
              }
}
Node "Jon_2_1"
notes ""
is_wtg = false
{
NPCText "This is Sandover. We have a lot of sick and diseased people living here. In fact, just about everyone is sick - *cough* - no one is turned away."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Is there anything interesting happening here at the moment?" linkto "Jon_2_2c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You sound ill yourself." linkto "Jon_2_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are there so many sick people living here?" linkto "Jon_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll be going. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I ask you 'thing diff'rent." linkto "Jon_9"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[Leave]" linkto "done"  notes ""
              }
}
Node "Jon_2_2a_1"
notes ""
is_wtg = false
{
NPCText "*Cough.* I don't know what you mean."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "That cough you've got doesn't sound too good." linkto "Jon_2_2a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are there so many sick people living here?" linkto "Jon_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll be going. Goodbye." linkto "done"  notes ""
              }
}
Node "Jon_2_2a_2"
notes ""
is_wtg = false
{
NPCText "Oh, that's nothing to worry about. Dr. Oswald says there's not much he can do about it, anyway."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why can't he do anything about your cough?" linkto "Jon_2_2a_3b_1"  notes "If the PC has completed the 'Fix the Autodoc' quest, go to Jon_2_2a_3c instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Who is Dr. Oswald?" linkto "Jon_2_2a_3a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are there so many sick people living here?" linkto "Jon_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you a question about something else?" linkto "Jon_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll be going. Goodbye." linkto "done"  notes ""
              }
}
Node "Jon_2_2a_3a"
notes ""
is_wtg = false
{
NPCText "As his name suggests, *cough,* he's the closest thing Sandover has to a doctor. You can find him on the upper level of the Sandover caves.  [He points to the mountain behind you, in which is set a guarded cave entrance.]"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are there so many sick people living here?" linkto "Jon_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why can't he do anything about your cough?" linkto "Jon_2_2a_3b_1"  notes "If the PC has completed the 'Fix the Autodoc' quest, go to Jon_2_2a_3c instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you a question about something else?" linkto "Jon_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll be going. Goodbye." linkto "done"  notes ""
              }
}
Node "Jon_2_2a_3b_1"
notes ""
is_wtg = false
{
NPCText "There probably isn't anything that *can* be done about it. *Cough.* It probably doesn't help that his Autodoc is broken, though."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Maybe I can fix the Autodoc." linkto "Jon_2_2a_3b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are there so many sick people living here?" linkto "Jon_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who is Dr. Oswald?" linkto "Jon_2_2a_3a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you a question about something else?" linkto "Jon_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll be going. Goodbye." linkto "done"  notes ""
              }
}
Node "Jon_2_2a_3b_2"
notes ""
is_wtg = false
{
NPCText "If you're mechanically inclined, that would be a great help to Sandover, even if it doesn't help me. Go speak to Saman about getting into the caves."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Where can I find Saman?" linkto "Jon_2_2a_3b_3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What else can you tell me about Sandover?" linkto "Jon_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are there so many sick people living here?" linkto "Jon_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who is Dr. Oswald?" linkto "Jon_2_2a_3a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you a question about something else?" linkto "Jon_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll be going. Goodbye." linkto "done"  notes ""
              }
}
