      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What else can you tell me about Sandover?" linkto "Jon_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are there so many sick people living here?" linkto "Jon_2_2b_1"  notes ""
