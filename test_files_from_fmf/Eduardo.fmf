Node "B_B_Aa_C"
notes ""
{
NPCText "Young man, I've had just about enough of your attitude. Did you have anything important to say, or will you stop wasting my time?"
 NPCFemaleText "Young woman, I've had just about enough of your attitude. Did you have anything important to say, or will you stop wasting my time?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, I had some questions..." linkto "B_B_Aa_C_A"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You don't have to be grumpy just because you're old you know. Goodbye." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "All right, I'll leave." linkto "done"  notes ""
              }
}
