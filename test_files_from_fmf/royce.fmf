Node "Node_Q_Business"
notes ""
is_wtg = false
{
NPCText "Took my whole life, but this here operation runs slicker than pigshit. I buy my fish straight out of the nets, gut them, salt them, pack them up and send them out the other door at twice the price. And no waste - I even got a guy who buys the innards."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who do you sell your fish to?" linkto "Node_Q_Business3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who would want to buy fish guts from you?" linkto "Node_Q_Business2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you something else." linkto "Node_Questions2"  notes ""
              }
}
