NPCName "Royce"
Location "Royce's Warehouse, CotC"
Description "Royce is the owner of a warehouse. A dwarf, a letch and a miser."
Unknown_Desc "You see a greasy little man."
Known_Desc "You see: Royce."
Detailed_Desc "He looks like he's in charge."
/* Float message nodes */

Floatnode "Intimidated"
notes "If the PC has intimidated royce to stay away from daisy"
{
"Leave me alone.",
"I haven't been near her, I swear it.",
"I ain't saying nothing.",
"Just get out of here.",
"What's your problem?",
"I said I ain't been near her, now leave me be!"
}
Floatnode "RobCaught"
notes "If the PC is caught robbing Royce (or admits it after)"
{
"Die, shithead!",
"Die!",
"Bitch! Bitch! Bitch! (fem only)",
"You ain't getting away with this!",
"I'm gunna cut out your eyes and piss in your skull!"
}
Floatnode "Sleeping"
notes "While Royce is sleeping"
{
"Mmmn.... zzz....",
"Zzz... mmm... right there...",
"Zzz... precious...",
"... Zzz...."
}
Floatnode "WakeAlarm"
notes "When the PC nearly wakes up Royce (failed lockpick, first sneak fail)"
{
"Guh? Hngh...",
"Uh? Hhmm... zzz...",
"Ggh... bbgzzz...."
}
Floatnode "Waking"
notes "When Royce is awoken by the PC"
{
"Wha? Who's there?",
"Get out! Get out you piece of shit, get out!",
"I'll kill you, you son of a bitch! Come here!",
"I'll rip your eyes out and spit in the sockets!",
"You're dead! You hear? Next time, you're a dead man!"
}
Floatnode "Idle"
notes "Floats while idling in the day"
{
"Can't you idiots work any faster?",
"Mmm... smells like success.",
"You! Work harder!",
"Are you trying to put me out of business?! Work!",
"Good help is hard to find.",
"Hogg better come up with the goods next time."
}
Floatnode "RobbedIdle"
notes "idling after he's been robbed"
{
"When I catch that son of a bitch...",
"Oh he'll pay alright. He'll pay. He'll pay with his blood.",
"Thinks he can just steal from me? From ME?!",
"... and then I'll cut him, and I'll slice him and I'll cut him some more..."
}
Floatnode "OffTime"
notes "if the PC tries to talk to Royce outside of working hours"
{
"Come back tomorrow.",
"We start work again in the morning.",
"You can keep working if you want, but I ain't paying you for it.",
"We're closed."
}
Floatnode "TooDumb"
notes "If a dumb PC has infuriated Royce with his stupidity"
{
"There's no place for you here.",
"You drag your knuckles somewhere else now, y'hear?",
"Are you lost?",
"The door's right over there.",
"Someone should put this idiot in a circus."
}
Floatnode "Accused"
notes "PC has accused Royce of the murder (or assisting murder) and Royce is locked up"
{
"This is bullshit. I never killed anyone.",
"Why would I want to kill some dyke bitch anyway?",
"How much is this going to cost me?",
"Whose dick do I gotta suck to get someone to listen to me?",
"You better make up for my losses when you figure this out."
}

/* Regular nodes */

Node "switcher"
notes ""
is_wtg = false
{
NPCText "ding"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "<default>" linkto "Node_DefaultIntro"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "<First Meeting>" linkto "Node_FirstIntro"  notes "PC meets Royce for the first time (before 12.00 noon)"
          int=4 Reaction=REACTION_NEUTRAL playertext "<Subsequent Meeting>" linkto "Node_NextIntro"  notes "PC has already talked to Royce but not worked for him"
          int=4 Reaction=REACTION_NEUTRAL playertext "<Post Noon>" linkto "Node_NoonIntro"  notes "If the PC talks to Royce after mid-day (but during working hours)"
          int=4 Reaction=REACTION_NEUTRAL playertext "<Post Job>" linkto "Node_JobIntro"  notes "if the pc has worked for royce (including quitting, shirking etc)"
          int=4 Reaction=REACTION_NEUTRAL playertext "<Post Robbed>" linkto "Node_RobIntro"  notes "if the PC has robbed Royce"
          int=4 Reaction=REACTION_NEUTRAL playertext "<Post-Daisy Invite>" linkto "Node_DaisyIntro"  notes "If the PC has agreed to deliver Royce's message to Daisy"
          int=4 Reaction=REACTION_NEUTRAL playertext "<Mid-shift Dialogue>" linkto "Node_MidShift"  notes "If the PC talks to Royce while working in the warehouse, or if the PC attempts to leave the warehouse during that time"
          int=4 Reaction=REACTION_NEUTRAL playertext "<End of Shift Dialogue>" linkto "Node_JobEnd"  notes "When the pc scoops up the last piece of guts or uses the gutting table (ie finishes the job)"
          int=4 Reaction=REACTION_NEUTRAL playertext "<Sleeping Royce>" linkto "Node_Sleeping"  notes "When the pc catches Royce asleep in his bed"
          int=4 Reaction=REACTION_NEUTRAL playertext "<Post Murder>" linkto "Node_MurderIntro"  notes "The first time the PC talks to Royce after Daisy has been killed"
          int=-3 Reaction=REACTION_NEUTRAL playertext "Dumb First Meeting" linkto "Node_FirstIntro"  notes "If the PC is dumb and has never spoken to Royce before"
          int=-3 Reaction=REACTION_NEUTRAL playertext "Dumb Subsequent Meeting" linkto "Node_NextIntro"  notes "If the PC is dumb and has spoken to Royce before, but never accepted a job."
          int=-3 Reaction=REACTION_NEUTRAL playertext "Dumb Post Job" linkto "Node_JobIntro"  notes "If the PC is dumb and has worked for Royce before"
          int=-3 Reaction=REACTION_NEUTRAL playertext "Dumb Midshift" linkto "Node_MidShift"  notes "If a dumb PC speaks to Royce while working for him, or attempts to leave the warehouse during that time"
          int=-3 Reaction=REACTION_NEUTRAL playertext "Dumb End Shift" linkto "Node_JobEnd"  notes "If the PC is dumb and finishes his job"
          int=4 Reaction=REACTION_NEUTRAL playertext "Dumb Post-robbed" linkto "Node_RobDumb"  notes "If the PC is dumb and has robbed Royce"
          int=4 Reaction=REACTION_NEUTRAL playertext "Dumb Royce Sleeping" linkto "Node_Sleeping"  notes ""
              }
}
