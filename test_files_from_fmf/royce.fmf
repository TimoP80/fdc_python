Node "Node_JobInfoCleaning"
notes ""
is_wtg = false
{
NPCText "Everybody starts on shovel detail, even fancy folk like you. Just scoop all the fish guts off the floor, and into these green barrels. Shift lasts as long as the sunlight, pays ten caps a day. Get to work."
 NPCFemaleText "Everybody starts on the shovel, even a precious thing like you. Just scoop all the fish guts off the floor and into these green barrels. Shift lasts as long as the sunlight, pays ten caps a day. You want it? Get started."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm on it." linkto "Node_JobStart"  notes "Variable CleaningWork = 1"
          int=4 Reaction=REACTION_NEUTRAL playertext "A whole day's work for ten caps? I want twenty, not a cap less." linkto "Node_JobBarter"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Wow, that smell just hit me. I quit." linkto "Node_JobQuit"  notes ""
              }
}
