              }
}
Node "Refusal4"
notes ""
is_wtg = false
{
NPCText "But -"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "But nothing, Ken. You got yourselves into this mess, you get yourselves out." linkto "done"  notes "This leads to the cutscene."
              }
}
Node "Team1"
notes ""
is_wtg = false
{
NPCText "However, this is too important to rest entirely in the hands of one person. For that reason, we have selected a team of qualified staff that will accompany you. You will rendezvous with your team at the Vault door."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Anything else I should know?" linkto "Team2"  notes "This option should spawn the NPC teammates by the door."
          int=4 Reaction=REACTION_NEUTRAL playertext "Who's on the team?" linkto "Team3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Ken, you've seen my file. I can do this on my own." linkto "Solo1" conditions { CHECK_SKILL speech > 34 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I was GOING to say that you've got the wrong man." linkto "Refusal3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You can count on me!" linkto "End1"  notes "This option should spawn the NPC teammates by the door."
              }
}
