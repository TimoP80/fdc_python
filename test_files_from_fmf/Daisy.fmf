/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.27.0-stable

*/

vars {
local var Daisy_Temper notes "This variable keeps track of Daisy's temper. If it falls to -3 or below, the PC will be unable to open future dialogues with her. She will float appropriate lines instead." = 0;
local var Daisy_Grace_Dead notes "This variable keeps track of whether or not the PC has shown condolences to Daisy when she tells the PC that her mother died six years ago. It prevents the player from repeatedly clicking on the node to increase the local variable Daisy_Temper ad infinitum." = 0;
}
NPCName "Daisy Duket"
Location "Cutty Sark, City on the Coast."
Description "Daisy is involved in the 'Find a date for Daisy' and 'Who killed Daisy?' quests. See the CotC section of the DevWiki for details."
Unknown_Desc "You see: a very attractive young woman."
Known_Desc "You see: Daisy. She looks busy."
Detailed_Desc "PC is male or has a charisma of 6 or less: She's struggling with the unwanted attention of the bar's male clientele. Daisy is not a follower, and the PC is female and has a charisma of 7 or above (random chance, say 15% that this happens, else the previous message shows): For a split second, Daisy looks up and your glances meet. She quickly looks away, but with a hint of a smile on her lips. Daisy is a follower: She looks up and as your eyes meet, she gives you a wink."
/* Float message nodes */

Floatnode "Daisy_Normal"
notes "Daisy floats these lines under default circumstances."
{
"I could see that was going to spill over.",
"Damn it, that'll take forever to clean out.",
"For the last time, no, I won't do anything of the sort for money.",
"*Sigh.* Men.",
"Who was that who pinched my butt?",
"Don't you fellas ever think about anything else?"
}
Floatnode "Daisy_Dyke"
notes "Daisy floats these lines if the rumor is out that she is a lesbian."
{
"Yeah, never mind what you heard.",
"You just go on thinking what you like.",
"*Sigh.* I can't put up with this for much longer.",
"Gossip: the one thing faster than light.",
"I have to get out of here.",
"Who said that? Who just called me a dyke?"
}
Floatnode "Daisy_Annoyed"
notes "Daisy floats these lines if the local variable Daisy_Temper =< -3 and the PC tries to speak to her directly."
{
"I got nothing more to say to you.",
"What makes you think I want any more of your abuse?",
"You just stay away from me, or I'll have my father deal with you.",
"Yeah, I can see you there.",
"Talk to the hand.",
"The face ain't listenin'."
}
Floatnode "DaisyF_Hurt"
notes "Daisy floats these lines if she is a follower and is hurt."
{
"I suppose I knew traveling weren't gonna be easy, but...",
"Can we rest soon?",
"I think I need some of your TLC over here, honey.",
"I hope you can look after me, girl.",
"Damn, that stings.",
"Am I slowing you down?"
}
Floatnode "DaisyF_Badly_Hurt"
notes "Daisy floats these lines if she is a follower and is badly hurt."
{
"*Sob*",
"This... really hurts.",
"Seriously, honey, I don't think I can go on much longer.",
"I feel faint.",
"I really need a doctor.",
"I wish my Daddy was here."
}
Floatnode "DaisyF_Poisoned"
notes "Daisy floats these lines if she is a follower and is poisoned."
{
"Woah, I don't feel none too good.",
"It's like the worst hangover I've ever had, except worse.",
"You got any antidote in that bag of yours?",
"Something is *seriously* disagreeing with my tummy.",
"I think I'm going to need the bathroom sometime soon.",
"Did something flash over there, or is it just my eyes?"
}
Floatnode "DaisyF_Radiated"
notes "Daisy floats these lines if she is a follower and is radiated."
{
"My hair! Some of my hair just fell out!",
"Oh god, I think I'm gonna puke.",
"So this is what the rad sickness is like.",
"I don't wanna die like this.",
"Honey? You need to get me to a doctor real soon.",
"Oh shit, my gums are bleeding."
}
Floatnode "DaisyF_Drugs"
notes "Daisy floats these lines if she is a follower and PC uses drugs on her."
{
"Is that even legal?",
"I hope you kept some for yourself!",
"Is this going to make me go crazy?",
"Do you even know what that stuff does?",
"I hope you know what you're doing.",
"I'm starting to feel weird already..."
}
Floatnode "DaisyF_Move"
notes "Daisy floats these lines if she is a follower and PC uses tooltip 'get out of my way' to make her move. "
{
"Sorry, honey. Didn't mean to stand in your way.",
"Where should I stand, over here?",
"No prizes for guessing who wears the pants in *this* relationship.",
"Oops!",
"I'm sure you could have squeezed past me. *Giggles.*",
"Oh, I didn't realize you were coming through here."
}
Floatnode "DaisyF_Heal1"
notes "Daisy floats these lines if she is a follower and PC uses healing on her."
{
"I feel better already.",
"Thanks, hon. I knew you'd take good care of me.",
"I didn't know you knew all that doctor stuff.",
"I should get hurt more often if it means I get this sort of quality time with you.",
"Just make sure you keep enough for yourself.",
"Thanks. I was starting to get worried, there."
}
Floatnode "DaisyF_Heal2"
notes "Daisy floats these lines if she is a follower, PC uses healing on her, but Daisy doesn't need healing."
{
"Save it for when we really need it, hon.",
"Looks like someone likes playing nurses and nurses. *Giggles.*",
"Any excuse to get your hands on me, huh? *Giggles.*",
"Hey, wait 'til we're somewhere more private, at least!",
"But I'm not hurt, hon.",
"What's that for?"
}
Floatnode "DaisyF_Alone"
notes "Daisy floats these lines if she is a follower but has been left behind."
{
"I don't like being on my own.",
"I hope she comes back soon.",
"She'd better not leave me here.",
"I hope I have enough to eat.",
"I'm starting to feel lonely already.",
"*Sigh*"
}
Floatnode "DaisyF_CotC"
notes "Daisy floats these lines if she is a follower and the PC's party are in City on the Coast."
{
"A lot of memories here. Not all of them good.",
"Sure am glad to be leaving some of these faces behind.",
"I hope Dad can cope on his own.",
"This place is looking smaller already.",
"I used to hide toys over there when I was a kid.",
"Never thought the smell of fish would make me feel so homesick."
}
Floatnode "DaisyF_Area"
notes "Daisy floats these lines if she is a follower and doesn't like the area the PC's party are in."
{
"Do we have to stay here for long?",
"This place creeps me out, hon.",
"Aren't you scared, too?",
"What do we have to do here?",
"Did I just see something move?",
"City on the Coast doesn't seem so boring right now."
}

/* Regular nodes */

Node "Daisy_0"
notes ""
is_wtg = false
{
NPCText "- STARTING CONDITIONS -"
      options {
          int=1 Reaction=REACTION_NEUTRAL playertext "The player has not spoken to Daisy before." linkto "Daisy_1a_1"  notes ""
          int=1 Reaction=REACTION_NEUTRAL Gender=MALE playertext "The player has spoken to Daisy before; the PC is male." linkto "Daisy_1b_M"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "The player has spoken to Daisy before; the PC is female, but Daisy is not attracted to her." linkto "Daisy_1b_M"  notes "get_critter_stat(dude_obj, STAT_ch) < 7"
          int=1 Reaction=REACTION_NEUTRAL playertext "The player has spoken to Daisy before; the PC is female and Daisy is attracted to her." linkto "Daisy_1b_F"  notes "get_critter_stat(dude_obj, STAT_ch) >= 7"
          int=1 Reaction=REACTION_NEUTRAL playertext "The rumor that Daisy is a lesbian is out; the PC has not spoken to Daisy since." linkto "Daisy_1c_1"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "The rumor that Daisy is a lesbian is out; the PC has spoken to Daisy since." linkto "Daisy_1c_6"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "Daisy is a follower of the PC; the PC has good karma." linkto "DaisyF_1G"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "Daisy is a follower of the PC; the PC has bad karma." linkto "DaisyF_1B"  notes ""
              }
}
Node "Daisy_1a_1"
notes "The Daisy_1a_* path is the default greeting Daisy uses when she speaks to the PC for the first time. It branches after this node depending on whether she finds the PC attractive."
is_wtg = false
{
NPCText "Hey there, welcome to the Cutty Sark."
      options {
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Hi, I'm <PC>. Who are you?" linkto "Daisy_1a_2Ma_1"  notes "This option appears for intelligent male PC's. It routs the conversation along a path where Daisy is far less amenable, since she finds the PC unattractive. \nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Hi, I'm <PC>. Who are you?" linkto "Daisy_1a_2Ma_1" conditions { CHECK_STAT charisma < 7 link_next NONE } notes "This option appears for intelligent female PC's to whom Daisy is not attracted, due to the PC's less-then-dazzling Charisma score. It routs the conversation along a path where Daisy is far less amenable.\nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Hi, I'm <PC>. Who are you?" linkto "Daisy_1a_2F_1a" conditions { CHECK_STAT charisma >= 7 link_next NONE } notes "This option appears for intelligent female PC's to whom Daisy is attracted, due to the PC's high Charisma score. It routs the conversation along a path where Daisy is far more amenable.\nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "What do you do here?" linkto "Daisy_1a_2Mb_1"  notes "This option appears for intelligent male PC's. It routs the conversation along a path where Daisy is far less amenable, since she finds the PC unattractive. \nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "What do you do here?" linkto "Daisy_1a_2Mb_1" conditions { CHECK_STAT charisma < 7 link_next NONE } notes "This option appears for intelligent female PC's to whom Daisy is not attracted, due to the PC's less-then-dazzling Charisma score. It routs the conversation along a path where Daisy is far less amenable.\nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "What do you do here?" linkto "Daisy_1a_2F_1b" conditions { CHECK_STAT charisma >= 7 link_next NONE } notes "This option appears for intelligent female PC's to whom Daisy is attracted, due to the PC's high Charisma score. It routs the conversation along a path where Daisy is far more amenable.\nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=-3 Reaction=REACTION_NEUTRAL Gender=MALE playertext "I <PC>. Who you?" linkto "Daisy_1a_2Ma_1"  notes "This option appears for dumb male PC's. It routs the conversation along a path where Daisy is far less amenable, since she finds the PC unattractive. \nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=-3 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "I <PC>. Who you?" linkto "Daisy_1a_2Ma_1" conditions { CHECK_STAT charisma < 7 link_next NONE } notes "This option appears for dumb female PC's to whom Daisy is not attracted, due to the PC's less-then-dazzling Charisma score. It routs the conversation along a path where Daisy is far less amenable.\nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=-3 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "I <PC>. Who you?" linkto "Daisy_1a_2F_1a" conditions { CHECK_STAT charisma >= 7 link_next NONE } notes "This option appears for dumb female PC's to whom Daisy is attracted, due to the PC's high Charisma score. It routs the conversation along a path where Daisy is far more amenable.\nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=-3 Reaction=REACTION_NEUTRAL Gender=MALE playertext "What you do here?" linkto "Daisy_1a_2Mb_1"  notes "This option appears for dumb male PC's. It routs the conversation along a path where Daisy is far less amenable, since she finds the PC unattractive. \nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=-3 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "What you do here?" linkto "Daisy_1a_2Mb_1" conditions { CHECK_STAT strength < 7 link_next NONE } notes "This option appears for dumb female PC's to whom Daisy is not attracted, due to the PC's less-then-dazzling Charisma score. It routs the conversation along a path where Daisy is far less amenable.\nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
          int=-3 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "What you do here?" linkto "Daisy_1a_2F_1b" conditions { CHECK_STAT charisma >= 7 link_next NONE } notes "This option appears for dumb female PC's to whom Daisy is attracted, due to the PC's high Charisma score. It routs the conversation along a path where Daisy is far more amenable.\nThis differentiation is applied at several points in the dialogue. This is why you'll see several copies of the same player option in many of the dialogue's nodes."
              }
}
Node "Daisy_1a_2F_1a"
notes ""
is_wtg = false
{
NPCText "I'm Daisy. Daisy Duket. It's a pleasure to meet you, <PC>. I haven't seen you in here before; what brings you to town?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do here?" linkto "Daisy_1a_2F_1b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I come from a vault to the north; I'm just getting to know the place." linkto "Daisy_1a_2F_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "This and that. Can I ask you a question about something else?" linkto "Daisy_9F_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "What you do here?" linkto "Daisy_1a_2F_1b"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC> from Vault 31. <PC> traveler." linkto "Daisy_1a_2F_2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I want ask you about another thing." linkto "Daisy_9F_1"  notes ""
              }
}
Node "Daisy_1a_2F_1b"
notes ""
is_wtg = false
{
NPCText "I'm a waitress here. Clean tables, work out back; that sort of thing. So, what brings you to town?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I come from a vault to the north; I'm just getting to know the place." linkto "Daisy_1a_2F_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "This and that. Can I ask you a question about something else?" linkto "Daisy_9F_1"  notes ""
              }
}
Node "Daisy_1a_2F_2"
notes "This node increments the variable which keeps track of how many people the PC has told that (s)he comes from a vault from the north. It regulates whether or not Bruce, the Wasteland Explorer will be at Vault 31 when the PC returns."
is_wtg = false
{
NPCText "Wow, a vault? You mean, like, one of those towns underground? I really like what you're wearing, by the way. It makes you look great."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you a question about something else?" linkto "Daisy_9F_1"  notes ""
              }
}
Node "Daisy_1a_2Ma_1"
notes ""
is_wtg = false
{
