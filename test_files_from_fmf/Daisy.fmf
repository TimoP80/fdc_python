Node "Daisy_1a_2Ma_2"
notes ""
is_wtg = false
{
NPCText "Dad owns this place. You can find him out back if you want to speak to him."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What else can you tell me about him?" linkto "Daisy_3_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where is your mother?" linkto "Daisy_3_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do here?" linkto "Daisy_1a_2Mb_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks, I'll do that. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Tell more 'bout Mitchell." linkto "Daisy_3_3a_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Where your mom?" linkto "Daisy_3_3b_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "What you do here?" linkto "Daisy_1a_2Mb_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[Leave.]" linkto "done"  notes ""
              }
}
Node "Daisy_1a_2Mb_1"
notes ""
is_wtg = false
{
NPCText "Oh, you know, the usual waitress stuff. If you don't mind, I ought to get back to my work."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I get a drink?" linkto "Daisy_1a_2Mc_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What's your name?" linkto "Daisy_1a_2Ma_1"  notes ""
          int=4 Reaction=REACTION_BAD Gender=MALE playertext "What's a fine piece of ass such as yourself doing working in a dump like this?" linkto "Daisy_1a_2Mb_2B_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Not at all. Sorry to bother you." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "What your name?" linkto "Daisy_1a_2Ma_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL Gender=MALE playertext "I like you, pretty girl." linkto "Daisy_1a_2Mb_2B_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[Leave.]" linkto "done"  notes ""
              }
}
Node "Daisy_1a_2Mb_2B_1"
notes ""
is_wtg = false
{
NPCText "[She looks at you as if she gets comments like those all the time.] Please, sir, I really must get back to what I was doing."
 NPCFemaleText "[She looks at you as if she gets comments like those all the time.] Please, miss, I really must get back to what I was doing."
      options {
