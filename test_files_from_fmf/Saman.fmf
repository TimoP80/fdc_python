NPCName "Saman"
Location "Sandover (Surface)"
Description ""
Unknown_Desc "You see a heavy-set guard with scars on his face."
Known_Desc "You see Saman"
Detailed_Desc "You see a large man in faded leathers. His skin is rough after years in the sun, and his face and neck are matted with scars. Despite his healthy build, he stands awkwardly, favouring his left leg."
/* Float message nodes */

Floatnode "Idle"
notes "Random floats while Saman idles."
{
"*Cough*",
"My bones ache.",
"Another sunny day in paradise.",
"Eurgh. I feel like shit."
}
Floatnode "Unhappy"
notes "Floats when Dialogue ends with grumpy Saman (Node -1)"
{
"Why do I always get the idiots?"
}

