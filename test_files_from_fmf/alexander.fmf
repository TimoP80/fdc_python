Node "7"
notes ""
is_wtg = false
{
NPCText "GAI? Sorry, that means nothing to me."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "It stands for 'General Atomics International', they were a robotics manufacturer in the old days." linkto "10"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Are you sure? I was told their building is near here." linkto "15"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Oh well. I had other questions." linkto "6b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No? At least I tried. Goodbye." linkto "done"  notes ""
              }
}
Node "8"
notes ""
is_wtg = false
{
NPCText "[He frowns] I thought you were a man of principle... perhaps I misjudged you. In either case, a reward is out of the question."
 NPCFemaleText "[He frowns] I thought you were a woman of principle... perhaps I misjudged you. In either case, a reward is out of the question."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Fair enough. Tell me something..." linkto "6a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Will you at least answer my questions? Or are you too cheap for that as well?" linkto "5"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Maybe I'll just take what I want, and leave everything else in pieces." linkto "9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No reward? I'm outta here." linkto "done"  notes ""
              }
}
Node "9"
notes "Massacre time!"
is_wtg = false
{
