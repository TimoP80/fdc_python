NPCName "Tim"
Location "V31, near the PC's room"
Description "almost utterly insignificant."
Unknown_Desc "You see Tim."
Known_Desc ""
Detailed_Desc "He has an usually bushy beard for a man of his age."
/* Regular nodes */

Node "Node_001"
notes ""
{
NPCText "Hey <PC>."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What are you two doing?" linkto "Node_002"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Bye." linkto "done"  notes ""
              }
}
Node "Node_002"
notes ""
{
NPCText "We're playing coins."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "How do you play that?" linkto "Node_003"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I join in?" linkto "Node_004"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll leave you to it." linkto "done"  notes ""
              }
}
Node "Node_003"
notes ""
{
NPCText "It's easy. You just throw your coin. Whoever gets closest to the wall wins all the coins."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Sounds like fun. Can I play?" linkto "Node_005"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll leave you to it." linkto "done"  notes ""
              }
}
Node "Node_004"
notes ""
{
NPCText "Sure, you just need a coin. We all throw at the wall and whoever gets closest wins."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Count me in." linkto "Node_005"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I changed my mind. I have to be somewhere." linkto "Node_007"  notes ""
              }
}
Node "Node_005"
notes ""
/* Skill checks for node Node_005 */

      define_skill_check cointoss {
      skill_num = 6;
      difficulty_modifier = 1;
      onsuccess => Node_008;
      onfailure => Node_006;
      }

{
NPCText "Sure thing. But aren't you supposed to be somewhere?"
      options {
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "I've got time. Let's do this." linkto "cointoss"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Good point. I'll leave you to it." linkto "Node_007"  notes ""
              }
}
