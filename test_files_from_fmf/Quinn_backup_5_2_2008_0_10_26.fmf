          int=-3 Reaction=REACTION_NEUTRAL playertext "You talk funny. Can <PC> have your money now?" linkto "Quinn_03a_2b_4c"  notes ""
              }
}
Node "Quinn_03a_2b_4bB"
notes ""
is_wtg = false
{
NPCText "Old as I am, I earned it! You earned nothing. You are nothing! He's as old as the sky, and you killed him. Why? Why are you doing this?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "It was a dangerous animal. I put it down. Isn't that what you wanted?" linkto "Quinn_03a_2b_5a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Did I miss something? Didn't I avenge your wife? Why are you so angry?" linkto "Quinn_03a_2b_4a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't really know. I guess I assumed there would be some sort of reward." linkto "Quinn_03a_2b_4c"  notes ""
              }
}
