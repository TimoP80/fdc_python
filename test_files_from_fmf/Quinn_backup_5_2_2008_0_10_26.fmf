/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.27.2-stable

*/

vars {
local var LVAR_Quinn_Story_Before notes "Keeps track of whether Quinn has told the story of CotC's origins before." = 0;
}
NPCName "Quinn"
Location "Whaler, City on the Coast"
Description "See the http://www.fanmadefallout.com/forums/viewtopic.php?t=1536&start=75 thread on the FMF forums for details on how we're going to link the Quinn_M* random madness paths to the rest of his 'sane' dialogue."
Unknown_Desc "You see: an old man."
Known_Desc "You see: Captain Quinn."
Detailed_Desc "(Before cure): He seems distracted, as if upset about something. (After cure): He's wearing old-fashioned sailor-looking clothes."
/* Float message nodes */

Floatnode "Quinn_mad"
notes "Quinn's general floats whilst he's still mad."
{
"More longer friend see that sky?",
"Claws and paws and guts and gore.",
"I can't think straight!",
"Where's Polly? She usually deals with this.",
"I had a terrible dream about Polly last night.",
"Where's my pretty parrot gone?",
"Guts everywhere, like you've never seen!",
"But it can't have happened like that. Can't have.",
"Claws in the night, such a fright.",
"The beast!",
"I hear it!",
"I hear your voice, monster!",
"Come out from behind there!"
}
Floatnode "Quinn_cured"
notes "Quinn's general floats after he's cured."
{
"I feel like a new man.",
"Might even put out to sea again one of these days.",
"I might be better, but this town don't run itself.",
"I got those rat fellers all wrong; they're okay.",
"Should think about making some memorial to Polly.",
"Just take it one day at a time, Quinn.",
"I've missed so much...",
"Better make sure this town knows I'm back in charge."
}
Floatnode "Quinn_combat"
notes "Quinn's combat taunts."
{
"I'll have your gizzards for me breakfast!",
"I'll keel haul yer, d'you hear?",
"You picked the wrong man for a fight!",
"I may be old, but I still know a few tricks!",
"Gut yer like a damn fish!",
"I'll decorate the wall o' me cabin with yer skull!"
}
Floatnode "Quinn_trip"
notes "Quinn's dream juice trip. Quinn floats the first four lines on his own as he enters the map. The 'Quinn, wait.' is spoken by the deathclaw; Quinn floats the next one; the Dclaw the one after that, and so on. The Dclaw morphs into Polly when Quinn speaks the line, 'Wife, what the... what's happening? Polly, is that you?' Polly disappears after the last node."
{
"What the hell is this place?",
"What's that?",
"The thing! The beast! I see it!",
"Have at you, animal!",
"Quinn, wait.",
"Did... did you just speak?",
"Of course, don't you recognize your own wife?",
"Wife, what the... what's happening? Polly, is that you?",
"Yes, dear.",
"For the holy love of mackerel, will you tell me what's going on?",
"I have a message for you.",
"From who?",
"'From whom.' Do learn to speak properly, dear.",
"Heh. That's my Polly all right.",
"Listen, you've got to let go of what happened to me on the night I left you.",
"It's all I can think about. I think I'm going mad. I think I've *gone* mad.",
"It's never too late. Let go, Quinn. Let go.",
"I'm just an old man... what use is my mind to anyone anyway?",
"That's not the Quinn I married. The City still needs much from you.",
"That's as maybe, but how can a captain lead with such a guilt on his shoulders?",
"You carry the guilt for nothing, my love.",
"What do you mean?",
"There was nothing you could have done to stop the beast, you must know that.",
"Do you... do you forgive me?",
"Same old Quinn, deaf as a post. There's nothing to forgive, my love.",
"Polly, I miss you so much.",
"Stay well, Quinn.",
"Don't go!"
}

/* Regular nodes */

Node "Quinn_0"
notes ""
is_wtg = false
{
NPCText "- SWITCHER -"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "<PC has never met Quinn>" linkto "Quinn_01_1a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "<PC is female (and not dumb) and never met Quinn>" linkto "Quinn_01_1F_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "<PC has met Quinn before>" linkto "Quinn_01_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "<PC has cured Quinn's madness>" linkto "Quinn_01_1c_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC is dumb and never met Quinn>" linkto "Quinn_01_1a"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC is dumb and has met Quinn before>" linkto "Quinn_01_1b_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC is dumb and has cured Quinn's madness>" linkto "Quinn_01_1c_1"  notes ""
              }
}
Node "Quinn_01_1a"
notes ""
is_wtg = false
{
NPCText "Who are you? What have you done with my Polly?"
 NPCFemaleText "Polly, is that you?"
      options {
          int=4 Reaction=REACTION_GOOD Gender=FEMALE playertext "No, I'm not Polly. I'm <PC>; good to meet you." linkto "Quinn_01_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_GOOD playertext "I'm sorry, I don't know who you mean. I'm <PC>; glad to meet you." linkto "Quinn_01_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "No. Who's this Polly?" linkto "Quinn_01_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "I haven't done anything to anyone called Polly." linkto "Quinn_01_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_BAD playertext "What the fuck are you gibbering about?" linkto "Quinn_01_1a_2B"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Who Polly?" linkto "Quinn_01_1a_2a_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Me not Polly. Me <PC>." linkto "Quinn_01_1a_2a_1"  notes ""
          int=-3 Reaction=REACTION_BAD playertext "You stupid. <PC> kill old man." linkto "combat"  notes ""
              }
}
Node "Quinn_01_1a_2a_1"
notes ""
is_wtg = false
{
NPCText "Polly, my dear, pretty girl-parrot."
 NPCFemaleText "No, of course you're not. Ignore me; I get... confused sometimes. So, what can I do for you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Polly's a parrot?" linkto "Quinn_02_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who is Polly?" linkto "Quinn_02_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm here to ask you a few questions." linkto "Quinn_09"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I was just leaving." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Polly a parrot?" linkto "Quinn_02_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Who Polly?" linkto "Quinn_02_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC> want ask question." linkto "Quinn_09"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[Leave]" linkto "done"  notes ""
              }
}
Node "Quinn_01_1a_2B"
notes ""
is_wtg = false
{
NPCText "What? Think you've found a weakling in old Quinn, do you? Think again, boy."
 NPCFemaleText "What? Think you've found a weakling in old Quinn, do you? Think again, girl."
      options {
          int=4 Reaction=REACTION_BAD playertext "We'll see about that. [Draw weapon]" linkto "combat"  notes ""
          int=4 Reaction=REACTION_BAD playertext "I was going to kill you, but now I can't be bothered." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[Leave]" linkto "done"  notes ""
              }
}
Node "Quinn_01_1b_1"
notes ""
is_wtg = false
{
NPCText "Who's there? Come for my blessing, have you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "We've met before. Don't you remember?" linkto "Quinn_01_1b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I found the beast that took your wife. It's dead." linkto "Quinn_03a_1"  notes "This option only appears if the PC has killed the deathclaw AND Quinn is still mad."
          int=4 Reaction=REACTION_NEUTRAL playertext "I had a few questions for you." linkto "Quinn_09"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've come from the Rat Temple. I think there is a way to help you." linkto "Quinn_04a_1"  notes "if PC is a prophet of the rat temple"
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC> want another story!" linkto "Quinn_08_01" conditions { LOCAL_VARIABLE LVAR_Quinn_Story_Before > 0 link_next NONE } notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I killed bad nightmare-man! Look at me!" linkto "Quinn_03a_1"  notes "This option only appears if the PC has killed the deathclaw AND Quinn is still mad."
          int=-3 Reaction=REACTION_NEUTRAL Gender=MALE playertext "<PC> got a thing he want ask old man." linkto "Quinn_09"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "<PC> got a thing she want ask old man." linkto "Quinn_09"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "You smell old." linkto "Quinn_0D_1"  notes "If PC has not got Nemesis quest"
          int=-3 Reaction=REACTION_NEUTRAL playertext "Old man! Giant rat from the sky can fix your brain!" linkto "Quinn_04D"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Bah. [Leave]" linkto "done"  notes ""
              }
}
Node "Quinn_01_1b_2"
notes ""
is_wtg = false
{
NPCText "We have? It must've slipped my mind. Never get old, boy. It does things to you."
 NPCFemaleText "We have? It must've slipped my mind. Never get old. It does things to you."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I found the beast that took your wife. It's dead." linkto "Quinn_03a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've come from the Rat Temple. I think there is a way to help you." linkto "Quinn_04a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I had a few questions for you." linkto "Quinn_09"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll keep that in mind. See you around." linkto "done"  notes ""
              }
}
Node "Quinn_01_1c_1"
notes ""
is_wtg = false
{
NPCText "<PC>, my favorite rat-lovin' guy! How does the day find you?"
 NPCFemaleText "<PC>, my favorite rat-lovin' girl! How does the day find you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "How are you now, Captain?" linkto "Quinn_01_1c_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I found the beast that took your wife. It's dead." linkto "Quinn_03b_1"  notes "This option only appears if the PC has killed the deathclaw AND Quinn has been cured."
