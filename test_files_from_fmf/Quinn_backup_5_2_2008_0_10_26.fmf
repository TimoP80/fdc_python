Node "Quinn_07_1"
notes "The Quinn_07_* path is where the PC can find out what Quinn knows about CotC."
is_wtg = false
{
NPCText "Ah, Fisherman's Rest. A fine young village it's growing into. Did you ever hear the story of Landfall? That fateful tale..."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You told me already. Don't you remember?" linkto "Quinn_07_2a" conditions { LOCAL_VARIABLE LVAR_Quinn_Story_Before > 0 link_next NONE } notes "If Quinn has already spoken Quinn_08_02."
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about what is happening in the town now?" linkto "Quinn_07_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'd like to hear your story." linkto "Quinn_08_02"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you about something else?" linkto "Quinn_09"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, I've got other things to do. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Yay! Story time!" linkto "Quinn_08_02"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC> hear old man tell Land-fill tale. <PC> want new story!" linkto "Quinn_07_2a" conditions { LOCAL_VARIABLE LVAR_Quinn_Story_Before > 0 link_next NONE } notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC> want ask old man about another thing." linkto "Quinn_09"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[Leave]" linkto "done"  notes ""
              }
}
