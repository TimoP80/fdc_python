/* Custom procedures */
      custom_proc giveMoney associate_node 12 {
      "item_caps_adjust(dude_obj,1000);",
      "call Node014;"
      }
      custom_proc giveMoney2 associate_node 13 {
      "item_caps_adjust(dude_obj,1000);",
      "call Node015;"
      }
