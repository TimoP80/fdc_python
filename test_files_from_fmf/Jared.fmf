      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Well, go find him then!" linkto "Node034"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Tell me where Jared is, or I'll kill you instead!" linkto "Node008"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Nothing. Bye." linkto "done"  notes ""
