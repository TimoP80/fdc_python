NPCName ""
Location ""
Description ""
Unknown_Desc ""
Known_Desc ""
Detailed_Desc ""
/* Timed events */

// Intervals are entered in seconds (converted to game ticks by the script)
// default_event points to an index from the timed event list
// starting from zero
Default_Event = 0
TimeEvent fixed_param_name="TheFloats", enum=1
IsRandomInterval = True
IntervalMin=2
IntervalMax=7
   code = {
    "call Floats;",
    "flush_add_timer_event_sec(self_obj, random(2, 7), TheFloats);",
    "animate_move_to_tile(tile_num_in_direction(self_tile,random(0,5),random(6,8)));"
  }

/* Float message nodes */

