Node "Node002"
notes ""
is_wtg = true
/* Skill checks for node Node002 */

      define_skill_check Skill_Check_000_Intelligence {
      skill_num = 23;
      difficulty_modifier = 0;
      onsuccess => NodeIntTrue;
      onfailure => NodeIntFalse;
      }

{
NPCText "Oh, that's too bad! I was hoping you could point me to some shit."
 NPCFemaleText "Oh, that's too bad! I was hoping you could point me to some shit."
      options {
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "okay, fucker, let's test some fucking skill checks! I am very intelligent!" linkto "Skill_Check_000_Intelligence"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let's fucking refer to a global variable! GVAR_HOLODISK_ENCLAVE_SECURITY BABY!" linkto "Node004" conditions { GLOBAL_VARIABLE GVAR_HOLODISK_ENCLAVE_SECURITY == 1 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Oh my god, there's a charisma check in ths option! WE ARE FUCKING DOOMED!" linkto "done" conditions { CHECK_STAT charisma > 4 link_next NONE } notes ""
              }
}
