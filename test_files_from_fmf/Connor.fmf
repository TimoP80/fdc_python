/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.26.0-beta

*/

NPCName "Connor"
Location "Sandover / Party"
Description "Connor dialogue"
Unknown_Desc "You see an anxious looking man."
Known_Desc "You see Connor."
Detailed_Desc "You see a thin, anxious looking man with a receding hairline."
/* Float message nodes */

Floatnode "Con_Vent"
notes "When Connor spots the GAI base's air vent"
{
"Take a look over there! Maybe it's some sort of vent."
}
Floatnode "Con_hurt"
notes "Connor is hurt"
{
"I hate to be a nuisance, but could I get a bit of healing here?",
"I don't suppose you've got a spare stimpak at all, have you?",
"If it's not too much hassle, could you pass me a stimpak please?",
"Owww... have we got a spare stimpak, please?",
"I've always hated the sight of my own blood."
}
Floatnode "Con_badlyhurt"
notes "Connor is badly hurt"
{
"Everything's going dark. I'm getting scared...",
"It's futile - I'm dead for sure, now.",
"Please - please help me! I'm bleeding out, help me!",
"Oh God, oh mother, it hurts!"
}
Floatnode "Con_poisoned"
notes "Connor is poisoned"
{
"Uhhhh... I don't feel so good.",
"Could we rest for a minute? I don't feel so HUUURRRRRKK!",
"I feel ill - sorry, but could we maybe rest up here for a while?"
}
Floatnode "Con_radiated"
notes "Connor is radiated"
{
"Oh no - I think I've got radiation poisoning! Please, do something!",
"Help, I'm irradiated! Give me some Rad-Away, now!",
"I've seen radiation poisoning before! Get me to a doctor right now!",
"I'm radiated! I am NOT going to die like this!"
}
Floatnode "Con_area"
notes "Connor doesn't like the area"
{
"Do we really have to be here?",
"I trust you, but this place looks sort of dangerous.",
"I'll stick close to you here. For... mutual protection.",
"Nothing bad's going to happen, is it?",
"Be strong, Connor... don't let them know what a wuss you are.",
"Nobody had better start anything. They, they just better not. Or... else."
}
Floatnode "Connor_drugs"
notes "Player uses drugs on Connor"
{
"Mother always told me to stay away from drugs...",
"That stuff's completely safe, right?",
"Well, I suppose taking drugs just once won't hurt.",
"This won't make me into a reliant, will it?",
"If everyone else is doing them, I suppose they can't be all bad."
}
Floatnode "Connor_pushed"
notes "Player pushes Connor out of the way"
{
"Oh, sorry, was I in the way?",
"I'm in the way again, aren't I? So stupid...",
"I've got to stop getting under everyone's feet."
}
Floatnode "Connor_heal1"
notes "Connor is healed while hurt"
{
"That feels a lot better.",
"Thankyou, I really needed that.",
"Thanks a lot. I'll try not to get hurt from now on.",
"Well, if you think you can spare a stimpak on me..."
}
Floatnode "Connor_heal2"
notes "Connor is healed while at full health"
{
"I don't want to argue with you, but I didn't really need that.",
"Thanks for looking after me, but I'm honestly fine.",
"I'm sure someone else needs that more - I'm feeling good."
}
Floatnode "Connor_waiting"
notes "Connor is waiting to be collected"
{
"Oh, you came back for me! Thankyou so much!",
"It's so good to see you again! Ready to go, partner?",
"Let's hit the trail, buddy, amigo, compadre!",
"I've really missed you.",
"I feel kind of lonely here."
}
Floatnode "Connor_Sandover"
notes "Connor is in Sandover"
{
"Let's not stay for too long - if that's all right with you.",
"I don't want to tell you your business, but do we need to be here?"
}

/* Regular nodes */

Node "Switcher"
notes ""
is_wtg = false
{
NPCText "switch"
      options {
          int=1 Reaction=REACTION_NEUTRAL playertext "Connor is in the party" linkto "Party"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "Connor has been in the party and told to wait" linkto "Waiting"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "Connor has not joined, player has not shown interest in him as a friend" linkto "Talk"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "Connor has not joined but is friendly with the player." linkto "Friends"  notes ""
              }
}
Node "Party"
notes "Heal node only available if Connor is hurt"
is_wtg = false
{
NPCText "What is it? Am I doing something wrong? "
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "No - I just want to ask you some questions." linkto "PartyQuestions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Heal yourself up, Connor." linkto "PartyHeal"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "We need to change our distance from each other." linkto "PartyDistance"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I need to talk to you about your gear." linkto "PartyGear"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Wait here until I come back." linkto "PartyWait"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind, it wasn't important." linkto "done"  notes ""
              }
}
Node "PartyWait"
notes "Both options remove Connor from the party."
is_wtg = false
{
NPCText "You're going to leave me here? I promise I can do better in future, please, just let me tag along..."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I won't be long." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Connor, you're being a little clingy. I need to be on my own for a while, but I'll be back... probably." linkto "done"  notes ""
              }
}
Node "PartyHeal"
notes "Heal node only available if Connor is hurt"
is_wtg = false
{
NPCText "I feel much better now."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Good. Let me ask you some questions." linkto "PartyQuestions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Heal yourself up, Connor." linkto "PartyHeal2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "We need to change our distance from each other." linkto "PartyDistance"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I need to talk to you about your gear." linkto "PartyGear"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Wait here until I come back." linkto "PartyWait"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay, let's go." linkto "done"  notes ""
              }
}
