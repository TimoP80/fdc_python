          int=4 Reaction=REACTION_NEUTRAL playertext "I need to talk to you about your gear." linkto "PartyGear"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Wait here until I come back." linkto "PartyWait"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay, let's go." linkto "done"  notes ""
              }
}
Node "PartyQuestions"
notes "Option 1 is available only if the GAI base hasn't been found yet."
is_wtg = false
{
NPCText "Questions? Well, I'll answer them if I can."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I need you to help me find a place called GAI, some sort of pre-war facility. It should be somewhere in the Sandover area." linkto "PartyGAI"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, never mind. I need to talk to you about something else." linkto "Party"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Forget it. Let's move on." linkto "done"  notes ""
              }
}
Node "PartyDistance"
notes "The current formation should not be displayed."
is_wtg = false
{
NPCText "Um, all right, just tell me what I need to do."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Stay close to me." linkto "PartyClose"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Don't move too far away." linkto "PartyMedium"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let's spread out a little." linkto "PartySpreadout"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, I think this distance is okay for now." linkto "PartySameDistance"  notes ""
              }
}
Node "PartyClose"
notes "Heal node only available if Connor is hurt"
is_wtg = false
{
NPCText "Good thinking! Probably safer for both of us that way - we got each others' backs, eh?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you some questions." linkto "PartyQuestions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Heal yourself up, Connor." linkto "PartyHeal"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "We need to change our distance from each other." linkto "PartyDistance"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I need to talk to you about your gear." linkto "PartyGear"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Wait here until I come back." linkto "PartyWait"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay, let's go." linkto "done"  notes ""
              }
}
Node "PartyMedium"
notes "Heal node only available if Connor is hurt"
is_wtg = true
{
NPCText "No problem. Protect each other but give you more room to do your thing, right? Got it."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you some questions." linkto "PartyQuestions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Heal yourself up, Connor." linkto "PartyHeal"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "We need to change our distance from each other." linkto "PartyDistance"  notes ""
