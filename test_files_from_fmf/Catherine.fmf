Node "Cath_2a_1"
notes "The Cath_2a_* path is where the PC finds out what Catherine knows about the GAI base. (Precious little). She directs the PC to Alexander."
is_wtg = false
{
NPCText "[She screws her eyes in thought and silently repeats the name to herself.] Nope. Name doesn't ring a bell. Oh, my father might know where you might find it, though."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who is your father?" linkto "Cath_2a_2a" conditions { LOCAL_VARIABLE Cath_Alex_Daught == 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where can I find your father?" linkto "Cath_2a_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you a question about something else?" linkto "Cath_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks. I'll go and ask him. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Where I find him?" linkto "Cath_2a_2b"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I got thing I want ask." linkto "Cath_9"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[LEAVE]" linkto "done"  notes ""
              }
}
Node "Cath_2a_2a"
notes "Increment the local variable Cath_Alex_Daught by 1."
is_wtg = false
{
NPCText "My father is Alexander. Reason I think he'll know where to look for your base is because he's in charge of Sandover. Not much gets past him."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Where can I find your father?" linkto "Cath_2a_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you a question about something else?" linkto "Cath_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks. I'll go and ask him. Goodbye." linkto "done"  notes ""
              }
}
