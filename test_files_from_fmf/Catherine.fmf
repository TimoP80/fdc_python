      skill_num = 15;
      difficulty_modifier = 0;
      onsuccess => Cath_5_4a_07;
      onfailure => Cath_5_9;
      }

{
NPCText "[Dr. Oswald said, \"of the patients coming into my hospital, a much greater proportion have illnesses that are radiation-related and terminal than you'd find in hospitals in other towns in the wastes. That means that I have to offer a higher number of beds and resources per capita to patients who aren't going to make it. Sandover is the last place on earth which can afford this.\"]"
      options {
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "[Repeat this to Catherine; emphasize how overstretched Sandover's resources are.]" linkto "Pro_Euth_Speech_3a"  notes "Slightly harder Speech skill check.\nAgain, Catherine mentioned that she relies on meds her father buys her. The subliminal implication in the PC's argument is that she gets these at the expense of other Scabs.\nNote: for the Speech check, add/subtract the local variable Cath_Mood to the difficulty modifier."
          int=4 linkflags skill_check Reaction=REACTION_GOOD playertext "[Repeat this to Catherine; emphasize the greater proportion of terminal radiation-related illnesses.]" linkto "Pro_Euth_Speech_3b"  notes "Normal Speech skill check.\nNote: for the Speech check, add/subtract the local variable Cath_Mood to the difficulty modifier."
