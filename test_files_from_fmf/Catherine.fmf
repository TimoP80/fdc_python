          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you a question about something else." linkto "Cath_9"  notes ""
              }
}
Node "Cath_3_3a_2"
notes ""
is_wtg = false
{
NPCText "Folks like you who are just passing through have nothing to worry about. There is higher level of rads buzzing in Sandover than you'd find in other nearby towns, though. It's a problem for people who live their whole lives here."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "So the other people in Sandover are more ill because they cannot get enough anti-rads?" linkto "Cath_3_3b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Tell me more about your father." linkto "Cath_3_3c_1" conditions { LOCAL_VARIABLE Cath_Alex_Daught == 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_BAD playertext "So his daughter gets enough medicine whilst the rest of the town goes without. Very convenient." linkto "Cath_3_3c_2" conditions { LOCAL_VARIABLE Cath_Alex_Daught > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you a question about something else." linkto "Cath_9"  notes ""
              }
}
