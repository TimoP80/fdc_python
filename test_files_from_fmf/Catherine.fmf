/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.26.0-beta

*/

vars {
local var Cath_Alex_Daught notes "This variable keeps track of whether or not the PC knows that Catherine is Alexander's daughter." = 0;
local var Cath_Euth_Anti_Conv notes "This variable keeps track of how many, and which, of the PC's anti-euthansia arguments Catherine has accepted. If it reaches 5, the PC has successfully given Catherine all the anti-euthanasia arguments, and she will convince Alexander to ban the practice outright." = 0;
local var Cath_Euth_Attempts notes "This variable keeps track of how many times the PC has tried to persuade Catherine his way of thinking re: euthanasia, but failed. After the PC fails three times, Catherine will not let him talk to her about the subject again." = 0;
local var Cath_Euth_Pro_Conv notes "This variable keeps track of how many, and which, of the PC's pro-euthansia arguments Catherine has accepted. If it reaches 5, the PC has successfully given Catherine all the pro-euthanasia arguments, and she will convince Alexander to legalize the practice outright." = 0;
local var Cath_Influence notes "This variable keeps track of whether or not the PC knows that Catherine has influence over Alexander's policy making. It allows the PC to give Catherine either side of the euthanasia debate." = 0;
local var Cath_Mood notes "This variable keeps track of Catherine's overall mood. The higher it is, the greater chance the PC has of persuading her to his viewpoint, when he gives his side of the euthanasia debate." = 0;
local var Cath_PC_Euth_Camp notes "This variable keeps track of which side of the euthanasia argument the PC has told Catherine he subscribes to. If it = 0, then he hasn' t said he takes either view; if it = 1, then he's pro-euth; if it = 2, then he's anti-euth." = 0;
}
NPCName "Catherine"
Location "Lower level of the Sandover caves, near Alexander"
Description "Only one quest involvement, 'Resolve the euthanasia debate'. The PC can use her as leverage on her father and in doing so, can determine whether Sandover legalizes, or bans, euthanasia."
Unknown_Desc "a young woman."
Known_Desc "Catherine."
Detailed_Desc "she has fewer blemishes and seems in better health than most Scabs."
/* Regular nodes */

Node "Cath_0"
notes "If the local variable Cath_Mood < -40, she will not speak to the PC at all, but will float as normal."
is_wtg = false
{
NPCText "- STARTING CONDITIONS -"
      options {
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has not spoken to Catherine before -" linkto "Cath_1a_1"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has spoken to Catherine before; Catherine likes the PC -" linkto "Cath_1b_G" conditions { LOCAL_VARIABLE Cath_Mood >= 0 link_next NONE } notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has spoken to Catherine before; Catherine dislikes the PC -" linkto "Cath_1b_B" conditions { LOCAL_VARIABLE Cath_Mood < 0 link_next NONE } notes ""
              }
}
Node "Cath_1a_1"
notes ""
is_wtg = true
{
NPCText "Hi, I don't remember seeing you around here before. You are?"
      options {
          int=4 Reaction=REACTION_GOOD playertext "Nice to meet you, my name is <PC>." linkto "Cath_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "<PC>." linkto "Cath_1a_2b"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Never you mind what my name is. What's your story?" linkto "Cath_1a_2c_1"  notes ""
          int=-3 Reaction=REACTION_GOOD playertext "Me <PC>. You pretty girl." linkto "Cath_1a_2a"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC>." linkto "Cath_1a_2b"  notes ""
          int=-3 Reaction=REACTION_BAD playertext "Huh. Why I tell you?" linkto "Cath_1a_2c_1"  notes ""
              }
}
Node "Cath_1a_2a"
notes "First impressions count.\nIncrement the local variable Cath_Mood by 5."
is_wtg = false
{
NPCText "[She smiles at you. She seems a lot more healthy than the other people in Sandover.] I'm Catherine. Say, what brings you to our neck of the woods?"
      options {
          int=4 Reaction=REACTION_GOOD playertext "I come from a vault from the north." linkto "Cath_1a_3"  notes "If the PC chooses this option, it counts towards the number of people he has told about V31. This increases the chance that he will encounter Bruce, the Wastelend Explorer, when he returns to V31."
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm looking for the General Atomics International base. Do you know where I can find it?" linkto "Cath_2a_1"  notes "This option only appears if the PC has accepted the 'Find the GAI base' quest from whomever gives it out at V31.\nIf Alexander has died from depression (see the wiki for details) go to Cath_2b_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't mean to be rude, but you don't seem as sick as the other people in Sandover. Why is that?" linkto "Cath_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm just getting to know the place. See you around." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC> live in vault. [Point to the north.]" linkto "Cath_1a_3"  notes "If the PC chooses this option, it counts towards the number of people he has told about V31. This increases the chance that he will encounter Bruce, the Wastelend Explorer, when he returns to V31."
          int=-3 Reaction=REACTION_NEUTRAL playertext "I look for find Gen'rul Tomacks Nun-nash-nall base. You know?" linkto "Cath_2a_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Why you not ill like rest of cave people?" linkto "Cath_3_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[LEAVE]" linkto "done"  notes ""
              }
}
