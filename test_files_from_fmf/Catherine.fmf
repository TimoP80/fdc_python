Node "Cath_4_3b"
notes "She does not like being patronised!\nDecrement the local variable Cath_Mood by 5."
is_wtg = false
{
NPCText "[She snorts.] I know that! Look, I'm not pretending life is easy for anyone in Sandover is easy, okay? So what if I get bored now and then?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Aside from having to act the part, what does being the leader's daughter mean you have to do?" linkto "Cath_4_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where can I find your father?" linkto "Cath_2a_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who is your father?" linkto "Cath_2a_2b" conditions { LOCAL_VARIABLE Cath_Alex_Daught == 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'd better change the subject. Let me ask you about something else." linkto "Cath_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Perhaps I'd better leave. Goodbye." linkto "done"  notes ""
              }
}
