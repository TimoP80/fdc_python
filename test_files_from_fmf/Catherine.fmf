Node "Cath_5_4a_02"
notes ""
is_wtg = false
/* Skill checks for node Cath_5_4a_02 */

      define_skill_check Pro_Euth_Speech_1b {
      skill_num = 15;
      difficulty_modifier = 0;
      onsuccess => Cath_5_4a_03;
      onfailure => Cath_5_9;
      }
      define_skill_check Pro_Euth_Speech_1a {
      skill_num = 15;
      difficulty_modifier = -5;
      onsuccess => Cath_5_4a_03;
      onfailure => Cath_5_9;
      }

{
NPCText "[Dr Oswald said, \"Let's start by clarifying what I mean when I talk about euthanasia. It's not as if I want free rein to kill people the minute they walk into my hospital. Naturally, the practice needs to be very tightly regulated. I would never administer euthanasia to anyone who was not conscious and lucid enough to reliably make the decision to end their own lives for themselves.\"]"
      options {
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "[Put the same argument to Catherine; emphasize that Dr. Oswald accepts the need for regulation.]" linkto "Pro_Euth_Speech_1a"  notes "Slightly harder Speech skill check.\nCatherine is young and not impressed by the stuffy world of laws and regulations.\nNote: for the Speech check, add/subtract the local variable Cath_Mood to the difficulty modifier."
          int=4 linkflags skill_check Reaction=REACTION_GOOD playertext "[Put the same argument to Catherine; emphasize that patients will need be concious and lucid to make the decision for themselves.]" linkto "Pro_Euth_Speech_1b"  notes "Normal Speech skill check.\nThis is a more compassionate and human view.\nNote: for the Speech check, add/subtract the local variable Cath_Mood to the difficulty modifier."
          int=4 Reaction=REACTION_NEUTRAL playertext "Perhaps I'd better ask you about something else." linkto "Cath_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind. Goodbye." linkto "done"  notes ""
              }
}
