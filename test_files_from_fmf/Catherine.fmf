              }
}
Node "Cath_3_1"
notes "The Cath_3_* path is where the PC can find out why Catherine appears to be more healthy than other people in Sandover."
is_wtg = false
{
NPCText "Well, let's just say that my father does what he can to take care of me and he does a good job."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What is he able to do for you that other people in Sandover can't do for themselves?" linkto "Cath_3_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you a question about something else." linkto "Cath_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Fair enough. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Answer me other thing I want ask." linkto "Cath_9"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[LEAVE]" linkto "done"  notes ""
              }
}
Node "Cath_3_2"
notes ""
is_wtg = false
{
NPCText "He makes sure I have a constant supply of anti-rad drugs for a start. That helps a lot when you're living in a town like Sandover."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why do you need a constant supply of anti-rad drugs?" linkto "Cath_3_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "So the other people in Sandover are more ill because they cannot get enough anti-rads?" linkto "Cath_3_3b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Tell me more about your father." linkto "Cath_3_3c_1" conditions { LOCAL_VARIABLE Cath_Alex_Daught == 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_BAD playertext "So his daughter gets enough medicine whilst the rest of the town goes without. Very convenient." linkto "Cath_3_3c_2" conditions { LOCAL_VARIABLE Cath_Alex_Daught > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you a question about something else." linkto "Cath_9"  notes ""
              }
}
