      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm looking for the General Atomics International base. Do you know where I can find it?" linkto "Cath_2a_1"  notes "This option only appears if the PC has accepted the 'Find the GAI base' quest from whomever gives it out at V31.\nIf Alexander has died from depression (see the wiki for details) go to Cath_2b_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't mean to be rude, but you don't seem as sick as the other people in Sandover. Why is that?" linkto "Cath_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm just getting to know the place. See you around." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I look for find Gen'rul Tomacks Nun-nash-nall base. You know?" linkto "Cath_2a_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Why you not ill like rest of cave people?" linkto "Cath_3_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[LEAVE]" linkto "done"  notes ""
              }
}
Node "Cath_1b_B"
notes ""
is_wtg = true
{
NPCText "Oh, it's you again. So what's up?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you know where I can find the General Atomics International base?" linkto "Cath_2a_1"  notes "This node does not appear if the PC has found one of the entrances to the GAI base."
          int=4 Reaction=REACTION_NEUTRAL playertext "You don't seem as sick as the other people in Sandover. Why is that?" linkto "Cath_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do around here?" linkto "Cath_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Your father doesn't want to talk to me about the euthanasia problem in Sandover. Could you speak to him for me?" linkto "Cath_5_1a_1" notes "This option will not appear if Alexander has died from depression."
          int=4 Reaction=REACTION_NEUTRAL playertext "Your father doesn't want to talk to me about the euthanasia problem in Sandover. Could you speak to him for me?" linkto "Cath_5_1b_1" notes "This option will not appear if Alexander has died from depression."
          int=4 Reaction=REACTION_NEUTRAL playertext "Nothing for now. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I look for find Gen'rul Tomacks Nun-nash-nall base. You know?" linkto "Cath_2a_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Why you not ill like rest of cave people?" linkto "Cath_3_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "[LEAVE]" linkto "done"  notes ""
              }
}
