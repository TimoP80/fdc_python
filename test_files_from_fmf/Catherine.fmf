      skill_num = 15;
      difficulty_modifier = -5;
      onsuccess => Cath_5_4a_05;
      onfailure => Cath_5_9;
      }

{
NPCText "[Dr. Oswald said, \"This isn't a vault. We don't have a team of skilled health-workers and our supply of med-drugs is pitiful. If a patient doesn't stand much chance of survival, we should concentrate resources that would be used on them to help other poor souls who probably would survive. Sandover is no place for the sick to hang around waiting, either.\"]"
      options {
          int=4 linkflags skill_check Reaction=REACTION_GOOD playertext "[Repeat this to Catherine; emphasize the importance of concentrating resources on healthier Scabs.]" linkto "Pro_Euth_Speech_2a"  notes "Normal Speech skill check.\nCatherine revealed earlier that Alexander already makes sure that she is well dosed-up on meds he buys for her.\nNote: for the Speech check, add/subtract the local variable Cath_Mood to the difficulty modifier."
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "[Repeat this to Catherine; emphasize that Sandover is a bad place for the sick to be made to wait for treatment.]" linkto "Pro_Euth_Speech_2b"  notes "Slightly harder Speech skill check.\nNo-one likes to be reminded their home is a shit-hole.\nNote: for the Speech check, add/subtract the local variable Cath_Mood to the difficulty modifier."
          int=4 Reaction=REACTION_NEUTRAL playertext "Perhaps I'd better ask you about something else." linkto "Cath_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind. Goodbye." linkto "done"  notes ""
              }
}
