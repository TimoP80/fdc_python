notes ""
is_wtg = false
{
NPCText "So, you think I'm crazy, eh?  The great Purge is the last hope of life in the world!!  Well, even if you do kill me and my troops here, there are hundreds more of us around the wastes!  You will never beat us!"
      options {
              }
}
Node "Great_Purge"
notes ""
is_wtg = false
/* Skill checks for node Great_Purge */

      define_skill_check Skill_Check_011_Speech {
      skill_num = 15;
      difficulty_modifier = -10;
      onsuccess => Excellent;
      onfailure => Believe;
      }

{
NPCText "Yes.  Every Man, Woman, and Child in the wastes must be purged to prevent the spread of evil.  Once all of the people of the Wastes are dead or recruited in this area, we will spread our reach nationwide, consuming all wickedness and envelopping the righteous into our fold.  "
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Isn't that a little extreme?" linkto "Purging"  notes ""
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "Amen, Colonel.  Let us decimate all that stand in our way." linkto "Skill_Check_011_Speech"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How will we purge the wastes with so little numbers?" linkto "Numbers"  notes ""
              }
}
