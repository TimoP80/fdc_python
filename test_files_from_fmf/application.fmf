/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.27.1-stable

*/

NPCName "Colonel Sanders"
Location "K.F.C."
Description "Colonel of the Kentucky Fighting Chickens.  A Lawful, Dignified man.  Very haughty, he has a tendency to overreact to certain small misdemeanors.  Any crime reults in capital punishment undr his command.  His goal is to lead his chickens into eliminating gangs and raiders in the wastes."
Unknown_Desc "You see a mid-sized, alt-and-pepper haired man standing in your midst.  He has black-framed glasses and a white beard. "
Known_Desc "You see Colonel Sanders, Head of the Kentucky Fighting Chickens."
Detailed_Desc "He looks very familiar.  You recall seeing this man in your Vault's records, but you can't remember what he did."
/* Dialogue starting conditions */

start_conditions
default_condition -1
{
cond target_node "TownInt"
{
    SSL "local_var(LVAR_Herebefore) == 1" var_param "" eval -1 value_to_check "" ini_index 9 link -1
},
cond target_node "Introduction"
{
    SSL "local_var(LVAR_Herebefore) == 0" var_param "" eval -1 value_to_check "" ini_index 6 link -1
}
};

/* Timed events */

// Intervals are entered in seconds (converted to game ticks by the script)
// default_event points to an index from the timed event list
// starting from zero
Default_Event = 0
TimeEvent fixed_param_name="Desperado Attack", enum=0
IsRandomInterval = True
IntervalMin=8
IntervalMax=12
   code = {
    "call Stranger, you best get to shelter, Here come the Desperados!;",
    "flush_add_timer_event_sec(self_obj, random(8, 8),Desperado Attack);"
  }

/* Regular nodes */

Node "Original_Intro_"
notes "(Original Introduction; One-time)"
is_wtg = true
{
NPCText "(The man looks you up and down, scrutinizing every part of your body.  His gaze is very penetrating)  The name's Colonel Sanders, leader of the Kentucky Fighting Chickens.  Who might you be, stranger?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm <PC>." linkto "What_You_Want"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm <PC>, and I'm here to kill you and your troops, you crazy bastard." linkto "Crazy"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Just a traveler." linkto "Hmph"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "You bad man.  You die." linkto "Idiot"  notes "You bad man.  You die."
              }
}
Node "What_You_Want"
notes ""
is_wtg = false
/* Skill checks for node What_You_Want */

      define_skill_check Skill_Check_000_Speech {
      skill_num = 15;
      difficulty_modifier = -40;
      onsuccess => Test;
      onfailure => Spy;
      }

{
NPCText "You will address me as 'sir'.  Well, <PC>, what brings you to the KFC camp?  Are you looking to join?"
      options {
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "Uh, Yes...sir!" linkto "Skill_Check_000_Speech"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Woah, there.  Slow down.  What are you guys all about?" linkto "Info"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm going to have to pass this time.  Sorry." linkto "Hmph"  notes ""
          int=6 Reaction=REACTION_NEUTRAL playertext "\"Kentucky\" Fighting Chickens?  aren't you guys a bit far south to be in Kentucky?  And why \"Chickens\"?" linkto "History" conditions { CHECK_SKILL outdoorsman >= 25 link_next NONE } notes ""
              }
}
Node "Test"
notes ""
is_wtg = false
/* Skill checks for node Test */

      define_skill_check Skill_Check_001_Speech {
      skill_num = 15;
      difficulty_modifier = -30;
      onsuccess => Test2;
      onfailure => Doubt_It;
      }
      define_skill_check Skill_Check_002_Speech {
      skill_num = 15;
      difficulty_modifier = -10;
      onsuccess => Great_Purge;
      onfailure => Spy;
      }

{
NPCText "Good to see a person so interested in doing something in the name of righteousness.  To get in, you need to pass a test to show your loyalty to righteousness and the Great Purge.  Are you still interested?"
      options {
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "Yes, sir!" linkto "Skill_Check_001_Speech"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hell no!" linkto "Hmph"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have a test for you.  What's what's black and blue and red all over?  The answer?  Your dead body.  Die, you sick son of a bitch." linkto "combat"  notes ""
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "Great Purge?" linkto "Skill_Check_002_Speech"  notes ""
              }
}
Node "Info"
notes ""
is_wtg = false
{
NPCText "The Sanders have run this fine regiment for generations, ever since my Great-grandfather founded it years ago.  the orginal idea of KFC was thought of by my Great-Great-Great-Grandafather, the original Colonel sanders.  Our goal is to rid the wastes of Bandits, thieves, and all manner of ne'er-do-wells.  And once the Great Purge is complete, The Wasteland will be a paradise.  Now are you going to join or not?   "
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "And you call yourselves the \"Kentucky Fighting Chickens\" because...?" linkto "History"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No, thanks." linkto "Hmph"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No, but I think I'll \"join\" my foot to your ass.  How's that?" linkto "combat"  notes ""
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "Great Purge?" linkto "Skill_Check_002_Speech"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How do you fund your \"little\" operation, here?" linkto "Shades_Of_Gray"  notes ""
              }
}
Node "History"
notes ""
is_wtg = false
/* Skill checks for node History */

      define_skill_check Skill_Check_003_Speech {
      skill_num = 15;
      difficulty_modifier = -20;
      onsuccess => Good;
      onfailure => Doubt_It;
      }
      define_skill_check Skill_Check_004_Speech {
      skill_num = 15;
      difficulty_modifier = -20;
      onsuccess => Shades_Of_Gray;
      onfailure => Spy;
      }

{
NPCText "Kentucky is added in our name for two reasons.  First, it confuses our enemies of our location.  Second, it is in honor of my Great-Great-Great-grandfather, Colonel Sanders.  \"Chickens\" is added because my Great-Great-Great Grandpappy took a liking to Chickens. (he leans in toward you)  You don't have a problem with that, do you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "(You stare him right in the eye)  No, just your chickens, old man." linkto "Combat"  notes ""
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "No...sir." linkto "Skill_Check_003_Speech"  notes ""
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "No, but I am curious about how this place is funded." linkto "Skill_Check_004_Speech"  notes ""
              }
}
Node "Hmph"
notes ""
is_wtg = false
{
NPCText "It appears you don't know who you're fucking with.  Allright boys, target practice!!"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "(looks like you have to fight)" linkto "combat"  notes ""
              }
}
Node "Test2"
notes ""
is_wtg = false
{
NPCText "You're eager!  Good, then here is the test.  Travel to the nearby city of Ghetto.  It is wretched, vile town full of scum and vialliny.  there you will find a family named McArthur.  Kill them all, every last man, woman, and child named McArthur.  Only then will you be allowed to fight in the name of Good."
      options {
          int=4 Reaction=REACTION_BAD playertext "Maybe I'm not seeing the big picture, but it seems to me that killing children is not a good thing." linkto "Kiddies"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've seen the McArthurs.  They seem like decent farm folk." linkto "McArthur"  notes "Only available if the PC has talked to the McArthurs in the past."
          int=4 Reaction=REACTION_NEUTRAL playertext "Consider it done." linkto "Excellent"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Um, I think I'll have to pass for now.  Bye!" linkto "Death"  notes ""
              }
}
