/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.25.5-stable

*/

vars {
var Ferd_Date_Arrange notes "This keeps track of whether or not the female PC has arranged a date with Ferdinand at 9 o'clock in the evening. If she fails to attend, or dumps him at some point during the date, she has 'blown out' Ferdinand and this has appropriate consequences." = 0;
var Ferd_Date_Blown notes "This keeps track of whether or not the female PC has blown her chance of convincing Ferd to join her as an NPC follower during a date with him by: sleeping with him on their first date; or getting drunk; or not sleeping with him by the end of their 2nd date; or standing him up. If she has, then Ferdinand will not join her until she completes the bones quest." = 0;
var Ferd_Date_Sex notes "This keeps track of whether the female PC has had sex with Ferdinand or not." = 0;
var Ferd_Dates notes "This keeps track of how many dates at Sara's Place the female PC has attended with Ferdinand." = 0;
var Ferd_Join notes "This node determines whether or not Ferdinand will join the PC if the PC asks him to." = 0;
var Ferd_Join_Ask notes "This node determines whether or not the PC has asked Ferdinand to join his/her group before." = 0;
var Ferd_Rude notes "This keeps track of how many times the PC has been rude to Ferdinand." = 0;
}
NPCName "Ferdinand"
Location "Wasteland Explorers' tent, Crossroads."
Description "If the PC has completed the bones quest, or, if the PC is female and has slept with Ferdinand, the PC can convince the Mexican Explorer to join him/her as a follower."
Unknown_Desc "You see a Latin-American man."
Known_Desc "It's Ferdinand, the Mexican Wasteland Explorer."
Detailed_Desc "He looks friendly but impatient, as if bitten by the wanderlust bug."
/* Float message nodes */

Floatnode "Ferd_Hurt"
notes "Ferdinand floats these strings if he is mildly hurt."
{
"I think I feel that last one a little.",
"This hurt a little, but I've had worse.",
"Nothing like a bit of pain to make a real man out of you.",
"You got the stimpacks, amigo? I could used one, here."
}
Floatnode "Ferd_Bad_Hurt"
notes "Ferdinand floats these strings if he is seriously hurt."
{
"Ay... I don' think I can go on much more.",
"ˇPuta! This hurt real bad, you know.",
"Estoy pedo... we rest soon, okay?",
"I don' feel this bad since the Explorers go to Sandover."
}
Floatnode "Ferd_Wait"
notes "Ferdinand floats these strings if he has been part of the PC's group, but has been asked to wait behind."
{
"I wonder when my frien' show up again.",
"Ay! I hope we get moving again, soon.",
"This is no place for a man to be left standing.",
"I got better things to do than stan' here all day."
}
Floatnode "Ferd_Place_Hate"
notes "Ferdinand floats these strings if he doesn't like the area the party is in."
{
"I got a bad feeling about this place...",
"I think we should go soon, okay?",
"I hope you're not thinking about staying too long.",
"The sooner we're gone, the better.",
"żQué pasa? Can we go soon?",
"I don' mind telling you I am a little afraid."
}
Floatnode "Ferd_Poisoned"
notes "Ferdinand floats these strings if he has been poisoned."
{
"Ferd_Poisoned"
}
Floatnode "Ferd_Radiated"
notes "Ferdinand floats these strings if he has been radiated."
{
"Ferd_Radiated"
}
Floatnode "Ferd_PC_Drugs"
notes "Ferdinand floats these strings when the PC uses drugs on him."
{
"Ferd_PC_Drugs"
}
Floatnode "Ferd_PC_Need_Heal"
notes "Ferdinand floats these strings if the PC uses healing measures on him, and Ferdinand was injured."
{
"Ferd_PC_Need_Heal"
}
Floatnode "Ferd_PC_Not_Need_Heal"
notes "Ferdinand floats these strings if the PC uses healing measures on him, and Ferdinand was not injured."
{
"Ferd_PC_Not_Need_Heal"
}
Floatnode "Ferd_Move"
notes "Ferdinand floats these strings if the PC tells him to get out of the way."
{
"Take it easy, amigo.",
"żQué te pasa?",
"I did not mean to get in your way, amigo.",
"I didn't see you there, <PC>.",
"Lo siento. I'll move.",
"żCómo?"
}
Floatnode "Ferd_Crossroads"
notes "Ferdinand floats these strings if the party is in Crossroads."
{
"I hope the Explorers do okay without me.",
"Maybe we check out Sara's Place?"
}
Floatnode "Ferd_Sandover"
notes "Ferdinand floats these strings if the party is in Sandover."
{
"Ferd_Sandover"
}
Floatnode "Ferd_Rusty"
notes "Ferdinand floats these strings if the party is in Rusty Springs."
{
"This is where all the drinking water comes from."
}
Floatnode "Ferd_CotC"
notes "Ferdinand floats these strings if the party is in the City on the Coast."
{
"Ferd_CotC"
}

/* Regular nodes */

Node "Ferd_0"
notes ""
is_wtg = false
{
NPCText "- STARTING CONDITIONS -"
      options {
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has never met Ferdinand before -" linkto "Ferd_1a_1"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has met Ferdinand before -" linkto "Ferd_1b"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC is female and has slept with Ferdinand before -" linkto "done"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "- Ferdinand is a member of the PC's group -" linkto "done"  notes ""
              }
}
Node "Ferd_1a_1"
notes ""
is_wtg = false
{
NPCText "Buenos días, Seńor. My name is Ferdinand. What bring you to the Wastelan' Explorers' tent?"
 NPCFemaleText "Buenos días, Seńorita. My name is Ferdinand. What bring you to the Wastelan' Explorers' tent?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I was wondering what you do here." linkto "Ferd_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are you talking like that?" linkto "Ferd_1a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm just leaving, actually." linkto "done"  notes ""
              }
}
Node "Ferd_1a_2a"
notes ""
is_wtg = false
{
NPCText "Like the others in here, I am a Wastelan' Explorer."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about the Wasteland Explorers?" linkto "Ferd_3_1a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What job do you have with the Wasteland Explorers?" linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are you talking like that?" linkto "Ferd_1a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Ferd_1a_2b_1"
notes ""
is_wtg = false
{
NPCText "żQué? Why am I talking like what?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You sound foreign." linkto "Ferd_1a_2b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You sound like an idiot." linkto "Ferd_1a_2b_2B_1"  notes "If the variable Ferd_Rude>3 then enter combat instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind. Who are you, anyway?" linkto "Ferd_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I must leave." linkto "done"  notes ""
              }
}
Node "Ferd_1a_2b_2"
notes ""
is_wtg = false
{
NPCText "[He smiles.] I soun' foreign to people from these places, si. I am from Mexico, amigo."
 NPCFemaleText "[He smiles.] I soun' foreign to people from these places, si. I am from Mexico, Seńorita."
      options {
          int=6 Reaction=REACTION_NEUTRAL playertext "You're very far from Mexico. Why are you in Crossroads?" linkto "Ferd_2_2a_1" conditions { CHECK_STAT intelligence >= 6 link_next NONE } notes "Note mild intelligence check."
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't know Mexico. Is it near here?" linkto "Ferd_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You sound like an idiot." linkto "Ferd_1a_2b_2B_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Please tell me what you are doing here." linkto "Ferd_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I must leave." linkto "done"  notes ""
              }
}
Node "Ferd_1a_2b_2B_1"
notes "Increment the variable Ferd_Rude by 1."
is_wtg = false
{
NPCText "Wha' d'you mean, \"I soun' like an idiot?\""
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm talking about that silly voice you're putting on." linkto "Ferd_1a_2b_2B_2b_1"  notes "If the variable Ferd_Rude>3 then enter combat instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, it's just that your accent sounds strange." linkto "Ferd_1a_2b_2B_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind. So what do you do, anyway?" linkto "Ferd_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You're not worth the time. Goodbye." linkto "done"  notes ""
              }
}
Node "Ferd_1a_2b_2B_2a"
notes ""
is_wtg = false
{
NPCText "Huh. Well, si. I am from Mexico. That is why I soun' different to you, gringo."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "That explains why you sound like such an idiot." linkto "Ferd_1a_2b_2B_2b_1"  notes "If the variable Ferd_Rude>3 then enter combat instead."
          int=6 Reaction=REACTION_NEUTRAL playertext "You're very far from Mexico. Why are you in Crossroads?" linkto "Ferd_2_2a_1" conditions { CHECK_STAT intelligence >= 6 link_next NONE } notes "Note mild intelligence check."
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't know Mexico. Is it near here?" linkto "Ferd_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Please tell me what you are doing here." linkto "Ferd_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You're not worth the time. Goodbye." linkto "done"  notes ""
              }
}
Node "Ferd_1a_2b_2B_2b_1"
notes "Increment the variable Ferd_Rude by 1."
is_wtg = false
{
NPCText "Hey, fuck you, zurramato. This is how I speak, comprende?"
 NPCFemaleText "Hey, fuck you, panocha. This is how I speak, comprende?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Don't you speak to me like that, asshole." linkto "Ferd_1a_2b_2B_2b_2"  notes "If the variable Ferd_Rude>3 then enter combat instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, it's just that your accent sounds strange." linkto "Ferd_1a_2b_2B_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I apologize. May I still ask you a question?" linkto "Ferd_1a_2b_2B_2b_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You're not worth the time. Goodbye." linkto "done"  notes ""
              }
}
Node "Ferd_1a_2b_2B_2b_2"
notes "Increment the variable Ferd_Rude by 1."
is_wtg = false
{
NPCText "So wha' the fuck are you gonna do about it, big man, huh? You got some big cojones to come in here looking for the trouble!"
 NPCFemaleText "So wha' the fuck are you gonna do about it, lady, huh? Don' you think being a seńorita mean you can speak to Ferdinand like a mayate!"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I apologize. May I still ask you a question?" linkto "Ferd_1a_2b_2B_2b_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[Draw weapon.]" linkto "combat"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You're not worth the time. Goodbye." linkto "done"  notes ""
              }
}
Node "Ferd_1a_2b_2B_2b_9"
notes ""
is_wtg = false
{
NPCText "Ask me your damn question, gringo."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What job do you have with the Wasteland Explorers?" linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about the Wasteland Explorers?" linkto "Ferd_3_1a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where do you come from?" linkto "Ferd_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, I don't have anything I need to ask you. Goodbye." linkto "done"  notes ""
              }
}
Node "Ferd_1b"
notes ""
is_wtg = false
{
NPCText "Hola, amigo. What can I do for you?"
 NPCFemaleText "Hola, Seńorita. What can I do for you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Have you changed your mind about joining me?" linkto "Ferd_4_1"  notes "This node only appears if the variable Ferd_Join_Ask>0."
          int=4 Reaction=REACTION_NEUTRAL playertext "What job do you have with the Wasteland Explorers?" linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about the Wasteland Explorers?" linkto "Ferd_3_1a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where do you come from?" linkto "Ferd_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm just stopping to say hello. Goodbye for now." linkto "done"  notes ""
              }
}
Node "Ferd_2_1"
notes "The Ferd_2_* path is where the PC can find out about Ferdinand's roots in Mexico."
is_wtg = false
{
NPCText "I am from Mexico, Seńor."
 NPCFemaleText "I am from Mexico, Seńorita."
      options {
          int=6 Reaction=REACTION_NEUTRAL playertext "You're very far from Mexico. Why are you in Crossroads?" linkto "Ferd_2_2a_1" conditions { CHECK_STAT intelligence >= 6 link_next NONE } notes "Note mild intelligence check."
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't know Mexico. Is it near here?" linkto "Ferd_2_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "That explains why you sound like an idiot." linkto "Ferd_1a_2b_2B_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Please tell me what you do, here." linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I must leave." linkto "done"  notes ""
              }
}
Node "Ferd_2_2a_1"
notes ""
is_wtg = false
{
NPCText "My people, they think the world north of Mexico to be a better place to live. I came here looking for a better life."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Is it a better life, here?" linkto "Ferd_2_2a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Please tell me what you do, here." linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to be going." linkto "done"  notes ""
              }
}
Node "Ferd_2_2a_2"
notes ""
is_wtg = false
{
NPCText "No. During the war, the bombs make a much worse mess here in America than they do in Mexico."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Which part of Mexico do you come from?" linkto "Ferd_2_2a_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How badly was Mexico damaged during the war?" linkto "Ferd_2_2a_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why don't you return to Mexico?" linkto "Ferd_2_2a_3c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Please tell me what you do, here." linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to be going." linkto "done"  notes ""
              }
}
Node "Ferd_2_2a_3a_1"
notes ""
is_wtg = false
{
NPCText "I come from Mexico City. She was hit by many bombs during the war. There is little left above the surface."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "\"Above the surface\"? What is below it?" linkto "Ferd_2_2a_3a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How badly was Mexico damaged during the war?" linkto "Ferd_2_2a_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why don't you return to Mexico?" linkto "Ferd_2_2a_3c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Please tell me what you do, here." linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to be going." linkto "done"  notes ""
              }
}
Node "Ferd_2_2a_3a_2"
notes ""
is_wtg = false
{
NPCText "A whole undergroun' world exists under Mexico City that no-one use or know about. Basements; old tunnels; old subway routes. My ancestors, they live in these areas long before the world above go loco and everyone blow each other up."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why do you think Mexico was attacked during the war?" linkto "Ferd_2_2a_3b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You mean your ancestors were vagrants?" linkto "Ferd_2_2a_3a_2B_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How badly was Mexico damaged during the war?" linkto "Ferd_2_2a_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why don't you return to Mexico?" linkto "Ferd_2_2a_3c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Please tell me what you do, here." linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to be going." linkto "done"  notes ""
              }
}
Node "Ferd_2_2a_3a_2B_1"
notes ""
is_wtg = false
{
NPCText "You mean like bums? You would not call them that to their faces; we are a proud people. Plus, we survive the war where others do not."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll call whomever I like whatever I like." linkto "Ferd_2_2a_3a_2B_2"  notes "If the variable Ferd_Rude>3 then enter combat instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Why do you think Mexico was attacked during the war?" linkto "Ferd_2_2a_3b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How badly was Mexico damaged during the war?" linkto "Ferd_2_2a_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why don't you return to Mexico?" linkto "Ferd_2_2a_3c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Please tell me what you do, here." linkto "Ferd_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to be going." linkto "done"  notes ""
              }
}
Node "Ferd_2_2a_3a_2B_2"
notes "Increment the variable Ferd_Rude by 1."
is_wtg = false
{
NPCText "[Ferdinand looks unimpressed.] Maybe you should watch your mouth, huh? Especially when you bring my family into it."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Maybe you should fuck off, vagrant." linkto "Ferd_1a_2b_2B_2b_2"  notes "If the variable Ferd_Rude>3 then enter combat instead."
