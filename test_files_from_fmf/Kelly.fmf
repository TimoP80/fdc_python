vars {
}
NPCName ""
Location ""
Description ""
Unknown_Desc ""
Known_Desc ""
Detailed_Desc ""
/* Regular nodes */

Node "Kelly_0"
notes ""
{
NPCText "- Starting conditions for the dialogue with Kelly -"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- The PC has never met Kelly before -" linkto "Kelly_1a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- The PC has met Kelly before; Kelly likes him/her -" linkto "Kelly_1b_G"  notes "This node begins the conversation IF the PC has spoken to Kelly before AND Kelly has spoken the node Kelly_2G."
          int=4 Reaction=REACTION_NEUTRAL playertext "- The PC has met Kelly before -" linkto "Kelly_1b_N"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- Kelly has killed Jedrek; the PC has not spoken with her since -" linkto "Kelly2_1a_1"  notes "Use this node to begin the conversation if the scripted scene where Kelly kills Jedrek has happened AND the player has NOT spoken to Kelly since."
              }
}
Node "Kelly_1a"
notes "This node beings the conversation if Kelly has never spoken to the PC before."
{
NPCText "Hi, there, stranger. Haven't seen you in these parts before."
      options {
          int=4 Reaction=REACTION_GOOD playertext "Hello, there. My name's <PC>. It's a pleasure to meet you." linkto "Kelly_2G"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Pretty lady!" linkto "Kelly_2Da_1a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I guess not. What's your name?" linkto "Kelly_2N_1"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Don't think you have. Not that it's any of your damn business." linkto "Kelly_2B_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, I thought you were someone else. 'Bye for now." linkto "done"  notes ""
              }
}
Node "Kelly_1b_G"
notes "This node begins the conversation IF the PC has spoken to Kelly before AND Kelly has spoken the node Kelly_2G."
{
NPCText "Hey, <PC>! Good to see you again."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Good to see you too, Kelly. Have you got a moment? I need to talk to you about something." linkto "Kelly_8"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Not you again! When will you piss off, you stupid bitch?" linkto "Kelly_9_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hi, Kelly. Just stopping to see how you were doing. See you later." linkto "done"  notes ""
              }
}
Node "Kelly_1b_N"
notes "This node begins the conversation IF the PC has spoken to Kelly before."
{
NPCText "Hello, again."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hi, Kelly. Have you got a moment? I need to talk to you about something." linkto "Kelly_8"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Not you again! When will you piss off, you stupid bitch?" linkto "Kelly_9_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hi, Kelly. Just stopping to see how you were doing. See you later." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Kelly-lady!" linkto "Kelly_2Db"  notes ""
              }
}
Node "Kelly_2B_1"
notes ""
{
NPCText "*Kelly's face darkens like a stormcloud* Hell, you want to try that again, mister?"
 NPCFemaleText "*Kelly's darkens like a stormcloud* Hell, you want to try that again, lady?"
      options {
          int=4 Reaction=REACTION_GOOD playertext "You're right, sorry. My name's <PC>" linkto "Kelly_2N_2"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Get fucked, bitch." linkto "Kelly_9_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No, I don't. Goodbye." linkto "done"  notes ""
              }
}
Node "Kelly_2B_2"
notes ""
{
NPCText "*She calls to a heavily muscled member of her team* Brute! I'm gonna need some help with this one!"
      options {
          int=4 Reaction=REACTION_BAD playertext "Oh, shit..." linkto "combat"  notes ""
              }
}
Node "Kelly_2Da_1a"
notes ""
{
NPCText "Aww, have you lost your Mommy?"
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "I like you." linkto "Kelly_2Da_2a_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "You SMELL!" linkto "Kelly_2Da_2b"  notes ""
              }
}
Node "Kelly_2Da_2a_1"
notes ""
{
NPCText "*She laughs* You're cute!"
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Are you my friend?" linkto "Kelly_2Da_2a_2"  notes ""
              }
}
Node "Kelly_2Da_2a_2"
notes "Increment player money by 1."
{
NPCText "Yeah, we can be friends. *She smiles indulgently* Go on; run along now. Kelly's very busy. Here's a little bottle cap for you to play with."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Thank you, Kelly-lady!" linkto "done"  notes ""
              }
}
Node "Kelly_2Da_2b"
notes ""
{
NPCText "*She rolls her eyes* Go on, now. Run along."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "'kay." linkto "done"  notes ""
              }
}
Node "Kelly_2Db"
notes ""
{
NPCText "*She gives you a brittle I-don't-have-time-for-this-smile* Sorry, but Kelly's too busy to play at the moment. *She shakes her head slowly.*"
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "You're no fun!" linkto "Kelly_2Da_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Aww!" linkto "done"  notes ""
              }
}
Node "Kelly_2G"
notes ""
{
NPCText "Well, it's a pleasure to meet you! I tell ya, manners are a rare commodity in the wastes. You're a dyin' breed, mister. My name's Kelly."
 NPCFemaleText "Well, it's a pleasure to meet you too! I tell ya, manners are a rare commodity in the wastes. You're a dyin' breed, sister. My name's Kelly."
      options {
          int=4 Reaction=REACTION_GOOD playertext "So, Kelly, could you tell me a bit about what you do?" linkto "Kelly_3"  notes ""
              }
}
Node "Kelly_2N_1"
notes ""
{
NPCText "Name's Kelly. And yours?"
      options {
          int=4 Reaction=REACTION_GOOD playertext "I can't believe I didn't introduce myself first. Sorry, Kelly. My name is <PC>" linkto "Kelly_2G"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind that for now. What's your story?" linkto "Kelly_3"  notes ""
          int=4 Reaction=REACTION_BAD playertext "You don't get to know my name, bitch." linkto "Kelly_9_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Look, I have to be going. Goodbye." linkto "done"  notes ""
              }
}
Node "Kelly_2N_2"
notes ""
{
NPCText "OK, <PC>, what do you want?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Well, what's your story?" linkto "Kelly_3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, nothing. Goodbye." linkto "done"  notes ""
              }
}
Node "Kelly_3"
notes ""
{
NPCText "I work for Jedrek. Where his caravan goes, I go too. T'aint much of a life for a girl, but it pays my way."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What's Jedrek like to work for?" linkto "Kelly_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who else works for Jedrek?" linkto "Kelly_5_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about the route your caravan takes?" linkto "Kelly_6_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Kelly, I've been speaking to Alexander and I need to talk to you about something." linkto "Kelly_7_1"  notes "This option only comes up if the player has spoken to Alexander about Jedrek's prices AND Kelly has NOT said node Kelly_7_2Na_4, where Kelly agrees to speak to Jedrek about his prices.\n\nIF Kelly has spoken node Kelly_7_2B_1, where the PC has told Kelly that Alexander said some very rude things about her, go to Kelly_7_2B_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Listen, Kelly, I have to be going. 'Bye for now." linkto "done"  notes ""
              }
}
Node "Kelly_4_1"
notes ""
{
NPCText "Jedrek? He's OK, but working the same route for so many years has made him kinda cranky, I guess you'd say."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "In what way 'cranky'?" linkto "Kelly_4_2"  notes ""
              }
}
Node "Kelly_4_2"
notes ""
{
NPCText "Not mean to us or nothin'. But he treats his customers with contempt."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Abusively?" linkto "Kelly_4_3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll have to bear that in mind when I deal with him. Could I ask another question, though?" linkto "Kelly_8"  notes ""
              }
}
Node "Kelly_4_3"
notes ""
{
NPCText "Not so much abuse or violence as putting his prices through the roof. There's no other caravans around to give us competition, y' see."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are there no other caravans coming here?" linkto "Kelly_4_4"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll keep an eye out for his high prices. I've got another question, if you don't mind." linkto "Kelly_8"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Well, I might speak to you again soon. Goodbye, Kelly." linkto "done"  notes ""
              }
}
Node "Kelly_4_4"
notes ""
{
NPCText "Sandover in particular has a reputation for being poverty stricken and highly radioactive. No-one else will touch it."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll stock up on Rad-X. I've got another question, if you don't mind." linkto "Kelly_8"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Well, I ought to head off. 'Bye, Kelly." linkto "done"  notes ""
              }
}
Node "Kelly_5_1"
notes ""
{
NPCText "Other than me, there's that guy over there everyone calls Brute."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Oh, right. What's he like?" linkto "Kelly_5_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why do they call him that?" linkto "Kelly_5_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Just the three of you, then. Can I ask another question?" linkto "Kelly_8"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "OK, thanks. I have to be going now. 'Bye." linkto "done"  notes ""
              }
}
Node "Kelly_5_2a"
notes ""
{
NPCText "Not much to say about him, really. Kinda slow, if you catch my drift *she taps the side of her head*."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Has he always been like that?" linkto "Kelly_5_3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hmm. Can I ask you about something else?" linkto "Kelly_8"  notes ""
              }
}
Node "Kelly_5_2b_1"
notes ""
{
NPCText "'Cause he's a dumb brute is why! You tried talking to him yet?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "No, I haven't." linkto "Kelly_5_2b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What's his story?" linkto "Kelly_5_2a"  notes ""
              }
}
Node "Kelly_5_2b_2"
notes ""
{
NPCText "Well, you won't get much out of him. Talks more with his fists than he does his speakin'."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What's he like otherwise?" linkto "Kelly_5_2a"  notes ""
              }
}
Node "Kelly_5_3"
notes ""
{
NPCText "I don't think so. Jedrek knows the full story. Something to do with Brute drinking too much one time and getting hisself into trouble. That's why Jedrek doesn't allow him to drink no more."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll see what Jedrek knows. Can I ask you about something else?" linkto "Kelly_8"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Interesting. Anyway, I have to be going, Kelly. Goodbye for now." linkto "done"  notes ""
              }
}
Node "Kelly_6_1"
notes ""
{
NPCText "This caravan just goes back and forth between Sandover and Crossroads."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What are the two places like?" linkto "Kelly_6_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Well, I've got a lot to be doing, Kelly. 'Bye for now." linkto "done"  notes ""
              }
}
Node "Kelly_6_2"
notes ""
{
NPCText "Well, which one first?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Sandover." linkto "Kelly_6_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Crossroads." linkto "Kelly_6_3b_1"  notes ""
              }
}
Node "Kelly_6_3a_1"
notes ""
{
NPCText "Sandover, huh? There are fewer worse places in the wastes let me tell ya."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Go on." linkto "Kelly_6_3a_2_1"  notes ""
              }
}
Node "Kelly_6_3a_2_1"
notes ""
{
NPCText "It's the radiation that does it. It's killing the people who live here bit by bit *she shudders*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "The radiation doesn't bother you?" linkto "Kelly_6_3a_2_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why do they stay here?" linkto "Kelly_6_3a_2_2b"  notes ""
              }
}
Node "Kelly_6_3a_2_2a"
notes ""
{
NPCText "No sir! I'm hopped up on so much Rad-X you could use my hide to line a Vault."
 NPCFemaleText "No ma'am! I'm hopped up on so much Rad-X you could use my hide to line a Vault."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why do the people in Sandover stay here?" linkto "Kelly_6_3a_2_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "That's an interesting mental image. What about Crossroads?" linkto "Kelly_6_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Could I ask you about something else?" linkto "Kelly_8"  notes ""
              }
}
Node "Kelly_6_3a_2_2b"
notes ""
{
NPCText "They've got nowhere else to go. No-one else'll take 'em in. There's good scavenging around here that helps pay their way, but... *She shakes her head sadly*."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "The radiation doesn't bother you?" linkto "Kelly_6_3a_2_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What's Crossroads like?" linkto "Kelly_6_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Rough deal. I've got something else I need to ask you." linkto "Kelly_8"  notes ""
              }
}
Node "Kelly_6_3b_1"
notes ""
{
NPCText "Crossroads is run by a guy named Jack and his family. It's a trading town more'n anything else."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What's it like compared to Sandover?" linkto "Kelly_6_3b_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Could you tell me how to get there?" linkto "Kelly_6_3b_2b"  notes ""
              }
}
Node "Kelly_6_3b_2a"
notes ""
{
NPCText "Total contrast. The place is small, like this one, but it's going places. I like it there."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Sounds great. Could you tell me how to get there?" linkto "Kelly_6_3b_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you think about Sandover itself?" linkto "Kelly_6_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Could I speak to you about something else?" linkto "Kelly_8"  notes ""
              }
}
Node "Kelly_6_3b_2b"
notes ""
{
NPCText "You'll need to ask Jedrek if you need to know how to get there. He does directions and that better'n I do."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you think of Sandover?" linkto "Kelly_6_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Fair enough. Do you have time for another question?" linkto "Kelly_8"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll go and do just that. Thanks for your help, Kelly." linkto "done"  notes ""
              }
}
Node "Kelly_7_1"
notes ""
{
NPCText "What did Alexander have to say?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "The jist was that he, and Sandover, were tired of having to pay through the nose for Jedrek's over-expensive goods." linkto "Kelly_7_2Na_1"  notes "Speech check. If the PC fails, go to Kelly_8_1 instead."
          int=4 Reaction=REACTION_BAD playertext "He said you were an ugly bitch who is as promiscuous as she is dumb." linkto "Kelly_7_2B_1"  notes "This option only appears once. If the player has spoken it before, it should not appear again."
          int=4 Reaction=REACTION_NEUTRAL playertext "Wait, can I ask you something else before we go into that?" linkto "Kelly_8"  notes "This option only comes up if the player has spoken to Alexander about Jedrek's prices."
          int=4 Reaction=REACTION_NEUTRAL playertext "We'll have to do this another time, Kelly. I have to be going." linkto "done"  notes ""
              }
}
Node "Kelly_7_2B_1"
notes "If this node is spoken by Kelly AND the PC never reveals to her it was a joke AND Kelly kills Jedrek in the scripted fight, node Kelly2_2a_5G_2 will lead to Kelly2_2a_5G_3b_1 instead of Kelly2_2a_5G_3a. Also, Kelly should  float vengeful snippets directed at Alexander until the player reveals he was joking.\n\nAlso, Kelly should now float vengeful snippets about Alexander."
{
NPCText "I'll kill that two-faced son of a bitch! I can't believe he called me those things!"
      options {
          int=4 Reaction=REACTION_BAD playertext "Hey, I was only joking when I said that, Kelly. Don't take things so seriously." linkto "Kelly_7_2B_2a_1"  notes ""
          int=4 Reaction=REACTION_BAD playertext "*Smirk* " linkto "Kelly_7_2B_2b"  notes ""
          int=4 Reaction=REACTION_BAD playertext "He's got it coming! See you around, Kelly." linkto "done"  notes ""
              }
}
Node "Kelly_7_2B_2a_1"
notes "IF this node is spoken by Kelly, the PC is re-allowed the opportunity to persuade Kelly to take over the Sandover-Crossroads route in the dialogue where he has had the chance."
{
NPCText "Wha... What?! That's your idea of a JOKE? What kind of person ARE you? What the HELL were you thinking?"
 NPCFemaleText "Wha... What?! That's your idea of a JOKE? What kind of person are you? I could understand that sort of thing from a guy, but from you? What the HELL were you thinking?"
      options {
          int=4 Reaction=REACTION_BAD playertext "Kelly, if you're dumb enough to fall for it, you've only got yourself to blame." linkto "Kelly_9_2b"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Actually, yeah. I suppose it was pretty stupid..." linkto "Kelly_7_2B_2a_2"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Just trying to have a bit of fun. Goodbye!" linkto "done"  notes ""
              }
}
Node "Kelly_7_2B_2a_2"
notes ""
{
NPCText "Damn straight it was stupid! Do you have ANY idea how much damage your little stunt could have caused?"
      options {
          int=4 Reaction=REACTION_BAD playertext "Kelly, I'm so sorry. I promise I'll never do anything as silly as that again." linkto "Kelly_7_2B_2a_3"  notes "Easy speech check. If failed, go to Kelly_9."
          int=4 Reaction=REACTION_BAD playertext "I do; that's why I did it. And I'd happily do it again." linkto "Kelly_9_2b"  notes ""
          int=4 Reaction=REACTION_BAD playertext "I suppose so. Well, goodbye." linkto "done"  notes ""
              }
}
Node "Kelly_7_2B_2a_3"
notes ""
{
NPCText "You must be one of the stupidest people I've ever dealt with, but I guess it doesn't do to hold a grudge. So OK, you're forgiven."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Phew. Let's change the subject." linkto "Kelly_7_2B_2a_4"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "*Lower guard* I'm glad we cleared the air... err.. goodbye." linkto "done"  notes ""
              }
}
Node "Kelly_7_2B_2a_4"
notes ""
{
NPCText "*Kelly shakes her head as if to clear it* So anyway. What were we talking about?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What's Jedrek like to work for?" linkto "Kelly_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who else works for Jedrek?" linkto "Kelly_5_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about the route your caravan takes?" linkto "Kelly_6_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Kelly, I've been speaking to Alexander and I need to talk to you about something." linkto "Kelly_7_1"  notes "This option only comes up if the player has spoken to Alexander about Jedrek's prices AND Kelly has NOT said node Kelly_7_2Na_4, where Kelly agrees to speak to Jedrek about his prices.\n\nIF Kelly has spoken node Kelly_7_2B_1, where the PC has told Kelly that Alexander said some very rude things about her, go to Kelly_7_2B_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "I think it's time you had that conversation with Jedrek about his prices." linkto "Kelly_7_2Na_4"  notes "This node only comes up IF Kelly has said node Kelly_7_4, where Kelly agrees to speak to Jedrek about his prices."
          int=4 Reaction=REACTION_BAD playertext "Come to think of it, I've got better things to do than waste my time listening to your bullshit." linkto "Kelly_9_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Nope. It slipped my mind. I'll come back when I remember what it was." linkto "done"  notes ""
              }
}
Node "Kelly_7_2B_2b"
notes ""
{
NPCText "I can't think how I'll get him, but he'll pay, be sure of that..."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hey, take it easy! it was just a joke." linkto "Kelly_7_2B_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "So anyway, can I ask you about something else?" linkto "Kelly_8"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll leave you to it." linkto "done"  notes ""
              }
}
Node "Kelly_7_2Na_1"
notes ""
{
NPCText "Well, that's no surprise. What's it to do with me? Or you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Well, look, Kelly, open your eyes. Sandover relies on this caravan, and Jedrek is bleeding the place dry." linkto "Kelly_7_2Na_2"  notes "Wrong response (patronising). Hard speech check. If the PC fails, go to Kelly_7_2Nb_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't mean to interfere, Kelly, but Jedrek's prices are killing Sandover." linkto "Kelly_7_2Na_2"  notes "This is the correct response (polite). Easy speech check. If failed, go to Kelly_7_2Nb_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "That's a good point. It really isn't either of our concerns. Well, be seeing you!" linkto "done"  notes ""
              }
}
Node "Kelly_7_2Na_2"
notes ""
{
NPCText "Yeah, I know what you mean. But there ain't much I can do about it."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "That's not true, Kelly. You're in a position where you can influence how Jedrek sets his prices." linkto "Kelly_7_2Na_4"  notes "This is the correct response and can bypass Kelly_7_2Na_3. Speech check. If the PC fails, go to Kelly_7_2Nb_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Kelly, for goodness sakes! Why can't you see that's not true?" linkto "Kelly_7_2Na_3"  notes "Speech check. If the PC fails, go to Kelly_7_2Nb_1 instead.\n\nThis is the incorrect response even if the above speech test is successful (too ambivalent, requires response) punishment is an extra node containing a speech test (Kelly_7_2Na_3)."
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me think about it. In the mean time, can I ask you something else?" linkto "Kelly_8"  notes "This option only comes up if the player has spoken to Alexander about Jedrek's prices."
          int=4 Reaction=REACTION_NEUTRAL playertext "OK. In any case, I'd better be going. 'Bye for now." linkto "done"  notes ""
              }
}
Node "Kelly_7_2Na_3"
notes ""
{
NPCText "How do you mean?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I shouldn't need to spell it out! You work with Jedrek all the time so he's got to listen to you, right?" linkto "Kelly_7_2Na_4"  notes "Wrong response (patronising and brusque). Hard speech check. If the PC fails, go to Kelly_7_2Nb_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "If Jedrek has enough respect for you to include you in his team, he's bound to listen to your advice on his prices." linkto "Kelly_7_2Na_4"  notes "This is the correct response (flattery will get you everywhere). Easy speech check. If failed, go to Kelly_7_2Nb_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me think about it. In the mean time, can I ask you something else?" linkto "Kelly_8"  notes "This option only comes up if the player has spoken to Alexander about Jedrek's prices."
              }
}
Node "Kelly_7_2Na_4"
notes ""
{
NPCText "I suppose you're right. It's about time I had a serious conversation with him."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Sandover will be in debt to you, Kelly. Speak to him now, before he rips anyone else off." linkto "done"  notes "This will instantly trigger the confrontation between Kelly and Jedrek. Brute will kill Kelly if he hasn't been knocked out with booze administered by the PC."
          int=4 Reaction=REACTION_GOOD playertext "I'm glad you agree, Kelly. But let me see if I can do something to soften your companions up before you talk to them." linkto "Kelly_7_2Na_5"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, forget what I said. Can we talk about something else?" linkto "Kelly_8"  notes "This option only comes up if the player has spoken to Alexander about Jedrek's prices."
              }
}
