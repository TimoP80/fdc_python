/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.25.5-stable

*/

vars {
var Sara_Round notes "This monitors the number of rounds the PC has bought for the patrons of Sara's Place!" = "0";
var Sara_Free_Booze notes "This monitors whether or not Sara has given the PC a bottle of Booze on the house." = "0";
var Sara_Robbery notes "This determines whether the PC has tried to rob Sara, successful so or not. If he has, Sara will float the appropriate nodes, and will attack the PC if directly spoken to again." = "0";
}
NPCName "Sara"
Location "Sara's Place, Crossroads"
Description "Sara is the eponymous owner and bar-keep of Sara's Place, in Crossroads."
Unknown_Desc "The bar-keep see a woman in her late thirties."
Known_Desc "It's Sara. She looks busy as usual."
Detailed_Desc "She looks tired as she struggles to keep up with her patrons' constant demands."
/* Dialogue starting conditions */

start_conditions
default_condition -1
{
cond target_node "Sara_0"
{
    SSL "default" var_param "" eval -1 value_to_check "" ini_index 5 link 0
}
};

/* Float message nodes */

Floatnode "Sara_Generic"
notes "Sara's basic floats."
{
"I think you've already had enough, buddy.",
"I'm going to need to get another crate in a minute.",
"Roll on closing time.",
"Don't you people have real homes to go to?",
"For the last time, no, you can't have a tab.",
"You people could drink Rusty Springs dry."
}
Floatnode "Sara_Robbery_1"
notes "These are the strings Sara floats if the variable Sara_Robbery>0, meaning that the PC has successfully robbed her."
{
"I don't think the bar will survive, now.",
"I should have brought in some security.",
"Fat lot you people were when I was getting robbed.",
"I won't even be able to afford the next consignment of water.",
"I can't cope with this!",
"If that asshole robber shows up again, I'll shoot to kill!"
}

/* Regular nodes */

Node "Sara_0"
notes ""
{
NPCText "*** STARTING CONDITIONS ***"
      options {
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has never spoken to Sara before -" linkto "Sara_1a_1"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has spoken to Sara before -" linkto "Sara_1b_1"  notes ""
              }
}
Node "Sara_1a_1"
notes ""
{
NPCText "*The female bar-keep looks up from her work.* Hey there, stranger. Welcome to Sara's Place. What'll it be?"
 NPCFemaleText "*The female bar-keep looks up from her work.* Hey there, sister. Welcome to Sara's Place. What'll it be?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You must be Sara?" linkto "Sara_1a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What have you got?" linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I want to buy a round for the whole bar." linkto "Sara_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "*In a quiet voice.* Just hand over your takings and nobody has to get hurt." linkto "Sara_B1_a1"  notes "IF the PC's Perception<7 OR the PC has a weapon in neither weapon slot, go to Sara_B1_b1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Nothing for now, thanks." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "What what be?" linkto "Sara_1a_2D_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Sara_1a_2"
notes ""
{
NPCText "That's right. What'll it be?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What have you got?" linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I want to buy a round for the whole bar." linkto "Sara_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "*In a quiet voice.* Just hand over your takings and nobody has to get hurt." linkto "Sara_0"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Nothing for now, thanks." linkto "done"  notes ""
              }
}
Node "Sara_1a_2D_1"
notes ""
{
NPCText "Well, what do you want? A drink? something to eat?"
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "I thirsty." linkto "Sara_1a_2D_2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I want eat." linkto "Sara_3_2a_2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I not want those. *Leave.*" linkto "done"  notes ""
              }
}
Node "Sara_1a_2D_2"
notes ""
{
NPCText "*She looks at you thoughtfully for a moment.* I think you'd better not have any of the hard stuff. Would you like a Nuka-Cola or water?"
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Nukie-Cole." linkto "Sara_3_2c_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Water." linkto "Sara_3_2b_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I not want those. *Leave.*" linkto "done"  notes ""
              }
}
Node "Sara_1b_1"
notes ""
{
NPCText "Hello, again. You drinking?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Yes. Remind me of what's on offer, please." linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I was after some food if you're serving." linkto "Sara_3_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Me and everyone else in the bar. I'd like to buy everyone a drink." linkto "Sara_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "*In a quiet voice.* Just hand over your takings and nobody has to get hurt." linkto "Sara_B1_a1"  notes "IF the PC's Perception<7 OR the PC has a weapon in neither weapon slot, go to Sara_B1_b1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "No, just saying hello. Maybe next time. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I drinking what?" linkto "Sara_1a_2D_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "No. <PC> go." linkto "done"  notes ""
              }
}
Node "Sara_2_1"
notes ""
{
NPCText "*Sara raises her voice so everyone in the bar can hear it.* Drinks on the gentleman here, folks. Come and get 'em."
 NPCFemaleText "*Sara raises her voice so everyone in the bar can hear it.* Drinks on the lady here, folks. Come and get 'em."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- MORE -" linkto "Sara_2_2"  notes ""
              }
}
Node "Sara_2_2"
notes ""
{
NPCText "*A drunken, ragged cheer goes up as the patrons storm the bar.*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- MORE -" linkto "Sara_2_3"  notes ""
              }
}
Node "Sara_2_3"
notes ""
{
NPCText "*Sara writes the patrons' orders on a scrap of paper as quickly as she can. Over the din, she gathers your attention again.* This's gonna set you back thirty caps, mister. You good for it?"
 NPCFemaleText "*Sara writes the patrons' orders on a scrap of paper as quickly as she can. Over the din, she gathers your attention again.* This's gonna set you back thirty caps, sister. You good for it?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Yes, no problem. Here. *Hand her the money.*" linkto "Sara_2_4a" conditions { CHECK_MONEY dude_caps >= 30 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually... no." linkto "Sara_2_4b_1" conditions { CHECK_MONEY dude_caps < 30 link_next NONE } notes ""
              }
}
Node "Sara_2_4a"
notes "IF the variable Sara_Round<1, the condition is triggered where Harris, the bar patron, finds the Lucky Horseshoe in his drink, as per the quest of the same name.\nIncrement the variable Sara_Round by 1 afterwards.\n\n"
{
NPCText "*The patrons gather up the drinks Sara pours for them and, after giving you a torrent of friendly back-slaps, retire to their seats again.* You having one yourself, stranger?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What have you got?" linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No, thanks. Goodbye." linkto "done"  notes ""
              }
}
Node "Sara_2_4b_1"
notes ""
{
NPCText "Ahh, for crying out loud. *She raises her voice again.* Sorry, folks, false alarm. The Beer Fairy here can't afford it."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- MORE -" linkto "Sara_2_4b_2"  notes ""
              }
}
Node "Sara_2_4b_2"
notes ""
{
NPCText "*With a collective groan, the patrons filter away from the bar, muttering some choice insults at you as they go. Sara looks at you reproachfully.*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I could still use a drink." linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you have any food?" linkto "Sara_3_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Sara_3_1"
notes ""
{
NPCText "I got water, Nuka-Cola, beer and liquor."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll have water." linkto "Sara_3_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll have a Nuka-Cola." linkto "Sara_3_2c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll have a beer." linkto "Sara_3_2d_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hit me with the liquor." linkto "Sara_3_2e_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you have any food?" linkto "Sara_3_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get one another time. Goodbye." linkto "done"  notes ""
              }
}
Node "Sara_3_2a_1"
notes ""
{
NPCText "Yup."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What's on the menu?" linkto "Sara_3_2a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get something another time. Goodbye." linkto "done"  notes ""
              }
}
Node "Sara_3_2a_2"
notes ""
{
NPCText "On the menu is jerky, or Iguana Shish-Kebab."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "How much is a portion of jerky?" linkto "Sara_3_2a_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How much is an Iguana Kebab?" linkto "Sara_3_2a_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I think I'll go for a drink, instead. What have you got?" linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get something another time. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Gimmie jerk." linkto "Sara_3_2a_3a_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Ig-wun Shish-bib!" linkto "Sara_3_2a_3b_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Want drink, not eat, now." linkto "Sara_1a_2D_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Sara_3_2a_3a_1"
notes ""
{
NPCText "Jerky's five caps."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Here's the five caps." linkto "Sara_3_2a_3a_2a" conditions { CHECK_MONEY dude_caps >= 5 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, I can't afford five caps." linkto "Sara_3_2a_3a_2b" conditions { CHECK_MONEY dude_caps < 5 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How much is an Iguana Kebab?" linkto "Sara_3_2a_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I think I'll go for a drink, instead. What have you got?" linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get something another time. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "- PAY -" linkto "Sara_3_2a_3a_2a" conditions { CHECK_MONEY dude_caps >= 5 link_next NONE } notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I thirsty now. Not want eat." linkto "Sara_1a_2D_2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Gah! *Leave.*" linkto "done"  notes ""
              }
}
Node "Sara_3_2a_3a_2a"
notes "Deduct five caps from the PC's inventory. Add one Meat Jerky to the PC's inventory."
{
NPCText "Okay. 'Scuse fingers. *She hands you a large strip of the dried meat.\""
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "So what can you tell me about Crossroads?" linkto "Sara_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I could use a drink, now." linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I could still use some more food. What do you have on offer again?" linkto "Sara_3_2a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to be going, now." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Want drink, now." linkto "Sara_1a_2D_2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "More food." linkto "Sara_3_2a_2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I go." linkto "done"  notes ""
              }
}
Node "Sara_3_2a_3a_2b"
notes ""
{
NPCText "Then you won't be able to afford the Ignuana, either. You want a drink, instead?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Sure, what have you got?" linkto "Sara_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get something another time. Goodbye." linkto "done"  notes ""
              }
}
Node "Sara_3_2a_3b_1"
notes ""
{
NPCText "The kebabs are eight caps each."
      options {
