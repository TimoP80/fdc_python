          int=4 Reaction=REACTION_NEUTRAL playertext "I'll go and speak to him now. Goodbye." linkto "done"  notes ""
              }
}
Node "Ferd_3_2a_3b_1"
notes ""
{
NPCText "Miranda is a good lady. A real mother for the group. Remember that she is married to Bruce, though, amigo. He can be a pretty mean guy when he wants to be."
 NPCFemaleText "Miranda is a good lady. A real mother for the group. You would like her; maybe you should introduce yourself to her, no?"
      options {
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "I'd like to meet her. Where is she?" linkto "Ferd_3_2a_3b_2F"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Bruce?" linkto "Ferd_3_2a_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do with the tech you find?" linkto "Ferd_3_1b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "May I ask you a question about something else?" linkto "Ferd_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Excuse me, I have to go." linkto "done"  notes ""
              }
}
