          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind. Goodbye." linkto "done"  notes ""
              }
}
Node "Seville_2_3a"
notes "Increment the variable Seville_PC_Hitman by 1."
{
NPCText "[He licks his lips nervously and watches you very carefully.] Hey, take it easy, now, trouble. Don't fly off the handle, here."
 NPCFemaleText "[He licks his lips nervously and watches you very carefully.] Hey, take it easy, now, sweetness. Don't fly off the handle, here."
      options {
