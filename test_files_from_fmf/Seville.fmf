notes ""
{
NPCText "[He snorts a laugh.] What's it to you why he wants me dead?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Because he's sent me to kill you." linkto "Seville_2_3a" conditions { CHECK_STAT strength >= 7 link_next NONE } notes "High STR PC path."
          int=4 Reaction=REACTION_NEUTRAL playertext "Because he's sent me to kill you." linkto "Seville_2_3b" conditions { CHECK_STAT strength < 7 link_next NONE } notes "Low STR PC path."
