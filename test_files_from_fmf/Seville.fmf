notes ""
{
NPCText "Hey, this is some heavy gear you've been selling us, man."
 NPCFemaleText "Hey, this is some heavy gear you've been selling us, sweetness. "
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you mean?" linkto "Seville_1_1d_2"  notes ""
              }
}
Node "Seville_1_1d_2"
notes ""
{
NPCText "Rico ODed, man. Your fucking shit killed him!"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who's Rico?" linkto "Seville_1_1d_3a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you mean, 'ODed'?" linkto "Seville_1_1d_3b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually killed him? He died?" linkto "Seville_1_1d_3c"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you want to buy some more from me?" linkto "Seville_1_1d_3d"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't have time for this. Let me ask you a question." linkto "Seville_9_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind. Goodbye." linkto "done"  notes ""
              }
}
