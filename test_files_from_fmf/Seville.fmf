      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "It's not your shadow that you need to worry about. Why does Saman want you dead?" linkto "Seville_2_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do out here?" linkto "Seville_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why don't you move away from here if you know Saman wants you dead so much?" linkto "Seville_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Time for me to earn my reward. [Reach for your weapon.]" linkto "combat"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you a question about something else." linkto "Seville_9_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind. Goodbye." linkto "done"  notes ""
              }
}
