/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.25.4-stable

*/

vars {
local var Seville_Had_Drugs notes "This determines how many times the PC has sold hard drugs to Seville." = 0;
local var Seville_PC_Dealer notes "This determines whether or not Seville thinks of the PC as a drug-dealer." = 0;
local var Seville_PC_Hate notes "This determines if Seville thinks the PC is either weak or a goody two-shoes." = 0;
local var Seville_PC_Hitman notes "This determines whether or not the PC has  told Seville that Saman wants the Vultures killed." = 0;
local var Seville_Rico_Dead notes "This determines if the PC has found out from Seville that Rico died from overdosing on the PC's drugs." = 0;
local var Seville_Saman_Dealer_Know notes "This determines if the PC has already told Seville that Saman has attacked the PC for selling drugs to the Vultures." = 0;
local var Seville_Scab_Suppliers notes "This determines whether or not the PC has found out from Seville that the Vultures are kept supplied by various members of the Scab community." = 0;
}
NPCName "Seville"
Location "Sandover scavenging grounds, GAI cluster"
Description "This is the leader of the Vultures gang. He has a younger brother, Douglas, who can  become involved if the PC accepts the quest from Dakin to deal with (read: kill) the Vultures gang."
Unknown_Desc "This man seems to be the leader of the group around him."
Known_Desc "It's Seville. For all his swagger and bravado he looks wired and probably hasn't slept in days."
Detailed_Desc "He is pale-faced and heavily stubbled."
/* Regular nodes */

Node "Seville_0"
notes "Starting conditions for the dialogue."
{
NPCText "- STARTING CONDITIONS -"
      options {
          int=1 Reaction=REACTION_NEUTRAL playertext "The PC has not spoken to Seville before." linkto "Seville_1_1a"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "The PC has spoken to Seville before, but doesn't know that he is Seville." linkto "Seville_1_1b"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "The PC has spoken to Seville before and knows who he is." linkto "Seville_9_1"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "The PC has spoken to Seville before and sold at least one dose of drugs to him." linkto "Seville_1_1c" conditions { LOCAL_VARIABLE Seville_Had_Drugs > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "The PC has sold at least ten doses of hard drugs to Seville." linkto "Seville_1_1d_1" conditions { LOCAL_VARIABLE Seville_Had_Drugs >= 10 link_next NONE } notes "The PC needs to have left the map and returned to it since selling Seville 10+ doses of drugs to get this greeting.\nIf Seville has spoken this node once, he will return to the normal greeting node that he uses when he is familiar with the PC as a drug dealer in future."
              }
}
Node "Seville_1_1a"
notes ""
{
NPCText "[The man, who has blood-shot, red-rimmed eyes, performs a comical double-take.] I know you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "My name is <PC>." linkto "Seville_1_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm your worst nightmare, pal." linkto "Seville_1_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm looking in this area for the Vultures gang." linkto "Seville_1_2c_1"  notes "This option only appears if the PC has accepted the Kill the Vultures gang quest."
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to go, goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Know?" linkto "Seville_1_2D_1"  notes ""
              }
}
Node "Seville_1_1b"
notes ""
{
NPCText "You again. What the hell do you want, anyway?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "My name is <PC>." linkto "Seville_1_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm your worst nightmare, pal." linkto "Seville_1_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm looking in this area for the Vultures gang." linkto "Seville_1_2c_1"  notes "This option only appears if the PC has accepted the Kill the Vultures gang quest."
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to go, goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "<PC> want say, \"hello.\"" linkto "Seville_1_1b_D"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I go." linkto "done"  notes ""
              }
}
Node "Seville_1_1b_D"
notes ""
{
NPCText "Okay, you've done it. Now say, \"goodbye.\""
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Goo'bye." linkto "done"  notes ""
              }
}
Node "Seville_1_1c"
notes ""
{
NPCText "Hey, if it isn't my favorite supplier. You got anything for me?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you know that Saman wants you killed?" linkto "Seville_2_1a" conditions { LOCAL_VARIABLE LOCAL_VARIABLE == 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you know that Saman wants you killed?" linkto "Seville_2_1b" conditions { LOCAL_VARIABLE LOCAL_VARIABLE > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do around here?" linkto "Seville_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why are you staying here?" linkto "Seville_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What is your relationship with Douglas?" linkto "Seville_5_1"  notes "This option only appears if the PC has spoken to Douglas and knows that he is Seville's younger brother."
          int=4 Reaction=REACTION_NEUTRAL playertext "How did Saman's men find out that I've been dealing to you?" linkto "Seville_8_1a" conditions { LOCAL_VARIABLE Seville_Saman_Dealer_Know == 0 link_next NONE } notes "This node only appears if Saman and/or his guards have attacked the PC after having been tipped off by Douglas. This happens if the PC has dealt 10 or more doses of hard drugs to the Vultures, causing the death of Rico, who OD's."
          int=4 Reaction=REACTION_NEUTRAL playertext "How did Saman's men find out that I've been dealing to you?" linkto "Seville_8_1b" conditions { LOCAL_VARIABLE Seville_Saman_Dealer_Know > 0 link_next NONE } notes "This node only appears if Saman and/or his guards have attacked the PC after having been tipped off by Douglas. This happens if the PC has dealt 10 or more doses of hard drugs to the Vultures, causing the death of Rico, who OD's."
          int=4 Reaction=REACTION_NEUTRAL playertext "I've got some gear to sell you. Do you want it?" linkto "Seville_7_1_1" conditions { LOCAL_VARIABLE LOCAL_VARIABLE > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Never mind. Goodbye." linkto "done"  notes ""
              }
}
