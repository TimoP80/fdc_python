}
Node "DUMB1"
notes ""
{
NPCText "I am Brian... I'm the doctor's assistant... Can I help you?"
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Me <PC>. I'm the doctor." linkto "DUMB2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I'm <PC>. What you do?" linkto "DUMB3"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I is <PC>. I help myself." linkto "done"  notes ""
              }
}
Node "DUMB2"
notes ""
{
NPCText "No you're not. The doctor is over there. Go and speak to him. I have things to do."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Oh. If he is doctor... what are you doing?" linkto "DUMB3"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I am doctor. You are fired. Leave now." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Ok. Me speak to doctor." linkto "done"  notes ""
              }
}
Node "DUMB3"
notes ""
{
NPCText "I help to heal the injured workers from the reactor or from brawls. Seems like you're beyond help though... Please, I have much to do."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Ok. I will help. I will go and injure people for you to fix." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I see. Bye bye." linkto "done"  notes ""
              }
}
