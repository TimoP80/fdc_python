NPCName ""
Location ""
Description ""
Unknown_Desc ""
Known_Desc ""
Detailed_Desc ""
/* Timed events */

// Intervals are entered in seconds (converted to game ticks by the script)
// default_event points to an index from the timed event list
// starting from zero
Default_Event = 0
TimeEvent fixed_param_name="d", enum=0
IsRandomInterval = True
IntervalMin=2
IntervalMax=8
   code = {
    "call d;",
    "flush_add_timer_event_sec(self_obj, random(2, 8),d);"
  }

/* Regular nodes */

Node "0"
notes ""
{
NPCText "Hi <PC>. You're back! Can I help you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hey Brian, how's things?" linkto "A1/B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hey Brian, say, how are things around here? " linkto "A2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm alright, thanks..." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Me <PC>. Who you?" linkto "DUMB1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I is <PC>. I help myself." linkto "done"  notes ""
              }
}
Node "A1/B1"
notes ""
{
NPCText "Boring. I'm so lonely. Did you manage to find some new Cat's Paw's for me?"
 NPCFemaleText "Iĺm th... th... the doctorĺs assistant. I help him f... fix the workers when they get injured after w... w... working in the reactor or get beaten up in a brawl. You're re... re... really pretty."
      options {
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "I don't care about those at the moment. I'm hurt. Can you fix me up? " linkto "C1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "... So, whatĺs going on around here? " linkto "A2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sure did." linkto "B2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "See... The thing is, I couldn't find any..." linkto "B3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm just getting them now..." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Get your own damn porn! Haven't you got patients to attend to anyway?" linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "You are such a sweet talker, I was wondering, could you fix me up? I'm a bit hurt." linkto "C1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Thank you... I think... Umm... So, what's been going on around here?" linkto "A2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "You're such a stud. Tell me, what's been going on around here?" linkto "A2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Umm... I hate to disappoint you, but... I'm a lesbian... Bye!" linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "I'll talk to you later, big boy..." linkto "done"  notes ""
              }
}
Node "A1.1"
notes ""
{
NPCText "Bored. I'm so lonely. These new magazines should help though. Thanks."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "My pleasure. Tell me, what's been happening?" linkto "A2.1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Not a problem. See you around." linkto "done"  notes ""
              }
}
Node "A2"
notes ""
{
NPCText "Oh, just the usual. Most of our casualties are from brawls between the workers, minor stuff, cuts and bruises, the odd broken bone here and there. Although, there has been a steady increase in casualties from the reactor, radiation poisoning, where something has gone wrong and the Handy's can't fix it. We have to send a technician in, it's getting pretty bad."
 NPCFemaleText "Well, you wouldn't believe it... I've saved the lives of seventeen people today..."
      options {
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Iĺm hurt. Can you fix me up? " linkto "C1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "So how's things?" linkto "A1/B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Well, it seems like you havenĺt got time to waste, Iĺll leave you to it. " linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "In that case, I'd love it if you could fix me up a bit?" linkto "C1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Wow, you are a hero. What is your actual job here?" linkto "A1/B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Yeah sure!!! What's you job here?" linkto "A1/B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Really!!! Well I shouldn't keep you from saving lives. See you around." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Yeah, right. How stupid do I look? Loser..." linkto "done"  notes ""
              }
}
Node "A2.1"
notes ""
{
NPCText "Oh, just the usual. Most of our casualties are from brawls between the workers, minor stuff, cuts and bruises, the odd broken bone here and there. Although, there has been a steady increase in casualties from the reactor, radiation poisoning, where somethingĺs gone wrong and the Handyĺs canĺt fix it, gotta send in a technician itĺs getting really bad."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm hurt. Can you fix me up? " linkto "C1.1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Well, it seems like you havenĺt got time to waste, Iĺll leave you to it." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "So how's things?" linkto "A1.1"  notes ""
              }
}
Node "B2"
notes ""
{
NPCText "You did! That's awesome. Can I have a look?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Sure. [You hand over all of your Cat's Paw Magazines]" linkto "B4"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Hmmů I seem to recall you saying something about a payment." linkto "B5"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Err... Truth is, I didn't really find any." linkto "B3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Not right now. I want to know. How've things been?" linkto "A1/B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Not at the moment. Tell me, what's been going on?" linkto "A2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No you can't. I decided I want them for myself. See you." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Here you go. I gotta run." linkto "done"  notes "Completes quest"
              }
}
Node "B3"
notes ""
{
NPCText "Bummer. They mustn't have survived the war... What a downer..."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Just kidding I did find some." linkto "B2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "It looks that way. Tell me, how've things been?" linkto "A1/B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm afraid so. Tell me, what's been going on?" linkto "A2"  notes "This option accepts the Cat's Paw quest for the PC."
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry. I'll catch you later." linkto "done"  notes ""
              }
}
Node "B4"
notes ""
{
NPCText "These are great. Here you go, as promised, I will pay you."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Itĺs not necessary, take them as a gift. So how are you?" linkto "A1.1"  notes "Complete quest: Gain 25 - 100 exp."
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't want your money, just update me, what's been going on?" linkto "A2.1"  notes "Quest complete."
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks. So how are you?" linkto "A1.1"  notes "Quest complete."
          int=4 Reaction=REACTION_NEUTRAL playertext "Cheers. So what's been going on?" linkto "A2.1"  notes "Quest complete."
          int=4 Reaction=REACTION_NEUTRAL playertext "It's not needed. I'll see you around." linkto "done"  notes "Quest complete."
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks. Catch you later." linkto "done"  notes "Quest complete."
              }
}
Node "B5"
notes ""
{
NPCText "Oh. Yeah, sure. Here you go. Now can I see them?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Pleasure doing business with you. [You hand over all of your Cat's Paw Magazines] So how are you?" linkto "A1.1"  notes "Complete Quest."
          int=4 Reaction=REACTION_NEUTRAL playertext "That's the way. [You hand over all of your Cat's Paw Magazines] So what's been going on?" linkto "A2.1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Good to do business with you. I'll be on my way then." linkto "done"  notes "Quest Complete."
              }
}
Node "C1"
notes ""
{
NPCText "*sigh* I have too much work to do. You should ask the doctor."
 NPCFemaleText "Ce... ce... certainly... just lay down here..."
      options {
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Ok. So, what exactly do you do? " linkto "A1/B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Oh, right. Say, whatĺs been going on around here lately?" linkto "A2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Iĺll ask him then, Iĺll leave you to it. Later." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Thanks." linkto "C2"  notes "HP should restore."
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Only if you join me... *wink*" linkto "C3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Actually, it's fine. Just tell me, what's been going on around here?" linkto "A2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Ugh. Don't you dare touch me with those hands..." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Actually, I don't really need it. I'll see you later" linkto "done"  notes ""
              }
}
