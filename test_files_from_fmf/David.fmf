          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you about something else." linkto "David_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to go. Goodbye." linkto "done"  notes ""
              }
}
