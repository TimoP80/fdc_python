vars {
export var David_Euth_Arg_1 notes "This variable determines if David has told the PC his first argument against euthanasia." = 0;
export var David_Euth_Arg_2 notes "This variable determines if David has told the PC his second argument against euthanasia." = 0;
export var David_Euth_Arg_3 notes "This variable determines if David has told the PC his third argument against euthanasia." = 0;
export var David_Euth_Arg_4 notes "This variable determines if David has told the PC his fourth argument against euthanasia." = 0;
export var David_Euth_Arg_5 notes "This variable determines if David has told the PC his fifth argument against euthanasia." = 0;
local var David_Euth_Know notes "This variable determines if David has told the PC that he is opposed to euthanasia." = 0;
local var David_Intro notes "This variable determines if David has told the PC that he is an assistant of Michael's." = 0;
}
NPCName "David"
Location "Sandover caves, near Michael the Priest"
Description "Is Michael's 'acolyte', or assistant. Is instrumental in the Euthanasia quest (see Wiki for details)."
Unknown_Desc "You see a man in loose-fitting, dun-colored robes."
Known_Desc "David, Michael's assistant."
Detailed_Desc "He is humming merrily to himself."
/* Float message nodes */

Floatnode "Dav_Norm"
notes "David's standard float node."
{
"These things are sent to try us.",
"Other towns in the wastes get Sandover all wrong.",
"I pray we don't suffer any deaths today.",
"It's a hard life, but I'm thankful for it.",
"Can you believe someone called me 'sanctimonious', the other day?",
"You would have thought we'd have a decent supply of anti-rad drugs by now."
}
Floatnode "Dav_Anger"
notes "An all-purpose node for use if the PC gets into combat with David and/or the PC manages to get euthanasia legalized in Sandover."
{
"These are grim times for Sandover.",
"Outsiders bring nothing but woe.",
"I pray for all of us.",
"Why do these things happen?",
"Has the world gone mad?",
"Saman should do more to keep bad influences out."
}

/* Regular nodes */

Node "David_0"
notes ""
is_wtg = true
{
NPCText "- STARTING CONDITIONS -"
      options {
          int=1 Reaction=REACTION_NEUTRAL playertext "The PC has not spoken to David before." linkto "David_1a_1"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "The PC has spoken to David before." linkto "David_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "The PC has completed the euthanasia quest; Alexander has banned it." linkto "David_1c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "The PC has completed the euthanasia quest; Alexander has legalized it." linkto "David_1d_1"  notes ""
              }
}
Node "David_1a_1"
notes ""
is_wtg = false
{
NPCText "Hi, there. I'm David. I haven't seen you around here before."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hi. My name's <PC>." linkto "David_1a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I don't associate with scum like you, that's why." linkto "David_1a_B1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "No see me?" linkto "David_1a_D1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to go. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I go." linkto "done"  notes ""
              }
}
