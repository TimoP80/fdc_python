Node "David_3_3_3a"
notes ""
is_wtg = false
{
NPCText "It's wrong! It's killing people, which is murder. Simple as that. Who could not be upset by that?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who do you know who practises euthanasia?" linkto "David_3_3_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Me. I couldn't give a damn who lives or dies." linkto "David_3_3_3a_B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you about something else, instead?" linkto "David_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to go. Goodbye." linkto "done"  notes ""
              }
}
