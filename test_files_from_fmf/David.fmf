          int=4 Reaction=REACTION_NEUTRAL playertext "I have to go. Goodbye." linkto "done"  notes ""
              }
}
Node "David_3_3_2"
notes ""
is_wtg = false
{
NPCText "Because it goes on right here, in Sandover."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why does it upset you so much?" linkto "David_3_3_3a"  notes ""
