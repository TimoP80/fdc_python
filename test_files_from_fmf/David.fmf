Node "David_3_3_1"
notes "Increment the local variable David_Euth_Know by 1."
is_wtg = false
{
NPCText "You want to know what really upsets me? Euthanasia."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why euthanasia in particular?" linkto "David_3_3_3a"  notes ""
