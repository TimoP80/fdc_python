Node "David_1d_2B_1"
notes ""
is_wtg = false
{
NPCText "'Prejudices?' I've been working with terminal patients since I started living here. Oh - pretty cheap trick using Alexander's daughter as leverage, by the way."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you a question?" linkto "David_1d_2B_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've gotten sick of your snivelling. [Draw weapon.]" linkto "combat"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Get over it. Goodbye." linkto "done"  notes "David will no longer speak to the PC after this, and will only float his hostile float node, Dav_Anger."
              }
}
Node "David_1d_2B_2"
notes ""
is_wtg = false
{
NPCText "No, I've had enough. You know what? You damn well cannot ask me a question."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I've gotten sick of your snivelling. [Draw weapon.]" linkto "combat"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Screw you. Goodbye." linkto "done"  notes "David will no longer speak to the PC after this, and will only float his hostile float node, Dav_Anger."
              }
}
Node "David_2a"
notes "The David 2_* node is where the PC can ask David about Michael."
is_wtg = false
{
NPCText "Oh, he's a great guy. Really is. Does a lot of good work here in Sandover, which is why I help him out."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Where can I find Michael?" linkto "David_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What sort of work?" linkto "David_2c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What made you decide to become Michael's assistant?" linkto "David_3_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have to go. Goodbye." linkto "done"  notes ""
              }
}
Node "David_2b"
notes "The David 2_* node is where the PC can ask David about Michael."
is_wtg = false
