NPCName ""
Location ""
Description ""
Unknown_Desc ""
Known_Desc ""
Detailed_Desc ""
/* Dialogue starting conditions */

start_conditions
default_condition -1
{
cond target_node "Initial"
{
    SSL "local_var(LVAR_Herebefore) == 0" var_param "" eval -1 value_to_check "" ini_index 6 link -1
}
};

/* Regular nodes */

Node "Initial"
notes ""
is_wtg = false
{
NPCText "Please donÆt make me leave. IģI donÆt have anywhere else to go. My parents, like, abandoned me here two years ago andģandģplease donÆt hurt me."
      options {
          int=4 Reaction=REACTION_BAD playertext "If you donÆt want me to hurt you, tell me again. Why are you still here?" linkto "Leaving"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Your presence is disrupting the sanctity of the temple. Why should I let you stay?" linkto "LikeRat"  notes ""
          int=-3 Reaction=REACTION_BAD playertext "You go! " linkto "Dumb"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Why let stay?" linkto "Dumb"  notes ""
              }
}
