notes ""
{
NPCText "*The spider leaves its kill to feast upon later and returns to its place in the center of the web.*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- WAIT -" linkto "Har_1b_6"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've just remembered I need to be somewhere else." linkto "done"  notes ""
              }
