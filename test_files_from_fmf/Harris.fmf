notes ""
{
NPCText "*It flies away and out of the bar-tent.*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- WAIT -" linkto "Har_1b_6"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've just remembered I need to be somewhere else." linkto "done"  notes ""
              }
}
Node "Har_1b_7b_2b_1"
notes ""
{
NPCText "*It flies straight into the web. The spider leaps into action, scuttling across the web's strands to its victim in the blink of an eye. It closes its lethal mandibles over the hapless fly, whose buzzing struggles soon come to an end.*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- WAIT -" linkto "Har_1b_7b_2b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've just remembered I need to be somewhere else." linkto "done"  notes ""
              }
}
