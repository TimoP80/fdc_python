NPCText "*A fly, having fed upon the alcoholic liquid carelessly slopped on nearby tables, buzzes drunkenly near the web.*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- WAIT -" linkto "Har_1b_7b_2b_1"  notes "Difficult roll against the PC's Luck. IF failed, go to Har_1b_7b_2a instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "I've just remembered I need to be somewhere else." linkto "done"  notes ""
