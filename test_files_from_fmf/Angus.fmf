              }
}
Node "GetPast"
notes ""
is_wtg = false
{
NPCText "No entry, buddy. Move along."
 NPCFemaleText "No entry, miss. Move along."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I really need to get into the supplies. It's a matter of life and death." linkto "LifeDeath"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How about if I make it worth your while? Fifty caps." linkto "Bribe"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me in, or I'll beat you senseless and take what I want anyway!" linkto "BeatUp"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "*FEMALE ONLY* [Smile suggestively] What if I made it... worth your while? " linkto "Seduce"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "*IF MET SAMAN* Saman sent me. I need to pick up some supplies for him." linkto "SamanSent"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Fair enough. Can I ask you a question before I go?" linkto "Questions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Right, right... I'm leaving." linkto "done"  notes ""
              }
}
