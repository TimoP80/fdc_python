Node "Questions"
notes "Main hub for questions"
is_wtg = false
{
NPCText "I don't get paid to chat. Ask your question, then stop hassling me."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who are you?" linkto "Whois"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Sandover?" linkto "Sandover"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Any work for a traveller round here?" linkto "Work"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I need to get into the supply room." linkto "GetPast"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, never mind. Goodbye." linkto "done"  notes ""
              }
}
Node "Whois"
notes ""
is_wtg = false
{
NPCText "I'm Angus. I guard the supply room."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You're a fount of information. Tell me a little more about yourself." linkto "MorePersonal"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you about something else." linkto "Questions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Good to meet you, Angus. See you later." linkto "done"  notes ""
              }
}
Node "Sandover"
notes ""
is_wtg = false
{
NPCText "It's a home. Folks here tend to be decent. No major trouble to speak of. [He eyes you suspiciously.]"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Major trouble? That implies that there's something I could help out with." linkto "Work"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you about something else." linkto "Questions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks. Goodbye." linkto "done"  notes ""
              }
}
