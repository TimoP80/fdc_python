Node "StopFirst"
notes ""
is_wtg = false
{
NPCText "You. Stop. You can't go through here."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm not planning on stealing anything, friend." linkto "GetPast"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I go where I want, and it'll take more than a pissant like you to stop me." linkto "BeatUp"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Who're you?" linkto "Whois"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "All right - I'm leaving." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "No go in?" linkto "Dumb"  notes ""
              }
}
Node "StopAgain"
notes ""
is_wtg = false
{
NPCText "I told you before, pal. Step away from there."
 NPCFemaleText "I told you before, miss. Step away from there."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Fine. Let me ask you some questions instead." linkto "Questions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Yeah, you told me before. This time, I'm telling you - take a walk before I break all your bones." linkto "BeatUp"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Fine. I'm leaving." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "But wan' go in!" linkto "DumbAgain"  notes ""
              }
}
Node "TalkFirst"
notes ""
is_wtg = false
{
NPCText "Can I help you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Yeah - who are you?" linkto "Whois"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you some questions." linkto "Questions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Not at the moment. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Help, yeah! Me wan' help." linkto "DumbTalk"  notes ""
              }
}
Node "TalkAgain"
notes ""
is_wtg = false
{
