          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you about something else, then." linkto "Questions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Fine. Goodbye." linkto "done"  notes ""
