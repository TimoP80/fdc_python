          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you another question." linkto "Questions"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks. Goodbye." linkto "done"  notes ""
              }
