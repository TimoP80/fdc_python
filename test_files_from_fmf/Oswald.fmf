      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I've received a lot of training and experience in the use of practical, field medicine." linkto "Osw_7_2a_1" conditions { CHECK_SKILL first_aid >= 50 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Not much, to be honest." linkto "Osw_7_2b_1" conditions { CHECK_SKILL first_aid < 50 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Perhaps this isn't a good idea. Let me ask you about something else." linkto "Osw_9"  notes ""
              }
}
