Node "Osw_9"
notes ""
is_wtg = false
{
NPCText "Make it brief. I have precious little enough time as it is."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I need medical attention. Can you help me?" linkto "Osw_2_1_0"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've been told that your Autodoc is broken. I'm skilled at repairing machinery." linkto "Osw_3_1a_1"  notes "This node only appears if the PC has been given the 'Fix the Autodoc' quest by Saman as an alternative means of getting into Sandover AND the PC has not already fixed the Autodoc OR used up all his five chances to do so unsuccessfully."
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you have any meds you can sell me?" linkto "Osw_5a_1"  notes "If the PC has completed the 'Challenge the Tech Supplies caravan's charges' quest in such a way that the caravan's prices are lowered, go to Osw_5b_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Alexander told me you want help around the hospital. What should I do?" linkto "Osw_7_1a" conditions { LOCAL_VARIABLE Osw_Hosp_Attempt == 0 link_next AND, LOCAL_VARIABLE Osw_Hosp_Job == 0 link_next NONE } notes "This option only appears if the PC has been given the 'Help around the Hospital' quest by Alexander."
          int=4 Reaction=REACTION_NEUTRAL playertext "Alexander told me you want help around the hospital. What should I do?" linkto "Osw_7_1b_1" conditions { LOCAL_VARIABLE Osw_Hosp_Attempt > 0 link_next AND, LOCAL_VARIABLE Osw_Hosp_Job == 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've run a diagnosis on Fran. I'd like to talk to you about it." linkto "Osw_7_1c_1"  notes "This node only appears if the PC has diagnosed severe radiation sickness in Fran (funnily enough) as part of the 'Help out at the Hospital' quest AND Fran has NOT been euthanased or cured."
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm trying to find those patients you wanted me to look at. Where did you say is the ward is?" linkto "Osw_7_2a_2a_2" conditions { LOCAL_VARIABLE Osw_Hosp_Job > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You seem very busy. Why is that?" linkto "Osw_8_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I won't take up any more of your time. Goodbye." linkto "done"  notes ""
              }
}
