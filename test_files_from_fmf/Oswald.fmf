              }
}
Node "Osw_7_1c_2c_2"
notes ""
is_wtg = false
{
NPCText "Well, I would put the poor woman out of her misery, but of course, you persuaded Alexander to prevent me from doing it by law."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "If you're talking about euthanasia, it's a wicked practice and I'm glad it's banned." linkto "Osw_7_1c_2c_3a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I didn't realize it would have these sorts of consequences." linkto "Osw_7_1c_2c_3b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you about something else?" linkto "Osw_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Perhaps I had better leave." linkto "done"  notes ""
              }
}
