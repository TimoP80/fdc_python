/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.26.0-beta

*/

vars {
local var Osw_Auto_Price notes "This variable keeps track of the number of stimpaks Dr. Oswald has agreed to give to the PC upon completion of the 'Fix the Autodoc quest." = 3;
local var Osw_Euth_Arg_1 notes "This variable determines if Dr. Oswald has told the PC his first argument in favour of euthanasia." = 0;
local var Osw_Euth_Arg_2 notes "This variable determines if Dr. Oswald has told the PC his second argument in favour of euthanasia." = 0;
local var Osw_Euth_Arg_3 notes "This variable determines if Dr. Oswald has told the PC his third argument in favour of euthanasia." = 0;
local var Osw_Euth_Arg_4 notes "This variable determines if Dr. Oswald has told the PC his fourth argument in favour of euthanasia." = 0;
local var Osw_Euth_Arg_5 notes "This variable determines if Dr. Oswald has told the PC his fifth argument in favour of euthanasia." = 0;
local var Osw_Fran_Euth notes "This variable keeps track of whether Dr. Oswald has made the decision to euthanase Fran. If Osw_Fran_Euth > 0, he will go and administer a lethal dose of drugs to Fran at the end of the dialogue with the PC." = 0;
local var Osw_Hosp_Attempt notes "This variable keeps track of whether the PC has offered to help out at the hospital (as per the quest of the same name) but failed to suitably impress Dr. Oswald with his medical skills." = 0;
local var Osw_Hosp_Job notes "This variable keeps track of whether Dr. Oswald has accepted the PC's medical credentials and has allowed him access to the hospital's patients." = 0;
}
NPCName "Dr. Bernard Oswald"
Location "Caves of Sandover"
Description "This is Bernard Oswald, the Scab Doctor.\nHe will not barter with the PC unless he has completed the 'Challenge the Tech Supplies caravan's charges' quest in such a way that the caravan's prices are lowered."
Unknown_Desc "You see a man in a white lab coat."
Known_Desc "It's Doctor Oswald. He looks busy."
Detailed_Desc "The doctor is kept extremely busy by all his patients."
/* Float message nodes */

Floatnode "Osw_Eleanor"
notes "This float node is used when Oswald is still at the site where Eleanor, the lost scavenger, is found, after Oswald has healed the woman."
{
"That should hold for now, although she should get back to the caves as soon as possible.",
"Honestly, what was she doing out here on her own, anyway?",
"Some nasty injuries she had there.",
"It'll be a few months before that young lady is out scavenging again."
}
Floatnode "Osw_PC_Not_Doc"
notes "Dr. Oswald floats one of these lines if the PC tries to interfere with any of his patients before he has given the PC permission to do so. See the 'Help Out in the Hospital' quest in the Wiki for details."
{
"STAY AWAY FROM THOSE PATIENTS!",
"YOU ARE NOT TO INTERFERE WITH THOSE PATIENTS!"
}
Floatnode "Osw_Normal"
notes "Oswald's standard float node."
{
"Another day, another tumor.",
"I don't know if our meds will last out the week, let alone the month.",
"That's all I need - another patient.",
"*Sigh.* I don't hold out much hope for some of these poor souls.",
"When will these people learn to buy more rad drugs?",
"I do wish they wouldn't try scavenging the more dangerous areas."
}
Floatnode "Osw_Euth"
notes "Oswald floats this text whilst administering a lethal dose of drugs to Fran, if the PC convinces the Doctor to euthanase her."
{
"I'm sorry it has come to this, Fran.",
"Sleep well, you poor soul.",
"It'll all be over in a second.",
"You're going to a better place."
}

/* Regular nodes */

Node "Osw_0"
notes ""
is_wtg = false
{
NPCText "***STARTING CONDITIONS***"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "- The PC has not spoken to Oswald before -" linkto "Osw_1a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- The PC has spoken to Oswald before -" linkto ""  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- The PC has fixed the Autodoc AND not spoken to Dr. Oswald since doing so -" linkto "Osw_3_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- The PC has failed to fix the Autodoc AND not spoken to Dr. Oswald since doing so -" linkto "Osw_3_1c_1"  notes "The PC has made five attempts to fix the Autodoc, none of which were successful."
              }
}
Node "Osw_1a_1"
notes ""
is_wtg = false
{
NPCText "Just a second. [The lab-coated man scribbles something on a clipboard.]"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "[WAIT]" linkto "Osw_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What are you writing, there?" linkto "Osw_1a_2b"  notes ""
              }
}
Node "Osw_1a_2a_1"
notes ""
is_wtg = false
{
NPCText "Right. Sorry about the wait. What appears to be the problem?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You're a doctor, I presume?" linkto "Osw_1a_3a" conditions { CHECK_STAT perception >= 4 link_next AND, CHECK_STAT charisma >=  7 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why do you think there is a problem?" linkto "Osw_1a_2a_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What were you writing, there?" linkto "Osw_1a_2a_2a"  notes ""
              }
}
Node "Osw_1a_2a_2a"
notes ""
is_wtg = false
{
NPCText "Not that it's any of your concern, but I was updating a patient's notes."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You're a doctor, I presume?" linkto "Osw_1a_3a" conditions { CHECK_STAT perception >= 4 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do around here?" linkto "Osw_1a_2a_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "It's my concern if I choose it to be." linkto "Osw_0"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_1a_2a_2b"
notes ""
is_wtg = false
{
NPCText "I am a doctor. Bernard Oswald is my name. Presumably you are feeling poorly or you would not be in here."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why do you think there is a problem?" linkto "Osw_0"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What were you writing, there?" linkto "Osw_1a_2a_2a"  notes ""
              }
}
Node "Osw_1a_2b"
notes ""
is_wtg = false
{
NPCText "I said just a second! [He continues scribbling.]"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "[WAIT]" linkto "Osw_1a_2a_1"  notes ""
              }
}
Node "Osw_1a_3a"
notes ""
is_wtg = false
{
NPCText "Of course. My name is Doctor Oswald. Are you unwell?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I've been injured." linkto "Osw_2_1a_1"  notes "This node only appears if the PC has less than maximum health points."
          int=4 Reaction=REACTION_NEUTRAL playertext "I need surgery on a serious injury." linkto "Osw_2_1b_1"  notes "This node appears if the PC has eye damage or has crippled limbs."
          int=4 Reaction=REACTION_NEUTRAL playertext "I think I've been poisoned." linkto "Osw_2_1c_1" conditions { CHECK_STAT cur_poison_lev > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I think I've been exposed to radiation." linkto "Osw_2_1d_1" conditions { CHECK_STAT cur_rad_lev > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Nothing that needs looking at for now. Let me ask you a question." linkto "Osw_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_1a_3b"
notes ""
is_wtg = false
{
NPCText "[He frowns.] Very few people come in here unless there is something wrong with them. If you aren't unwell, please leave at once."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I've been injured." linkto "Osw_2_1a_1"  notes "This node only appears if the PC has less than maximum health points."
          int=4 Reaction=REACTION_NEUTRAL playertext "I need surgery on a serious injury." linkto "Osw_2_1b_1"  notes "This node appears if the PC has eye damage or has crippled limbs."
          int=4 Reaction=REACTION_NEUTRAL playertext "I think I've been poisoned." linkto "Osw_2_1c_1" conditions { CHECK_STAT cur_poison_lev > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I think I've been exposed to radiation." linkto "Osw_2_1d_1" conditions { CHECK_STAT cur_rad_lev > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Nothing that needs looking at for now. Let me ask you a question." linkto "Osw_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1_0"
notes ""
is_wtg = false
{
NPCText "And what seems to be the problem?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I've been injured." linkto "Osw_2_1a_1"  notes "This node only appears if the PC has less than maximum health points."
          int=4 Reaction=REACTION_NEUTRAL playertext "I need surgery on a serious injury." linkto "Osw_2_1b_1"  notes "This node appears if the PC has eye damage or has crippled limbs."
          int=4 Reaction=REACTION_NEUTRAL playertext "I think I've been poisoned." linkto "Osw_2_1c_1" conditions { CHECK_STAT cur_poison_lev > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I think I've been exposed to radiation." linkto "Osw_2_1d_1" conditions { CHECK_STAT cur_rad_lev > 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Nothing that needs looking at for now. Let me ask you a question." linkto "Osw_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1a_1"
notes "The Osw_2_1a* path is where the PC can have losses in hit points healed."
is_wtg = false
{
NPCText "I see. Let me take a look at you, then."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Allow him to examine you.]" linkto "Osw_2_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I would prefer it if I were examined by a female member of staff." linkto "Osw_2_1a_2F"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No. Goodbye." linkto "Osw_2_1a_2b"  notes ""
              }
}
Node "Osw_2_1a_2a_1"
notes ""
is_wtg = false
{
NPCText "Hmm. You seem to have a series of small cuts, abrasions and bruising, none of which should be life-threatening on their own. However, they should be treated straight away. In combination with one another, even minor wounds can cause more serious problems."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "That's just what I was going to say." linkto "Osw_2_1a_2a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can you help me?" linkto "Osw_2_1a_2a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get them looked at another time. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1a_2a_2a_1"
notes ""
is_wtg = false
{
NPCText "I see. I suppose you were about to treat yourself as well?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Yes. I just wanted a second opinion." linkto "Osw_2_1a_2a_2a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No." linkto "Osw_2_1a_2a_2a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1a_2a_2a_2a_1"
notes ""
is_wtg = false
{
NPCText "Well, now you have it, 'doctor'. If you will excuse me, I have patients to whom I must attend who don't share your medical expertise."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I need to buy some meds from you so I can heal myself." linkto "Osw_5a_1"  notes "If the PC has completed the 'Challenge the Tech Supplies caravan's charges' quest in such a way that the caravan's prices are lowered, go to Osw_5b_1 instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Thank you. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1a_2a_2a_2b_1"
notes ""
is_wtg = false
{
NPCText "In that case, kindly leave the diagnoses to me."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "All right. Will you help me?" linkto "Osw_2_1a_2a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1a_2a_2b_1"
notes ""
is_wtg = false
{
NPCText "That's what I'm here to do. Just pop yourself into one of the empty beds and we'll see what we can do to get you fixed."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay." linkto "Osw_2_1a_2a_2b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get the injuries looked at another time. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1a_2a_2b_2"
notes "Make the PC's health points five less than his maximum. If he was only 5 or less away from his health points, make no change."
is_wtg = false
{
NPCText "[Doctor Oswald applies a series of treatments to your wounds and dresses them all appropriately. Finally, he brings you an earthenware mortar bowl filled with a murky looking liquid.] Drink this."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What is it?" linkto "Osw_2_1a_2a_2b_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No, thank you. I don't want to." linkto "Osw_2_1a_2a_2b_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Drink the bowl's contents.]" linkto "Osw_2_1a_2a_2b_3a_1"  notes ""
              }
}
Node "Osw_2_1a_2a_2b_3a_1"
notes "Take the PC up to full health. Apply the temporary -1 to PER that you get from using one sack of Healing Powder."
is_wtg = false
{
NPCText "[The liquid is surprisingly warm. It is a watery concoction that tastes of an unpleasant mix of unfamiliar herbs.]"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Yuck!" linkto "Osw_2_1a_2a_2b_3a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Thank you." linkto "Osw_2_1a_2a_2b_3a_2"  notes ""
              }
}
Node "Osw_2_1a_2a_2b_3a_2"
notes ""
is_wtg = false
{
NPCText "[He takes the bowl back.] That's all I can do for you. Now, if you don't mind, I'll be needing that bed back, as well."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I have another injury that I'd like you to take a look at." linkto "Osw_0"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Before I go, can I ask you a question?" linkto "Osw_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Thank you for your help, Doctor. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1a_2a_2b_3b_1"
notes ""
is_wtg = false
{
NPCText "It's nothing to worry about. It's a simple mix of plant matter that is known for its healing properties."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Drink the bowl's contents.]" linkto "Osw_2_1a_2a_2b_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Are there any side effects?" linkto "Osw_2_1a_2a_2b_3b_2"  notes ""
              }
}
Node "Osw_2_1a_2a_2b_3b_2"
notes ""
is_wtg = false
{
NPCText "Oh, some slight drowsiness, perhaps, but nothing that won't pass after an hour or two. Really, you have nothing to worry about. Drink it whilst it's still warm."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Drink the bowl's contents.]" linkto "Osw_2_1a_2a_2b_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No, thank you. You've done enough for me." linkto "Osw_2_1a_2a_2b_3a_2"  notes ""
              }
}
Node "Osw_2_1a_2b"
notes ""
is_wtg = false
{
NPCText "Don't be silly. Come on, this won't take a moment."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Allow him to examine you.]" linkto "Osw_2_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I would prefer it if I were examined by a female member of staff." linkto "Osw_2_1a_2F"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I said no. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1a_2F"
notes ""
is_wtg = false
{
NPCText "You needn't worry. You won't have anything I haven't seen before."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Allow him to examine you.]" linkto "Osw_2_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1b_1"
notes "The Osw_2_1b* path is where the PC can have damaged eyes or crippled limbs healed."
is_wtg = false
{
NPCText "Yes, I thought I noticed that you were having trouble when you came in. Let me take a look at that."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Allow him to examine you.]" linkto "Osw_2_1b_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "I would prefer it if I were examined by a female member of staff." linkto "Osw_2_1b_2F"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No. Goodbye." linkto "Osw_2_1a_2b"  notes ""
              }
}
Node "Osw_2_1b_2a_1"
notes ""
is_wtg = false
{
NPCText "Oh dear. Yes, this is quite nasty. I dread to think what would have happened if you hadn't got this treated soon."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Can you fix it?" linkto "Osw_2_1b_2a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get it looked at another time. Goodbye for now." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1b_2a_2"
notes ""
is_wtg = false
{
NPCText "Yes. What needs to be done is actually fairly simple, given how unpleasant the injury is. Lie down, won't you? We'll have you patched up in no time."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "[Lie down as Dr. Oswald instructs you.]" linkto "Osw_2_1b_2a_3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'll get it looked at another time. Goodbye for now." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1b_2a_3"
notes "An hour or so should pass whilst the PC is 'in surgery'. Any crippled limbs or eye damage the PC is suffering from is repaired."
is_wtg = false
{
NPCText "[The Doctor spends a long time tending to your injury.] When he's finished, he helps you out of bed. Now, that's not a miracle cure; you're still going to need to take it easy for a few days whilst that heals, okay?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I have another ailment that I'd like you to take a look at." linkto "Osw_2_1_0"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Before I go, can I ask you a question?" linkto "Osw_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Thank you for your help, Doctor. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1b_2b"
notes ""
is_wtg = false
{
NPCText "Don't be silly. Come on, this won't take a moment."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Allow him to examine you.]" linkto "Osw_2_1b_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I would prefer it if I were examined by a female member of staff." linkto "Osw_2_1a_2F"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I said no. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1b_2F"
notes ""
is_wtg = false
{
NPCText "You needn't worry. You won't have anything I haven't seen before."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. [Allow him to examine you.]" linkto "Osw_2_1a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "No. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1c_1"
notes "The Osw_2_1c* node is where the PC can be cured of poison by Dr. Oswald."
is_wtg = false
{
NPCText "Poisoned, you say? Well, I'll need a blood sample to be sure of what I need to provide an antidote for."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Blood sample?" linkto "Osw_2_1c_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. What do you need me to do?" linkto "Osw_2_1c_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I feel better already. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1c_2a_1"
notes ""
is_wtg = false
{
NPCText "Oh yes, I can't make a diagnosis without it. Just a little amount. You're a big boy; you don't mind needles, do you?"
 NPCFemaleText "Oh yes, I can't make a diagnosis without it. Just a little amount. You're a big girl; you don't mind needles, do you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I hate needles. No deal." linkto "Osw_2_1c_2a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay. What do you need me to do?" linkto "Osw_2_1c_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I feel better already. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1c_2a_2"
notes ""
is_wtg = false
{
NPCText "I can't help you, in that case. Come back when you've come to your senses."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Okay, I've changed my mind. What do you want me to do?" linkto "Osw_2_1c_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1c_2b_1"
notes ""
is_wtg = false
{
NPCText "Just roll your sleeve up, please. [He fishes a convincingly clean-looking needle from a neatly arranged wall-rack.]"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "[Roll up your sleeve and allow Dr. Oswald to take a blood sample.]" linkto "Osw_2_1c_2b_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I feel better already. Goodbye." linkto "Osw_2_End"  notes ""
              }
}
Node "Osw_2_1c_2b_2"
notes ""
is_wtg = false
{
NPCText "[You hardly feel the needle as it goes in or, half a minute later, when it comes out.] There, all done. Just a moment whilst I run an analysis on the sample."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Do I get a lollipop for being brave?" linkto "Osw_2_1c_2b_3a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[WAIT]" linkto "Osw_2_1c_2b_4"  notes ""
              }
}
Node "Osw_2_1c_2b_3a"
notes ""
is_wtg = false
{
NPCText "[Dr. Oswald forces a smile.] Very good. I haven't heard that one today. Now I must have a look at this sample."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "[WAIT]" linkto "Osw_2_1c_2b_4"  notes ""
              }
}
Node "Osw_2_1c_2b_4"
notes ""
is_wtg = false
{
NPCText "[Five minutes later he comes back.] Yes, you were right; you do have a high level of toxins in your bloodstream. Luckily, I have an antidote to hand."
      options {
