Node "Osw_7_1c_2b_2"
notes "Increment the local variable Osw_Fran_Euth by 1."
is_wtg = false
{
NPCText "A man of your experience must know very well what I mean, Doctor. I'm talking about a merciful death for Fran."
 NPCFemaleText "A woman of your experience must know very well what I mean, Doctor. I'm talking about a merciful death for Fran."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "In that case I agree. It's for the best. Do what you have to do." linkto "Osw_7_1c_2b_3a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Absolutely not. I refuse to have anything to do with it." linkto "Osw_7_1c_2b_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You mean euthanasia? Is that even legal in Sandover?" linkto "Osw_6_01"  notes ""
              }
}
Node "Osw_7_1c_2b_3a"
notes ""
is_wtg = false
{
