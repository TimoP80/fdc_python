notes ""
is_wtg = false
{
NPCText "This isn't a vault. We don't have a team of skilled health-workers; our supply of med-drugs is pitiful; and our one Autodoc is busted to hell."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "[MORE]" linkto "Osw_6_08_1"  notes ""
