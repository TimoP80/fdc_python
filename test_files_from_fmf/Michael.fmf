Node "Mich_4_1"
notes "The Mich_4_* path comes from the main question node, Mich_9. It answers the PC's question, \"Have you lived in Sandover all your life?\""
is_wtg = false
{
NPCText "No. I have only been here for ten years or so. Maybe slightly longer; I suspect I have lost track of the time."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do in Sandover?" linkto "Mich_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where did you come from before you lived in Sandover?" linkto "Mich_4_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Sandover?" linkto "Mich_2_3a_2b_2c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I see. Let me ask you another question, please." linkto "Mich_9"  notes ""
              }
}
