Node "Mich_2_3d_2b_2"
notes ""
is_wtg = false
{
NPCText "Know them? I used to be an Explorer myself. *He pauses and he becomes more sombre.* Of course, that all ended on the day of our expedition to Sandover, which I presume the Explorers told you about. Tell me, is a man named Bruce still with the group?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Yes. It's Bruce who wants the bodies of the Explorers brought back to Crossroads." linkto "Mich_5_3"  notes "This node only appears if the player has accepted the bones quest from Bruce, the Wasteland Explorer."
          int=4 Reaction=REACTION_NEUTRAL playertext "Describe the duties you have in Sandover again, please." linkto "Mich_2_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you about something else." linkto "Mich_9"  notes ""
              }
}
Node "Mich_3_1"
notes "The Mich_3_* path is where the PC finds out for the first time about Michael's past with the Wasteland Explorers and the disasterous Sandover expedition. This is for players who meet Michael before Bruce, the Wasteland Explorer, in Crossroads."
is_wtg = false
{
NPCText "*He sighs.* I used to be part of a group that explores the Wastes for valuable items left unclaimed after the Great War."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "That doesn't sound like such a bad thing. Why the sigh?" linkto "Mich_3_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Wait... are you talking about the Wasteland Explorers?" linkto "Mich_5_1"  notes "This node only appears IF the PC has met Bruce, the Explorer Representitive, OR Miranda, his wife."
          int=4 Reaction=REACTION_NEUTRAL playertext "Please remind me of the places you have visited in the Wastes." linkto "Mich_2_3a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you a completely unrelated question." linkto "Mich_9"  notes ""
              }
}
