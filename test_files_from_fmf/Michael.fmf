/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.27.2-stable

*/

vars {
local var Mich_Rude notes "This monitors how rude the PC has been to Michael. If Mich_Rude goes over 2, the PC gets a different greeting and will not receive rad-away treatment from Michael. If it goes over 9, Michael will not speak to the PC at all and will float hostile speech.";
local var Mich_Rad_Away notes "This monitors whether Michael has used his spare sachet of Rad Away on the PC. Michael will only do so once.";
local var Mich_Danger_Site notes "This monitors whether or not Michael has told the PC where the site of the Explorers' disastrous expedition is.";
local var Mich_Bones_Know notes "";
local var Mich_Bones_Screwed notes "";
local var Mich_Site_Bones_Return notes "This monitors whether or not the PC has shown Michael all three sets of the bones of the Explorers who died and were left at the expedition site.";
local var Mich_G_Counter_Return notes "This monitors whether or not the PC has returned the geiger counter Michael lost at the Sandover expedition site.";
local var Mich_Shovel notes "This monitors whether the PC needs to find a shovel in order to complete the bones quest by digging up the remains of the two Explorers buried in Sandover's cemetary.";
local var Mich_Alex_Force notes "This monitors if the PC has convinced Alexander, the Scab leader, to overrule Michael and force the priest to let the PC dig up the bones of the two Explorers buried in Sandover's cemetary.";
local var Mich_Cemetary_Bones notes "This monitors whether or not the PC has dug up the bones of the two Explorers buried in the Sandover cemetary.";
local var Mich_Guilt_Trip notes "This monitors whether or not the PC has tried to guilt-trip Michael over the Explorers' disastrous expedition to Sandover. If Mich_Guilt_Trip=1, the PC has had his one chance to convince Michael to kill himself. If Mich_Guilt_Trip=2, Michael will not speak to the PC at all in the future and will float hostile speech.";
local var Mich_Spoken_Intro notes "";
}
NPCName "Michael"
Location "Sandover Caves"
Description "This is Michael, the Scab 'Priest'. He used to be known as Mikey, the Wasteland Explorer. However, the disastrous expedition to the high-rad area near Sandover caused him to turn his back on his life as an explorer and become a priest-like figure for the Scabs of Sandover."
Unknown_Desc "You see a figure in loose-fitting, dun-colored robes."
Known_Desc "You see Michael shuffling around with his usual pious gait."
Detailed_Desc "Despite his loose-fitting robes, you can tell that he is stick-thin and far from healthy."
/* Dialogue starting conditions */

start_conditions
default_condition -1
{
cond target_node "Mich_1a_1"
{
    SSL "local_var(LVAR_Mich_Spoken_Intro) == 0" var_param "Mich_Spoken_Intro" eval 1 value_to_check "0" ini_index 3 link 0
},
cond target_node "Mich_1b_1"
{
    SSL "local_var(LVAR_Herebefore) == 1" var_param "" eval -1 value_to_check "" ini_index 9 link 1,
    SSL "local_var(LVAR_Mich_Spoken_Intro) == 1" var_param "Mich_Spoken_Intro" eval 1 value_to_check "1" ini_index 3 link 1,
    SSL "local_var(LVAR_Mich_Rude) <= 2" var_param "Mich_Rude" eval 6 value_to_check "2" ini_index 3 link 0
},
cond target_node "Mich_1_Ba_1"
{
    SSL "local_var(LVAR_Mich_Spoken_Intro) == 1" var_param "Mich_Spoken_Intro" eval 1 value_to_check "1" ini_index 3 link 1,
    SSL "local_var(LVAR_Mich_Rude) >= 3" var_param "Mich_Rude" eval 5 value_to_check "3" ini_index 3 link 0
},
cond target_node "FloatHostile"
{
    SSL "local_var(LVAR_Mich_Rude) >= 10" var_param "Mich_Rude" eval 5 value_to_check "10" ini_index 3 link 2,
    SSL "local_var(LVAR_Mich_Guilt_Trip) > 1" var_param "Mich_Guilt_Trip" eval 3 value_to_check "1" ini_index 3 link 0
},
cond target_node "Debugger"
{
    SSL "default" var_param "" eval -1 value_to_check "" ini_index 5 link 0
}
};

/* Float message nodes */

Floatnode "FloatHostile"
notes "Hostile text to float for Michael."
{
"Go away, you heathen!",
"Get away from me, you incarnation of evil!",
"I am not speaking to you.",
"Off with you.",
"Burn in hell, bastard!"
}
Floatnode "Debugger"
notes "just some shit"
{
"Help! I can't determine my starting node. I'm fucked up!"
}

/* Regular nodes */

Node "Mich_0"
notes ""
is_wtg = false
{
NPCText "Set the opening conditions for the dialogue with Michael, the Scab 'Priest'"
      options {
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has never met Michael before -" linkto "Mich_1a_1"  notes ""
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has met Michael before -" linkto "Mich_1b_1"  notes "Michael needs to have spoken node Mich_1a_2a, OR, for dumb players, node Mich_1a_D2, where he introduces himself by name AND the variable Mich_Rude must be 2 or less."
          int=1 Reaction=REACTION_NEUTRAL playertext "- The PC has met Michael before; the PC has been rude to the Priest -" linkto "Mich_1_Ba_1"  notes "Michael needs to have spoken node Mich_1a_2a, where he introduces himself by name AND the variable Mich_Rude must be 3 or greater. If Mich_Rude>=10 OR Mich_Guilt_Trip>1, then Michael will not speak to the PC at all, but will float hostile text."
              }
}
Node "Mich_1_Ba_1"
notes "Because the PC has been rude to Michael previously, the Priest will not use his rad-away freely on him. (See Mich_2_2). Michael's justification for this is that the PC is a 'bad sort', and the drugs should be used on someone more deserving. \nDecrement the variable Mich_Rude by 1. This means Michael's wariness of the PC will wane with time."
is_wtg = false
{
NPCText "Hello again, my son. I trust you will remember your manners, this time."
 NPCFemaleText "Hello again, my child. I trust you will remember your manners, this time."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hello, Michael. I'd like to ask you a question." linkto "Mich_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've managed to find a shovel." linkto "Mich_1b_2a"  notes "This option only appears IF the PC has a shovel AND Mich_Shovel>0 AND Mich_Cemetary_Bones=0. Also, the variable Mich_Alex_Force must be greater than 0, OR Mich_G_Counter_Return must be greater than 0 AND Mich_Site_Bones_Return must be greater than 2."
          int=4 Reaction=REACTION_NEUTRAL playertext "Alexander said you have to give me the two sets of bones you know the whereabouts of." linkto "Mich_7_1"  notes "This node is only visible if the variable Mich_Alex_Force>0 AND Mich_Shovel<1."
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "You can stop calling me 'your son' for a start." linkto "Mich_1_Ba_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "You can stop calling me 'your child' for a start." linkto "Mich_1_Ba_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, I need to be somewhere else. Goodbye." linkto "done"  notes ""
              }
}
Node "Mich_1_Ba_2"
notes "Increment Mich_Rude by 1."
is_wtg = false
{
NPCText "Still the attitude, hmm? Please leave and only come back when you have calmed down."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "No, I think I'll kill you instead, you self-righteous bastard. *Draw weapon.*" linkto "combat"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Mich_1a_1"
notes ""
is_wtg = false
{
NPCText "Good day to you, my son. How may I help you?"
 NPCFemaleText "Good day to you, my child. How may I help you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hello, I'm trying to get to know the people around here. What can you tell me about yourself?" linkto "Mich_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "I'm not 'your son'." linkto "Mich_1a_1B"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "I'm not 'your child'." linkto "Mich_1a_1B"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, I need to be somewhere else. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "You look scary." linkto "Mich_1a_D1_a"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Poo, you smell funny!" linkto "Mich_1a_D1_b"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Hello. Who you?" linkto "Mich_1a_D2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Mich_1a_1B"
notes "Increment Mich_Rude by 1."
is_wtg = false
{
NPCText "Well... no, of course not. Not in the biological sense. I mean no harm; what can I do for you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm trying to get to know the people around here. What can you tell me about yourself?" linkto "Mich_1a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You can stand there whilst I kill you." linkto "combat"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Mich_1a_2a"
notes ""
is_wtg = false
    insert_custom_code {
    "set_local_var(LVAR_Mich_Spoken_Intro,1);"
    }
{
NPCText "My name is Michael. Would you like to know what I do here in Sandover?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Yes, please." linkto "Mich_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Yes! Come on, don't keep me waiting." linkto "Mich_1a_2B_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Maybe another time. I have to be going." linkto "done"  notes ""
              }
}
Node "Mich_1a_2B_1"
notes "Increment Mich_Rude by 1."
is_wtg = false
{
NPCText "You should learn greater patience, my son! It is a rare virtue in the Wastes, but none should consider themselves above it."
 NPCFemaleText "You should learn greater patience, my child! It is a rare virtue in the Wastes, but none should consider themselves above it."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I apologize, you're right. Please tell me a bit about what you do around here." linkto "Mich_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You may have time to be patient, but I am very busy." linkto "Mich_1a_2B_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Don't call me 'my damn son'!" linkto "Mich_1a_2B_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Don't call me 'my damn child!'" linkto "Mich_1a_2B_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Mich_1a_2B_2a"
notes "Increment Mich_Rude by 1."
is_wtg = false
{
NPCText "More haste, less speed, my son. You will achieve little if your mind is not settled."
 NPCFemaleText "More haste, less speed, my son. You will achieve little if your mind is not settled."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I apologize, you're right. Please tell me a bit about what you do around here." linkto "Mich_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Enough of the sermons, wise man. Tell me what you do around here." linkto "Mich_2_1"  notes "Increment Mich_Rude by 1."
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "Don't call me 'my damn son'!" linkto "Mich_1a_2B_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "Don't call me 'my damn child!'" linkto "Mich_1a_2B_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Mich_1a_2B_2b"
notes "Increment Mich_Rude by 1."
is_wtg = false
{
NPCText "So much anger. Why is that? I am here only to help others."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I apologize. Please tell me a bit about what you do around here." linkto "Mich_2_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "You can shove your 'help'. Goodbye." linkto "done"  notes "Increment Mich_Rude by 2."
              }
}
Node "Mich_1a_D1_a"
notes ""
is_wtg = false
{
NPCText "Oh. *He laughs.* I don't mean to be. I'm here to help you if you need it."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Who you?" linkto "Mich_1a_D2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Poo, you smell funny!" linkto "Mich_1a_D1_b"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Mich_1a_D1_b"
notes ""
is_wtg = false
{
NPCText "Hmm. Can I help you in any way, my son? I am rather busy at the moment."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Who you?" linkto "Mich_1a_D2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "You look scary." linkto "Mich_1a_D1_a"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Mich_1a_D2"
notes ""
is_wtg = false
    insert_custom_code {
    "set_local_var(LVAR_Mich_Spoken_Intro,1);"
    }
{
NPCText "My name is Michael. The people in this town call me their priest."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "What do priest do?" linkto "Mich_1a_D3"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "What a priest?" linkto "Mich_1a_D3"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "- LEAVE -" linkto "done"  notes ""
              }
}
Node "Mich_1a_D3"
notes ""
is_wtg = false
{
NPCText "A priest does good things for people who need aid. Do you need help with anything, my son?"
 NPCFemaleText "A priest does good things for people who need aid. Do you need help with anything, my child?"
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "A got a hurt. *Point to injury.*" linkto "Mich_2_3b"  notes "This node only appears if the PC has less than maximum hit points."
          int=-3 Reaction=REACTION_NEUTRAL playertext "I keep doing sick and not feeling good." linkto "Mich_2_3c_1a"  notes "This only appears if the PC is radiated."
          int=-3 Reaction=REACTION_NEUTRAL playertext "I not need help. Goodbye." linkto "done"  notes ""
              }
}
Node "Mich_1b_1"
notes ""
is_wtg = false
{
NPCText "Hello again, my son. How may I help you?"
 NPCFemaleText "Hello again, my child. How may I help you?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hello, Michael. I'd like to ask you a question." linkto "Mich_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've managed to find a shovel." linkto "Mich_1b_2a" conditions { LOCAL_VARIABLE Mich_Shovel > 0 link_next AND, LOCAL_VARIABLE Mich_Cemetary_Bones == 0 link_next AND, LOCAL_VARIABLE Mich_Alex_Force > 0 link_next NONE } notes "This option only appears IF the PC has a shovel AND Mich_Shovel>0 AND Mich_Cemetary_Bones=0. Also, the variable Mich_Alex_Force must be greater than 0, OR Mich_G_Counter_Return must be greater than 0 AND Mich_Site_Bones_Return must be greater than 2."
          int=4 Reaction=REACTION_NEUTRAL playertext "Alexander said you have to give me the two sets of bones you know the whereabouts of." linkto "Mich_7_1" conditions { LOCAL_VARIABLE Mich_Alex_Force > 0 link_next AND, LOCAL_VARIABLE Mich_Shovel < 1 link_next NONE } notes "This node is only visible if the variable Mich_Alex_Force>0 AND Mich_Shovel<1."
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "You can stop calling me 'your son' for a start." linkto "Mich_1b_2B"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "You can stop calling me 'your child' for a start." linkto "Mich_1b_2B"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, I need to be somewhere else. Goodbye." linkto "done"  notes ""
              }
}
Node "Mich_1b_2a"
notes ""
is_wtg = false
{
NPCText "You've come back for the bones of the last two Explorers, presumably?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "That's right. Let's go out and get them." linkto "Mich_6_4a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Before we go out to the cemetary, I'd like to ask you a question." linkto "Mich_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, I need to be somewhere else. Goodbye." linkto "done"  notes ""
              }
}
Node "Mich_1b_2B"
notes "Increment Mich_Rude by 1."
is_wtg = false
{
NPCText "Oh. I mean no harm by it, you know."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Anyway, I'd like to ask you a question." linkto "Mich_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Mich_2_1"
notes "The Mich_2_* path is where the PC finds out about Michael's roles in Sandover. See NPC Text for this node."
is_wtg = false
{
NPCText "The people of Sandover think of me as their priest. I am not, strictly speaking, a priest, but the duties I perform around the town are like those usually associated with holy men."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What duties are those?" linkto "Mich_2_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Have you lived in Sandover all your life?" linkto "Mich_4_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Sandover?" linkto "Mich_2_3a_2b_2c_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Please let me ask you a question about something else." linkto "Mich_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've got to go. Goodbye." linkto "done"  notes ""
              }
}
Node "Mich_2_2"
notes ""
is_wtg = false
{
NPCText "I guide and give advice to those who seek it; I provide what meagre comfort I can for the town's sick and infirm; I administer medical aid where I can; and, for those Sandover people who cannot be helped and die, I oversee their burials."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I could use your advice." linkto "Mich_2_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm hurt. Can you help with these injuries?" linkto "Mich_2_3b"  notes "This node only appears if the PC has less than his maximum hit points."
          int=4 Reaction=REACTION_NEUTRAL playertext "I feel a little sick. I think I've been exposed to too many rads. Can you help?" linkto "Mich_2_3c_1a"  notes "IF Mich_Rad_Away>0 OR IF Mich_Rude>=3, go to Mich_2_3c_1b instead."
          int=4 Reaction=REACTION_NEUTRAL playertext "Where do you bury the town's dead?" linkto "Mich_2_3d_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Interesting. Let me ask you about something else." linkto "Mich_9"  notes ""
              }
}
Node "Mich_2_3a_1"
notes ""
is_wtg = false
{
NPCText "*The Priest visibly straightens up, delighted to have his advice called upon.* It would be my pleasure. What can I help you with?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm looking for a facility that was owned by General Atomics International before the Great War. Do you know where it is?" linkto "Mich_2_3a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I am fairly new to this area of the wastes. What can you tell me about them?" linkto "Mich_2_3a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I MUST know where you bought those robes. They're just fabulous, darling." linkto "Mich_2_3a_2d_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, I ought not to talk too much about my concerns - no offence. Tell me what your duties were, again." linkto "Mich_2_2"  notes ""
              }
}
Node "Mich_2_3a_2a_1"
notes ""
is_wtg = false
{
NPCText "*Michael is still for a moment. You can imagine him frowning in thought under his cowl.* No... the name does not ring a bell. Forgive me, my son; I cannot be of any use to you with that. Maybe Alexander can help you."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who is Alexander?" linkto "Mich_2_3a_2a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I am fairly new to this area of the Wastes. What can you tell me about them?" linkto "Mich_2_3a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I MUST know where you bought those robes. They're just fabulous, darling." linkto "Mich_0"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Actually, I ought not to talk too much about my concerns - no offence. Tell me what your duties were, again." linkto "Mich_2_2"  notes ""
              }
}
Node "Mich_2_3a_2a_2"
notes ""
is_wtg = false
{
NPCText "Alexander is the leader of the people of Sandover. He lives in these caves; you can find him in these caves by *put in direction to Alexander's area.*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks. Perhaps you can give me advice about something else, too." linkto "Mich_2_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What were the things you did around Sandover again?" linkto "Mich_2_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I have a question about something else that I'd like to ask you." linkto "Mich_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I'd better go and speak to him. Goodbye for now." linkto "done"  notes ""
              }
}
Node "Mich_2_3a_2b_1"
notes ""
is_wtg = false
{
NPCText "The Wastes are a dangerous place, my son. I have not travelled much, but I can tell you what I know about the places I have been and lived in. These are Rusty Springs, where I was born; Crossroads, where I used to live and work; and Sandover, where we are now."
 NPCFemaleText "The Wastes are a dangerous place, my child. I have not travelled much, but I can tell you what I know about the places I have been and lived in. These are Rusty Springs, where I was born; Crossroads, where I used to live and work; and Sandover, where we are now."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Tell me about Rusty Springs." linkto "Mich_2_3a_2b_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Tell me about Crossroads." linkto "Mich_2_3a_2b_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Tell me about Sandover." linkto "Mich_2_3a_2b_2c_1"  notes ""
              }
}
Node "Mich_2_3a_2b_2a_1"
notes ""
is_wtg = false
{
NPCText "As I have already said, I was born and raised in Rusty Springs. It is a good place - the town is built upon a source of natural spring water, and it is to this that the town owes its prosperity."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What else can you tell me about Rusty Springs?" linkto "Mich_2_3a_2b_2a_2a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Could you tell me how to get to Rusty Springs?" linkto "Mich_2_3a_2b_2a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Which parts of the wastes are you familiar with?" linkto "Mich_2_3a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you a completely different question." linkto "Mich_9"  notes ""
              }
}
Node "Mich_2_3a_2b_2a_2a_1"
notes ""
is_wtg = false
{
NPCText "Alas, it is so long since I visited the town of my birth. The town may have changed so much since I was last there that what I might tell you about it would be entirely misleading. I advise you ask someone who has been there more recently, or visit Rusty Springs yourself."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why have you not revisited Rusty Springs in such a long time?" linkto "Mich_2_3a_2b_2a_2a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Could you tell me how to get to Rusty Springs?" linkto "Mich_2_3a_2b_2a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Which parts of the wastes are you familiar with?" linkto "Mich_2_3a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you a completely different question." linkto "Mich_9"  notes ""
              }
}
Node "Mich_2_3a_2b_2a_2a_2"
notes ""
is_wtg = false
{
NPCText "My life is rooted in Sandover, now. I am too busy here to go as far afield as Rusty Springs. Besides, I have changed a lot since I lived there; I doubt I would even want to return."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Could you tell me how to get to Rusty Springs?" linkto "Mich_2_3a_2b_2a_2b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Which parts of the wastes are you familiar with?" linkto "Mich_2_3a_2b_1"  notes ""
