NPCName "Security Control"
Location "GAI - Level 2"
Description "This is the central computer in the security control room on level 2 of the GAI HQ."
Unknown_Desc "You see a security computer."
Known_Desc "You see Security Control."
Detailed_Desc ""
/* Regular nodes */

Node "Switcher"
notes ""
{
NPCText "Starting conditions:"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Power is off" linkto "Node_001"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Power is on" linkto "Node_002"  notes ""
