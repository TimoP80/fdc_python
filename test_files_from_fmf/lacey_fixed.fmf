          int=4 Reaction=REACTION_NEUTRAL playertext "[More]" linkto "Lacey05_05a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Why can't you remember her name?" linkto "Lacey05_05b"  notes ""
              }
}
