Node "Lacey01_MALE_aBAD"
notes ""
is_wtg = false
/* Skill checks for node Lacey01_MALE_aBAD */

      define_skill_check Skill_Check_000_Speech {
      skill_num = 15;
      difficulty_modifier = -20;
      onsuccess => Lacey01_MALE_aBAD_2a;
      onfailure => Lacey01_MALE_aBAD_2b;
      }

{
NPCText "That works for both of us, buster. Now get the fuck out of my room."
      options {
          int=4 Reaction=REACTION_BAD playertext "Smell ya later, corpse-face." linkto "done"  notes "Lacey won't communicate with the PC from now on beyond float fext."
          int=4 Reaction=REACTION_BAD playertext "I'm not taking shit from a ghoul. [Combat]" linkto "combat"  notes ""
          int=4 linkflags skill_check Reaction=REACTION_NEUTRAL playertext "Wait, I'm sorry. I'm having a bad day. Can we try again?" linkto "Skill_Check_000_Speech"  notes ""
              }
}
