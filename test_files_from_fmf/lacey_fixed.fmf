          int=4 Reaction=REACTION_NEUTRAL playertext "Do that." linkto "Lacey05_02a"  notes ""
              }
}
Node "Lacey05_03a"
notes ""
is_wtg = true
{
NPCText "I decided enough was enough. I was... involved with a security guard at the time. Willow, her name was. Worked here, at the club. She set up cameras in the girls' rooms and, to go with it, the surveillance suite you found."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Involved? How?" linkto "Lacey05_04b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[More]" linkto "Lacey05_04a"  notes ""
              }
}
