Node "Lacey05_02a"
notes ""
is_wtg = true
{
NPCText "It wasn't the first time this sort of thing had happened, but it was the last straw. Let a man get steamin' drunk then let him loose on a pretty girl... you see the worst of the other half of humanity."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "[More]" linkto "Lacey05_03a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What sort of things would these men do?" linkto "Lacey05_03b"  notes ""
              }
}
