Node "Lacey01"
notes ""
is_wtg = false
{
NPCText "[This dark-haired female ghoul was probably strikingly attractive around the time her clothes were still in fashion, which by the looks of them was before the Great War. She looks you up and down with sharp, intelligent eyes]."
      options {
          int=1 Reaction=REACTION_NEUTRAL Gender=MALE playertext "[More]" linkto "Lacey01_MALE_a"  notes "PC = human. Time of day = day."
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "[More]" linkto "Lacey01_MALE_b"  notes "PC = human. Time of day = night."
          int=1 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "[More]" linkto "Lacey01_FEM"  notes "PC = human."
          int=4 Reaction=REACTION_NEUTRAL playertext "[More]" linkto "Lacey00"  notes "The PC is a ghoul."
          int=4 Reaction=REACTION_NEUTRAL playertext "[More]" linkto "Lacey00"  notes "The PC is a super mutant."
              }
}
Node "Lacey01_FEM"
notes ""
is_wtg = false
{
NPCText "You lookin' for work, sugar, or you interested in sampling the girls yourself?"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What is the strange language coming from the room with all the machines in it?" linkto "Lacey04" conditions { CHECK_STAT intelligence >= 4 link_next AND, CHECK_STAT intelligence < 6 link_next NONE } notes "Condition: low to moderate intelligence. The player has discovered Lacey’s surveillance suite in Brothel / Lacey’s Lounge on the top floor of Circle Junction, where a machine is playing audio from a Chinese listening station."
          int=4 Reaction=REACTION_NEUTRAL playertext "Why is there a machine speaking Chinese in the room with all the surveillance equipment?" linkto "Lacey04" conditions { CHECK_STAT intelligence >= 6 link_next AND, CHECK_STAT intelligence < 8 link_next NONE } notes "Condition: moderate to high intelligence. The player has discovered Lacey’s surveillance suite in Brothel / Lacey’s Lounge on the top floor of Circle Junction, where a machine is playing audio from a Chinese listening station."
          int=4 Reaction=REACTION_NEUTRAL playertext "Why is one of the machines in the surveillance suite counting in Chinese?" linkto "Lacey04" conditions { CHECK_STAT intelligence >= 8 link_next NONE } notes "Condition: very high intelligence. The player has discovered Lacey’s surveillance suite in Brothel / Lacey’s Lounge on the top floor of Circle Junction, where a machine is playing audio from a Chinese listening station."
          int=4 Reaction=REACTION_NEUTRAL playertext "Who are you?" linkto "Lacey03"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What kind of work?" linkto "Lacey01_FEM2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Girls? Do you mean the ghouls crawling around up here?" linkto "Lacey03_c1_MID_CHR" conditions { CHECK_STAT charisma <= 7 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Girls? Do you mean the ghouls crawling around up here?" linkto "Lacey03_c1_HIGH_CHR" conditions { CHECK_STAT charisma > 7 link_next NONE } notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Wot dat machine do funny talkie in other room?" linkto "Lacey00"  notes "The player has discovered Lacey’s surveillance suite in Brothel / Lacey’s Lounge on the top floor of Circle Junction, where a machine is playing audio from a Chinese listening station."
          int=-3 Reaction=REACTION_NEUTRAL playertext "Hoo you?" linkto "Lacey03"  notes ""
              }
}
