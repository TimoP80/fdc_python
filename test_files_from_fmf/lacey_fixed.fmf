Node "Lacey03"
notes "Branch 3 is where Lacey can talk a bit about herself."
is_wtg = false
{
NPCText "Well, now, you may call me Lacey. I look after the girls who work at this establishment."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What kind of work do the girls do?" linkto "Lacey03_a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "How much to hire one of your girls?" linkto "Lacey03_bMALE"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "How much to hire one of your girls?" linkto "Lacey03_bFEM"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Girls? Do you mean the ghouls crawling around up here?" linkto "Lacey03_c1_MID_CHR" conditions { CHECK_STAT charisma <= 7 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Girls? Do you mean the ghouls crawling around up here?" linkto "Lacey03_c1_HIGH_CHR" conditions { CHECK_STAT charisma > 7 link_next NONE } notes ""
              }
}
Node "Lacey03_a"
notes "Branch 3 is where Lacey can talk a bit about herself."
is_wtg = false
{
NPCText "[She gives a sharp, bitter laugh]. Ha! You ain't been out much sugar. My girls? They make your fantasies come true, that's their 'work'. Only question is, can you pay?"
      options {
          int=4 Reaction=REACTION_NEUTRAL Gender=MALE playertext "How much to hire one of your girls?" linkto "Lacey03_bMALE"  notes ""
          int=4 Reaction=REACTION_NEUTRAL Gender=FEMALE playertext "How much to hire one of your girls?" linkto "Lacey03_bFEM"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Girls? Do you mean the ghouls crawling around up here?" linkto "Lacey03_c1_MID_CHR" conditions { CHECK_STAT charisma <= 7 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Girls? Do you mean the ghouls crawling around up here?" linkto "Lacey03_c1_HIGH_CHR" conditions { CHECK_STAT strength > 7 link_next NONE } notes ""
              }
}
