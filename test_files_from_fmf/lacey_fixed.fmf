          int=4 Reaction=REACTION_NEUTRAL playertext "[More]" linkto "Lacey05_03a"  notes ""
              }
}
Node "Lacey05_04a"
notes ""
is_wtg = true
{
NPCText "Another \"john\" got nasty with one of my girls. This time, it was real bad. No way she was gonna earn money as a hooker, after that. Sweet thing. Funny. I can see her face clear as yours, but I can't remember her name."
