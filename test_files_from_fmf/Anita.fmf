Node "thanks"
notes ""
is_wtg = false
{
NPCText "Okay! Thank you so much! Not many people help out a sob story like me any more."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Sob story? You mean more so than usual?" linkto "story"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Happy to help. You take care now." linkto "done"  notes ""
              }
}
Node "pay"
notes ""
is_wtg = false
{
NPCText "I guess I have a little bit..."
      options {
          int=4 Reaction=REACTION_GOOD playertext "How's $2 sound?" linkto "thanks"  notes " karma +1 \nAnita likes the player"
          int=4 Reaction=REACTION_NEUTRAL playertext "How's $5 sound?" linkto "thanks"  notes "karma neutral\nAnita likes the player"
          int=4 Reaction=REACTION_BAD playertext "How's $10 sound?" linkto "thanks2"  notes "karma -2\nAnita likes the player"
          int=4 Reaction=REACTION_BAD playertext "How's $20 sound?" linkto "broke"  notes "Greedy bastard.  Karma - 5"
          int=4 Reaction=REACTION_GOOD playertext "Nah, forget the money. Here you go. [Give Anita food.]" linkto "thanks"  notes "karma +3\nAnita likes the player"
          int=4 Reaction=REACTION_BAD Gender=MALE playertext "You wanna eat, you gotta suck me." linkto "perv"  notes "if you're male.  Karma -10 or something"
          int=4 Reaction=REACTION_BAD Gender=FEMALE playertext "Wanna eat food? Eat me out first." linkto "perv"  notes "if you're female.  Karma -10 or something"
              }
}
