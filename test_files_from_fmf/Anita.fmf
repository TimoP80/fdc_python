NPCName "Anita"
Location "Sandover"
Description "starving scab"
Unknown_Desc "You see a young woman clad in rags."
Known_Desc "You see Anita."
Detailed_Desc "You see a young woman. She would be incredibly beautiful if not for the cancerous growths that cover her skin."
/* Regular nodes */

Node "switcher"
notes ""
is_wtg = false
{
NPCText "switch"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "First conversation" linkto "initial"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Have met before, Anita likes the player." linkto "talkfriend"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Have met before, Anita dislikes the player." linkto "talkdislike"  notes ""
              }
}
Node "initial"
notes "Make sure to check for food items.  Don't display the ones where you feed her if you havent got food. 'Dismiss' options appropriate to perception appear. PER to notice 'asshole' is currently 6."
is_wtg = false
{
NPCText "Hey, stranger. Spare some leftovers? [She holds out her hands pitifully]"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I got some food, but can you pay for it?" linkto "pay"  notes ""
          int=4 Reaction=REACTION_GOOD playertext "Sure, here you go. [Give Anita food.]" linkto "thanks"  notes " Karma + 3\nAnita likes the player"
          int=4 Reaction=REACTION_NEUTRAL playertext "[Pat yourself down.] Sorry, hon. I dont have anything on me." linkto "sorry"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Sorry, no. I gotta eat too, you know." linkto "DismissPER" conditions { CHECK_STAT perception >= 6 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sorry, no. I gotta eat too, you know." linkto "DismissBADPER" conditions { CHECK_STAT perception < 6 link_next NONE } notes ""
          int=4 Reaction=REACTION_BAD playertext "Get away from me, you worthless, ugly leech!" linkto "DismissPER" conditions { CHECK_STAT perception >= 6 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Get away from me, you worthless, ugly leech!" linkto "DismissBADPER" conditions { CHECK_STAT perception < 6 link_next NONE } notes ""
          int=-3 Reaction=REACTION_GOOD playertext "Food? Me see. [Dig through your pack.]" linkto "dumb1"  notes ""
          int=-3 Reaction=REACTION_BAD playertext "No! You no have!" linkto "dumbdis"  notes ""
              }
}
Node "talkfriend"
notes "Make sure to check for food items.  Don't display the ones where you feed her if you havent got food. 'Dismiss' options appropriate to perception appear. PER to notice \"asshole\" is currently 6."
is_wtg = false
{
NPCText "Hello again, stranger. Can you spare me some more food? I'm starving."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I've got food, but it'll cost you." linkto "pay"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Sure, here you are. [Give Anita food.]" linkto "thanks"  notes "Anita likes the player"
          int=4 Reaction=REACTION_NEUTRAL playertext "Not this time. See you around." linkto "sorry"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Stop leeching off me, you bloodsucker! Go find another mark." linkto "DismissPER" conditions { CHECK_STAT perception >= 6 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Stop leeching off me, you bloodsucker! Go find another mark." linkto "DismissBADPER" conditions { CHECK_STAT perception < 6 link_next NONE } notes ""
              }
}
Node "talkdislike"
notes "Make sure to check for food items.  Don't display the ones where you feed her if you havent got food."
is_wtg = false
{
NPCText "Come on, pal, give me something to eat!"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Fine. Here you go. [Give Anita food.]" linkto "thanks"  notes "Anita likes the player"
          int=4 Reaction=REACTION_NEUTRAL playertext "You can have food, but I want paying in return." linkto "pay"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I said no the first time, now crawl away before I ventilate your skull!" linkto "done"  notes ""
              }
}
Node "DismissPER"
notes "when you're a prick, you go here, then conversation ends. Come here if PER check passed.\nBoth options : Anita dislikes player."
is_wtg = false
{
NPCText "Yeah, sure. [She mutters 'Asshole' to herself.]"
      options {
          int=4 Reaction=REACTION_BAD playertext "And proud of it, baby." linkto "done"  notes ""
          int=4 Reaction=REACTION_BAD playertext "I heard that." linkto "done"  notes ""
              }
}
Node "DismissBADPER"
notes "when you're a prick, you go here, then conversation ends. If have low perception, go here.\nOption 1: Anita dislikes player"
is_wtg = false
{
