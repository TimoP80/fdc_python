/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.26.0-beta

*/

vars {
local var Gnaghi_Story_Interrupt notes "This variable keeps track of how many times the PC has interrupted Gnaghi whilst he's telling his life story. It also doubles as a means of keeping track of the PC's general rudeness." = 0;
}
NPCName "Gnaghi"
Location "Sandover"
Description "Eventually gives the PC the whereabouts of Sandover's scavenging grounds."
Unknown_Desc "a very old man."
Known_Desc "Gnaghi."
Detailed_Desc "he has a sprightly energy about him."
/* Float message nodes */

Floatnode "Gna_Float_1"
notes "Gnaghi's standard float node."
{
"Too many scavengers, not enough scavenge.",
"I'm getting too old for this.",
"Nice place to live, so long as you like rads.",
"If Jedrek wasn't such a shyster, I could've retired by now.",
"I ain't as young as I was, that's for sure.",
"The wastes are a dangerous place, mark my words."
}
Floatnode "Gna_Hostile"
notes "This node is used if the PC has offended Gnaghi, or Gnaghi is attacking the PC."
{
"Lucky for you I'm not twenty years younger than I am.",
"I've a good mind to teach you some manners.",
"I wouldn't have gotten away with that in my day.",
"Youngsters these days - no respect.",
"I'm not putting up with that behavior.",
"You'll walk away if you've any sense."
}

/* Regular nodes */

Node "Gnaghi_0"
notes "If the local variable Gnaghi_Story_Interrupt >= 6 then Gnaghi will not speak to the PC at all and will only float the float node Gna_Hostile ."
is_wtg = true
{
NPCText "- STARTING CONDITIONS -"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "The PC has not spoken to Gnaghi before." linkto "Gnaghi_1a_1"  notes ""
          int=6 Reaction=REACTION_NEUTRAL playertext "The PC has spoken to Gnaghi before." linkto "Gnaghi_1B_1"  notes ""
              }
}
Node "Gnaghi_1a_1"
notes ""
is_wtg = false
{
NPCText "Hello there, young feller. I don't recall seeing you 'round here before."
 NPCFemaleText "Hello there, young lady. I don't recall seeing you 'round here before."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who are you?" linkto "Gnaghi_1a_2"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Who you?" linkto "Gnaghi_1a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Fuck you, old-timer." linkto "Gnaghi_1B_1"  notes "Increment the local variable Gnaghi_Story_Interrupt by 3. This means Gnaghi will never train the PC's Outdoorsman skill."
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I leave." linkto "done"  notes ""
              }
}
Node "Gnaghi_1a_2"
notes ""
is_wtg = false
{
NPCText "They call me Gnaghi 'round these parts. As I recall, it's a nickname of sorts. Don't ask me what my real name is, though. Been years since I forgot it."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Do you know where I can find the General Atomics International base?" linkto "Gnaghi_1a_3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do in Sandover?" linkto "Gnaghi_2_1a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Sandover?" linkto "Gnaghi_2_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Fuck you, old-timer." linkto "Gnaghi_1B_1"  notes "Increment the local variable Gnaghi_Story_Interrupt by 3. This means Gnaghi will never train the PC's Outdoorsman skill."
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "Gnag-hi?" linkto "Gnaghi_1a_3D_1"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I go now." linkto "done"  notes ""
              }
}
Node "Gnaghi_1a_3"
notes ""
is_wtg = false
{
NPCText "[He stratches his chin in thought, causing a loud rasping noise.] Never heard o' such a place. Name like that strikes me as something from before the war."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you do in Sandover?" linkto "Gnaghi_2_1a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Sandover?" linkto "Gnaghi_2_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_1a_3D_1"
notes ""
is_wtg = false
{
NPCText "Err... sure, that's it. Don't go straining the brain there, young 'un. Take it easy."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "I go now." linkto "done"  notes ""
              }
}
Node "Gnaghi_1B_1"
notes ""
is_wtg = true
{
NPCText "An attitude, eh? Don't think just because I'm old, you can just push me around, young feller. Big mistake."
 NPCFemaleText "An attitude, eh? Don't think just because I'm old, you can just push me around, young lady. Big mistake."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why don't we see about that? *Draw weapon.*" linkto "combat"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_1b_1"
notes ""
is_wtg = true
{
NPCText "Hello, again, youngster. Keeping yourself out of trouble, I hope."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Hi. Do you have time to answer a question?" linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Alexander sent me. Could you tell me where your scavenging grounds are?" linkto "Gnaghi_3_1"  notes "This node only appears if Alexander (Scab leader) has agreed to reveal the whereabouts of the Scabs' scavenging grounds and told the PC to go to Gnaghi to get the information."
          int=4 Reaction=REACTION_NEUTRAL playertext "I'm looking for a pass key. Have you seen one?" linkto "Gnaghi_4_1"  notes "This option only appears if the PC has found the entrance to the GAI base, knows that he needs to find a pass key to enter it, does not already have the pass key, and has not found another way into the GAI base."
          int=4 Reaction=REACTION_NEUTRAL playertext "Fuck you, old-timer." linkto "Gnaghi_1B_1"  notes "Increment the local variable Gnaghi_Story_Interrupt by 3. This means Gnaghi will never train the PC's Outdoorsman skill, if he has not done so already."
          int=10 Reaction=REACTION_NEUTRAL playertext "Sorry, I thought you were someone else. Goodbye." linkto "done"  notes ""
          int=-3 Reaction=REACTION_NEUTRAL playertext "I not trouble." linkto "Gnaghi_1b_2D_1"  notes ""
              }
}
Node "Gnaghi_1b_2D_1"
notes ""
is_wtg = true
{
NPCText "Of course you're not. Old Gnaghi can tell you're a good kid. You take care, now."
      options {
          int=-3 Reaction=REACTION_NEUTRAL playertext "Blar." linkto "done"  notes ""
              }
}
Node "Gnaghi_2_1a_1"
notes "The Gnaghi_2_* path is where the PC can find out about Gnaghi's role as a scavenger and about the Tech Supplies caravan."
is_wtg = false
{
NPCText "I do what most of us in Sandover do and that is scavenge to make ends meet. I'm one of the town's better scavengers."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "What do you scavenge for?" linkto "Gnaghi_2_1a_2"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Sandover?" linkto "Gnaghi_2_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What makes you so good at scavenging?" linkto "Gnaghi_2_1c_01"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_2_1a_2"
notes ""
is_wtg = false
{
NPCText "We scavenge for anything that's worth anything. That, we sell on."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who do you sell your goods to?" linkto "Gnaghi_2_1a_3a_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where do you go to scavenge?" linkto "Gnaghi_2_1a_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Sandover?" linkto "Gnaghi_2_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you about something else?" linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_2_1a_3a_1"
notes ""
is_wtg = false
{
NPCText "We don't have any choice but to sell to those goddamn rip-off merchants, the Tech Supplies caravan. They'll take you for every last cap if you give them half a chance."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Why don't you sell to other buyers?" linkto "Gnaghi_2_1a_3a_2a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where can I find the Tech Supplies caravan?" linkto "Gnaghi_2_1a_3a_2b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Where do you go to scavenge?" linkto "Gnaghi_2_1a_3b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "What can you tell me about Sandover?" linkto "Gnaghi_2_1b_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you about something else?" linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_2_1a_3a_2a"
notes ""
is_wtg = false
{
NPCText "No-one else comes out here to Sandover, see? Tech Supplies have got theirselves a regular mo- no- poly."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Where can I find the Tech Supplies caravan?" linkto "Gnaghi_2_1a_3a_2b"  notes ""
