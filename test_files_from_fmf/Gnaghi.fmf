      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you about something else?" linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_2_1c_B1"
notes ""
is_wtg = false
{
NPCText "You can't stop running your trap while I'm talking, younster. I'm not going to bother if you're not going to listen."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me ask you about something else, then." linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_3_1"
