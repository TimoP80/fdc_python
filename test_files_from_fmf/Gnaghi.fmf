}
Node "Gnaghi_2_1c_08c"
notes "Increment the local variable Gnaghi_Story_Interrupt by 1."
is_wtg = false
{
NPCText "Haven't I already told you to quit flapping yer gums? Anyway. Back then, when I arrived, Sandover wasn't as organized as it is now when it came to scavenging. No idea how to plan a search, or cope in the wastes."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "How did they learn to scavenge more effectively?" linkto "Gnaghi_2_1c_B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[MORE]" linkto "Gnaghi_2_1c_09a"  notes ""
