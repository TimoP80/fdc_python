notes ""
is_wtg = false
{
NPCText "They usually pitch up topside, every [PERIOD BETWEEN TECH SUPPLIES CARAVAN'S VISITS] regular as clockwork on [DATE OF TECH SUPPLIES CARAVAN'S ARRIVAL]"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Where do you go to scavenge?" linkto "Gnaghi_2_1a_3b_1"  notes ""
