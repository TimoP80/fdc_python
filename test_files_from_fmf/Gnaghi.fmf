              }
}
Node "Gnaghi_2_1c_09a"
notes ""
is_wtg = false
{
NPCText "It took the know-how I'd picked up as a youngster and what I'd learned travelling out here to teach them the scavenging trade. I hate to think what would have become of the place if I hadn't turned up."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You've a pretty high opinion of your own abilities." linkto "Gnaghi_2_1c_10b"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[MORE]" linkto "Gnaghi_2_1c_10a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Maybe I should ask you about something else, instead." linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
