Node "Gnaghi_2_1c_12a_3"
notes ""
is_wtg = false
{
NPCText "...and when you return to the trap, make sure it's sprung before you dismantle it. Got it? Okay, I think that's all I can teach you."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Thanks, Gnaghi." linkto "Gnaghi_2_1c_12a_4"  notes ""
              }
}
Node "Gnaghi_2_1c_12a_4"
notes ""
is_wtg = false
{
NPCText "My pleasure. You know, you remind me of myself at your age in an odd kinda way."
 NPCFemaleText "Don't mention it, young lady. I just hope you don't have to call on those skills too often."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Can I ask you about something else?" linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
