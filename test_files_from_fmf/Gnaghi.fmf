}
Node "Gnaghi_2_1c_06a"
notes ""
is_wtg = false
{
NPCText "I'd heard about this place, Sandover, which serves as a kind of refuge for folks who find it hard to get along in other places in the wastes. I set out a-walking here."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "How did you find out about Sandover?" linkto "Gnaghi_2_1c_07b" conditions { LOCAL_VARIABLE Gnaghi_Story_Interrupt == 0 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How did you find out about Sandover?" linkto "Gnaghi_2_1c_07c_1" conditions { LOCAL_VARIABLE Gnaghi_Story_Interrupt >= 1 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[MORE]" linkto "Gnaghi_2_1c_07a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Maybe I should ask you about something else, instead." linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_2_1c_06b"
notes "Increment the local variable Gnaghi_Story_Interrupt by 1."
