Node "Gnaghi_2_1c_07c_2"
notes ""
is_wtg = false
{
NPCText "So where was I? Oh yeah. When I got here, Sandover was much the same as it is today. Except with fewer people living here, maybe."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "How many people lived here when you arrived?" linkto "Gnaghi_2_1c_B1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[MORE]" linkto "Gnaghi_2_1c_08a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Maybe I should ask you about something else, instead." linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
Node "Gnaghi_2_1c_08a"
notes ""
is_wtg = false
{
NPCText "'Course, back in them days, they weren't as organized as they are now when it came to scavenging. No idea how to plan a search, or cope in the wastes."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "How did they learn to scavenge more effectively?" linkto "Gnaghi_2_1c_09b_1" conditions { LOCAL_VARIABLE Gnaghi_Story_Interrupt <= 1 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "How did they learn to scavenge more effectively?" linkto "Gnaghi_2_1c_B1" conditions { LOCAL_VARIABLE Gnaghi_Story_Interrupt >= 2 link_next NONE } notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "[MORE]" linkto "Gnaghi_2_1c_09a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Maybe I should ask you about something else, instead." linkto "Gnaghi_9"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Goodbye." linkto "done"  notes ""
              }
}
