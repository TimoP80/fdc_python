Node "Gnaghi_2_1c_12a_2"
notes "Boost the PC's Outdoorsman skill by 10 or 15 points."
is_wtg = false
{
NPCText "[Several hours pass. Gnaghi teaches you many new wasteland survival techniques.]"
      options {
