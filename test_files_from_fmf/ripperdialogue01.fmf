          int=4 Reaction=REACTION_NEUTRAL playertext "You're nuts. I'll go find someone with a clear head to talk to. Goodbye." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Seriously, I think you should stop using drugs." linkto "waster2"  notes ""
              }
}
Node "waster5"
notes ""
is_wtg = false
