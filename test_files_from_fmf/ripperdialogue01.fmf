          int=4 Reaction=REACTION_NEUTRAL playertext "I want you to leave!" linkto "waster5"  notes ""
              }
}
Node "waster1"
notes ""
is_wtg = false
{
NPCText "The demon hippies will get you! They're everywhere!"
      options {
          int=0 Reaction=REACTION_NEUTRAL playertext "Demon hippies? Well then I really should leave immediately. Goodbye." linkto "done"  notes ""
          int=0 Reaction=REACTION_NEUTRAL playertext "What are you babbling about?" linkto "waster2"  notes ""
              }
}
Node "waster2"
notes ""
is_wtg = false
{
NPCText "They're real! DEEEEMON! DEEEEEMON! Hippies from hell!"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "You're sick dude, I'm outta here." linkto "done"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "There's one behind you! Run for your life!" linkto "waster3"  notes "Quest node"
          int=4 Reaction=REACTION_NEUTRAL playertext "Yes! I am their leader and I'm here to kill you. Now die!" linkto "combat"  notes ""
              }
}
