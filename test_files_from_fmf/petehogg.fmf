/*

    Fan Made Fallout Dialogue Tool
         dialogue script file

 -- hand editing this file is not recommended

 Created with version 0.27.1-stable

*/

NPCName "Pete Hogg"
Location "City of the Coast"
Description "Simoleon"
Unknown_Desc "An old man."
Known_Desc "It's Pete Hogg, the owner of the company."
Detailed_Desc "You see an old, unhealthy looking man with his face in a bitter scowl."
/* Dialogue starting conditions */

start_conditions
default_condition -1
{
cond target_node "Greeting"
{
    SSL "local_var(LVAR_Herebefore) == 0" var_param "" eval -1 value_to_check "" ini_index 6 link -1
},
cond target_node "Greetingknown"
{
    SSL "local_var(LVAR_Herebefore) == 1" var_param "" eval -1 value_to_check "" ini_index 9 link -1
}
};

/* Regular nodes */

Node "Switcher"
notes ""
is_wtg = true
{
NPCText "Which situation are you in"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "I've never met you before" linkto "Greeting"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I've heard about your coming demise and know about the two brothers" linkto "Quest1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Phil has the company" linkto "PhilOwner"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Ike has the company" linkto "IkeOwner"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Brothers share the Company" linkto "SharedOwnership"  notes ""
          int=5 Reaction=REACTION_NEUTRAL playertext "I'm dumb as a brick." linkto "DumbGreeting"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Phil has been killed and the PC hasn't spoken to Pete since." linkto "PhilKilled_1"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Ike has been killed and the PC hasn't spoken to Pete since." linkto "Ikekilled_1"  notes ""
              }
}
