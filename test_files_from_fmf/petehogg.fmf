{
NPCText "Answers? I don't have any. Get lost."
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Let me rephrase..." linkto "Greetingknown"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Forget about it." linkto "done"  notes ""
