      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Who's going to run the business now?" linkto "Ikekilled_3N"  notes ""
          int=4 Reaction=REACTION_BAD playertext "Best thing that could have happened to him." linkto "Ikekilled_3B"  notes ""
              }
}
