              }
}
Node "Bruce2_B_2"
notes ""
{
NPCText "You're not going anywhere until you've got this door open for us. *Bruce gestures towards Vault 31's huge blast door with the muzzle of his gun.*"
      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Just give me a second to talk to the people inside and it will be open." linkto "Bruce2_B_3a"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "Fuck you, Bruce!" linkto "Bruce2_B_3b"  notes ""
