      options {
          int=4 Reaction=REACTION_NEUTRAL playertext "Fair enough. Here's the gun and the money." linkto "Bruce2_2_4_4a"  notes "This node only appears if the PC has VALUE or more caps in his inventory."
          int=4 Reaction=REACTION_NEUTRAL playertext "That's way too much. No deal." linkto "Bruce2_2_4_3"  notes ""
          int=4 Reaction=REACTION_NEUTRAL playertext "I can't afford that much money." linkto "Bruce2_2_4_3"  notes ""
              }
}
